DASHBOARD_PASSWORD=change_this_strong_password_now
JWT_SECRET=generate_a_long_random_string_here_min_32_chars
JWT_EXPIRES_IN=8h

# ─── Business Config ──────────────────────────────────────────────────────────
BUSINESS_NAME=PrintHub Africa
