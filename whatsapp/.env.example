# ─── App ──────────────────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=development
BASE_URL=https://your-ngrok-or-domain.com                # Public URL (no trailing slash)
ALLOWED_ORIGINS=https://printhub.africa,http://localhost:3000

# ─── Dashboard Auth (change these!) ───────────────────────────────────────────
