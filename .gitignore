# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# Environment variables — NEVER commit these
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
.env.test
.env.seed

# dependencies
/node_modules
/.pnp
.pnp.js
.yarn/install-state.gz

# testing
/coverage
/test-results
/playwright-report

# next.js
/.next/
/out/
/build

# Prisma
prisma/dev.db
prisma/dev.db-journal

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# misc
.DS_Store
Thumbs.db
*.pem

# Editor
.vscode/
.idea/
*.swp
*.swo

# Uploads (never commit user files)
public/uploads/

# ERPNext Docker volumes (local only)
erpnext-data/

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

/lib/generated/prisma

# Personal / dev files — do not commit
Coursera*.pdf
*Cursor*Prompt*
*CursorAI*

# Sentry Config File
.env.sentry-build-plugin

# Archived/removed files — not part of the build
/archive/

# Docs folder
!/docs/
!/docs/*.md

# Only root README.md is committed; all other .md files are excluded from this repo by default
*.md
!/README.md
!/docs/*.md
