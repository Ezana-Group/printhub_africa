    "@types/three": "^0.183.1",
    "dotenv": "^17.3.1",
    "eslint": "^8",
    "eslint-config-next": "^15.5.0",
    "eslint-config-prettier": "^10.1.8",
    "postcss": "^8",
    "prettier": "^3.8.1",
    "tailwindcss": "^3.4.1",
    "tsx": "^4.21.0",
    "typescript": "^5"
  }
