{
  "name": "printhub",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev -p 3000",
    "build": "prisma generate && next build",
    "build:with-migrate": "prisma generate && prisma migrate deploy && next build",
    "start": "next start",
    "lint": "next lint",
    "format": "prettier --write .",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:push": "prisma db push",
    "db:seed": "tsx prisma/seed.ts",
    "db:reset": "prisma migrate reset",
    "db:studio": "prisma studio",
    "test": "jest",
    "test:coverage": "jest --coverage",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:all": "jest && playwright test",
    "test:lf-engine": "tsx lib/lf-calculator-engine.test.ts",
    "prepare": "husky",
    "docker:db": "docker compose up -d db",
    "docker:up": "docker compose up -d",
    "docker:down": "docker compose down",
    "erpnext:check": "bash scripts/check-docker.sh",
    "erpnext:start": "bash scripts/erpnext-start.sh",
    "erpnext:stop": "bash scripts/erpnext-stop.sh",
    "erpnext:reset": "bash scripts/erpnext-reset.sh",
    "erpnext:setup": "npx tsx scripts/erpnext-setup.ts",
    "erpnext:migrate": "npx tsx scripts/erpnext-migrate.ts",
    "erpnext:test": "npx tsx scripts/test-erpnext-connection.ts",
    "erpnext:logs": "docker compose -f docker-compose.erpnext.yml logs -f"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "lint-staged": {
    "*.{js,ts,tsx,json,css,md}": [
      "prettier --write"
    ]
  },
  "dependencies": {
    "@auth/prisma-adapter": "^2.11.1",
    "@aws-sdk/client-s3": "^3.700.0",
    "@aws-sdk/s3-request-presigner": "^3.700.0",
    "@prisma/adapter-pg": "^7.4.2",
    "@prisma/client": "^7.4.2",
    "@radix-ui/react-accordion": "^1.2.12",
    "@radix-ui/react-alert-dialog": "^1.1.15",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-switch": "^1.2.6",
    "@tanstack/react-query": "^5.90.21",
    "@tanstack/react-table": "^8.21.3",
    "bcryptjs": "^3.0.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "framer-motion": "^12.34.5",
    "lucide-react": "^0.576.0",
    "next": "14.2.35",
    "next-auth": "^4.24.13",
    "otplib": "^13.3.0",
    "pg": "^8.19.0",
    "prisma": "^7.4.2",
    "react": "^18",
    "react-dom": "^18",
    "react-email": "^5.2.9",
    "recharts": "^3.7.0",
    "resend": "^6.9.3",
    "tailwind-merge": "^3.5.0",
    "tailwindcss-animate": "^1.0.7",
    "zod": "^4.3.6",
    "zustand": "^5.0.11"
  },
  "overrides": {
    "hono": "^4.12.4",
    "@hono/node-server": "^1.19.11",
    "lodash": "4.17.23",
    "glob": "10.5.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/bcryptjs": "^2.4.6",
    "@types/jest": "^30.0.0",
    "@types/node": "^20",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "@types/supertest": "^7.2.0",
    "dotenv": "^17.3.1",
    "eslint": "^8",
    "eslint-config-next": "14.2.35",
    "eslint-config-prettier": "^10.1.8",
    "husky": "^9.1.7",
    "jest": "^30.2.0",
    "jest-environment-jsdom": "^30.2.0",
    "lint-staged": "^16.3.2",
    "postcss": "^8",
    "prettier": "^3.8.1",
    "supertest": "^7.2.2",
    "tailwindcss": "^3.4.1",
    "tsx": "^4.21.0",
    "typescript": "^5"
  }
}
