    "lucide-react": "^0.576.0",
    "next": "^15.5.12",
    "next-auth": "^4.24.13",
    "otplib": "^13.3.0",
    "pg": "^8.19.0",
    "prisma": "^7.5.0",
    "qrcode.react": "^4.2.0",
    "react": "^18",
    "react-dom": "^18",
    "recharts": "^3.7.0",
    "resend": "^6.9.3",
    "sharp": "^0.34.5",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "tailwindcss-animate": "^1.0.7",
    "three": "^0.183.2",
    "zod": "^4.3.6",
    "zustand": "^5.0.11"
