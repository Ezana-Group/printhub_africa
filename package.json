{
  "name": "printhub",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev -p 3000",
    "build": "prisma generate && next build",
    "build:with-migrate": "prisma generate && prisma migrate deploy && next build",
    "start": "next start",
    "lint": "eslint . --ext .js,.jsx,.ts,.tsx",
    "format": "prettier --write .",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:push": "prisma db push",
    "db:seed": "tsx prisma/seed.ts",
    "db:seed:legal": "tsx prisma/seeds/legal-pages.ts",
    "db:seed:email-templates": "tsx prisma/seeds/email-templates.ts",
    "db:seed:whatsapp-templates": "tsx prisma/seeds/whatsapp-templates.ts",
    "db:clean-test-data": "tsx prisma/scripts/clean-test-data.ts",
    "db:reset-catalogue": "PRINTHUB_SEED_ALLOW=1 tsx prisma/scripts/reset-catalogue.ts",
    "db:reset": "prisma migrate reset",
    "db:studio": "prisma studio",
    "docker:db": "docker compose up -d db",
    "docker:up": "docker compose up -d",
    "docker:down": "docker compose down",
    "erpnext:check": "bash scripts/check-docker.sh",
    "erpnext:start": "bash scripts/erpnext-start.sh",
    "erpnext:stop": "bash scripts/erpnext-stop.sh",
    "erpnext:reset": "bash scripts/erpnext-reset.sh",
    "erpnext:setup": "npx tsx scripts/erpnext-setup.ts",
    "erpnext:migrate": "npx tsx scripts/erpnext-migrate.ts",
    "erpnext:test": "npx tsx scripts/test-erpnext-connection.ts",
    "erpnext:logs": "docker compose -f docker-compose.erpnext.yml logs -f"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@auth/prisma-adapter": "^2.11.1",
    "@aws-sdk/client-s3": "^3.700.0",
