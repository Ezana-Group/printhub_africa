// ============== CAREERS ==============
enum JobType {
  FULL_TIME
  PART_TIME
  CONTRACT
  INTERNSHIP
  ATTACHMENT
}

enum JobStatus {
  DRAFT
  PUBLISHED
  PAUSED
  CLOSED
  FILLED
}

enum ApplicationStatus {
  NEW
  REVIEWING
  SHORTLISTED
  INTERVIEW_SCHEDULED
  INTERVIEWED
  OFFER_MADE
  HIRED
  REJECTED
  WITHDRAWN
}

model JobListing {
  id                   String           @id @default(cuid())
  title                String
  slug                 String           @unique
  department           String           // Production | Design | Sales | Operations | Tech
  type                 JobType
  location             String           @default("Nairobi, Kenya")
  isRemote             Boolean          @default(false)
  description          String          @db.Text
  responsibilities     String           @db.Text
  requirements         String           @db.Text
  niceToHave           String?          @db.Text
  salaryMin            Int?             // KES per month
  salaryMax            Int?             // KES per month
  showSalary           Boolean          @default(false)
  benefits             String[]         @default([])
  applicationDeadline  DateTime?
  status               JobStatus        @default(DRAFT)
  isFeatured           Boolean          @default(false)
  sortOrder            Int              @default(0)
  metaTitle            String?
  metaDescription      String?
  customQuestions      Json?            // [{ id, question, type, required, options? }]
  applications         JobApplication[]
  createdAt            DateTime         @default(now())
  updatedAt            DateTime         @updatedAt
  createdBy            String?
  publishedAt          DateTime?

  @@index([status])
  @@index([slug])
}

model JobApplication {
  id               String             @id @default(cuid())
  jobListingId     String
  jobListing       JobListing         @relation(fields: [jobListingId], references: [id], onDelete: Cascade)
  firstName        String
  lastName         String
  email            String
  phone            String
  location         String?
  coverLetter      String             @db.Text
  linkedinUrl      String?
  portfolioUrl     String?
  cvFileUrl        String             // R2 key or full URL
  cvFileName       String
  answers          Json?
  source           String?
  referredBy       String?
  status           ApplicationStatus  @default(NEW)
  internalNotes    String?            @db.Text
  reviewedBy       String?
  reviewedAt       DateTime?
  interviewDate    DateTime?
  interviewNotes   String?            @db.Text
  rejectionReason  String?            @db.Text
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt

  @@index([jobListingId])
  @@index([status])
}

