// ============== CATALOGUE (Print-on-Demand) ==============
enum CatalogueStatus {
  DRAFT
  PENDING_REVIEW
  LIVE
  PAUSED
  RETIRED
}

enum CatalogueSourceType {
  MANUAL
  PRINTABLES
  THINGIVERSE
  PARTNER
  ORIGINAL
}

enum CatalogueLicense {
  CC0
  CC_BY
  CC_BY_SA
  PARTNERSHIP
  ORIGINAL
}

model CatalogueCategory {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique
  icon        String?
  description String?
  imageUrl    String?
  sortOrder   Int      @default(0)
  isActive    Boolean  @default(true)

  items CatalogueItem[]

  @@index([slug])
}

model CatalogueDesigner {
  id         String   @id @default(cuid())
  name       String
  slug       String?  @unique
  username   String?
  platform   String?
  profileUrl String?

  items CatalogueItem[]
}

model CatalogueItem {
  id               String             @id @default(cuid())
  name             String
  slug             String             @unique
  shortDescription String?
  description      String?
  categoryId       String
  category         CatalogueCategory  @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  designerId       String?
  designer         CatalogueDesigner? @relation(fields: [designerId], references: [id])
  tags             String[]
  sourceUrl        String?
  licenseType      CatalogueLicense   @default(CC_BY)
  designerCredit   String?
  sourceType       CatalogueSourceType @default(MANUAL)
  status           CatalogueStatus    @default(DRAFT)
  minQuantity      Int                @default(1)
  maxQuantity      Int                @default(50)
  isFeatured       Boolean            @default(false)
  isNewArrival     Boolean            @default(false)
  isStaffPick      Boolean            @default(false)
  isPopular        Boolean            @default(false)
  sortOrder        Int                @default(0)
  basePriceKes     Float?
  priceOverrideKes Float?
  weightGrams      Float?
  printTimeHours   Float?
  metaTitle        String?
  metaDescription  String?
  approvedBy       String?
  approvedAt       DateTime?
  rejectedBy       String?
  rejectionReason  String?       @db.Text
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt

  photos            CatalogueItemPhoto[]
  availableMaterials CatalogueItemMaterial[]

  @@index([categoryId])
  @@index([status])
  @@index([slug])
}

model CatalogueItemPhoto {
  id              String        @id @default(cuid())
  catalogueItemId String
  catalogueItem   CatalogueItem  @relation(fields: [catalogueItemId], references: [id], onDelete: Cascade)
  url             String
  storageKey      String?
  altText         String?
  sortOrder       Int            @default(0)
  isPrimary       Boolean        @default(false)
  sourceUrl       String?

  @@index([catalogueItemId])
}

model CatalogueItemMaterial {
  id                String        @id @default(cuid())
  catalogueItemId   String
  catalogueItem     CatalogueItem @relation(fields: [catalogueItemId], references: [id], onDelete: Cascade)
  materialCode      String
  materialName      String
  priceModifierKes  Float?        @default(0)
  isDefault         Boolean       @default(false)
  isAvailable       Boolean       @default(true)
  availableColours   Json?         // array of colour hex or names

  @@index([catalogueItemId])
}

enum ImportStatus {
  PENDING
  PROCESSING
  DONE
  FAILED
}

model CatalogueImportQueue {
  id        String       @id @default(cuid())
  status    ImportStatus @default(PENDING)
  sourceUrl String?
  stlStorageKey String?
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt

  @@index([status])
}

// ============== CAREERS ==============
enum JobStatus {
  DRAFT
  PUBLISHED
  PAUSED
  CLOSED
  FILLED
}

enum JobType {
  FULL_TIME
  PART_TIME
  CONTRACT
  INTERNSHIP
  ATTACHMENT
}

enum ApplicationStatus {
  NEW
  REVIEWING
  SHORTLISTED
  INTERVIEW_SCHEDULED
  INTERVIEWED
  OFFER_MADE
  HIRED
  REJECTED
  WITHDRAWN
}

model JobListing {
  id                  String    @id @default(cuid())
  title               String
  slug                String    @unique
  department          String
  type                JobType
  location            String    @default("Nairobi, Kenya")
  isRemote            Boolean   @default(false)
  description         String
  responsibilities    String
  requirements        String
  niceToHave          String?
  salaryMin           Int?
  salaryMax           Int?
  showSalary          Boolean   @default(false)
  benefits            Json?     // array of strings
  applicationDeadline DateTime?
  status              JobStatus @default(DRAFT)
  isFeatured          Boolean   @default(false)
  sortOrder           Int       @default(0)
  metaTitle           String?
  metaDescription     String?
  customQuestions     Json?
  publishedAt         DateTime?
  createdBy           String?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  applications JobApplication[]

  @@index([status])
  @@index([slug])
}

model JobApplication {
  id             String            @id @default(cuid())
  jobListingId   String
  jobListing     JobListing        @relation(fields: [jobListingId], references: [id], onDelete: Cascade)
  firstName      String
  lastName       String
  email          String
  phone          String?
  location       String?
  coverLetter    String?
  linkedinUrl    String?
  portfolioUrl   String?
  cvFileUrl      String?
  cvFileName     String?
  answers        Json?
  source         String?
  referredBy     String?
  status           ApplicationStatus @default(NEW)
  internalNotes    String?
  reviewedBy       String?
  reviewedAt       DateTime?
  rejectionReason  String?
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt

  @@index([jobListingId])
  @@index([status])
  @@index([email])
}
