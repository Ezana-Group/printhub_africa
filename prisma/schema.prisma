model EmailThread {
  id            String       @id @default(cuid())
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
  createdById   String?
  isActive      Boolean      @default(true)
  label         String
  subject       String
  customerName  String?
  customerEmail String
  mailboxId     String
  assignedToId  String?
