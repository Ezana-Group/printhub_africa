  Supplier              Supplier?             @relation(fields: [supplierId], references: [id])
  HardwareVariant       HardwareVariant[]
  OrderItem             OrderItem[]
  StockMovement         StockMovement[]
  WarrantyRecord        WarrantyRecord[]
}

model HardwareVariant {
  id              String          @id
  productId       String
  name            String
  sku             String?         @unique
  priceDiff       Decimal         @default(0) @db.Decimal(10, 2)
  stockQty        Int             @default(0)
  attributes      Json
  isActive        Boolean         @default(true)
  reservedQty     Int             @default(0)
  HardwareProduct HardwareProduct @relation(fields: [productId], references: [id])
}

model NavigationItem {
  id                   String           @id
  label                String
  href                 String
  parentId             String?
  sortOrder            Int              @default(0)
  isActive             Boolean          @default(true)
  NavigationItem       NavigationItem?  @relation("NavigationItemToNavigationItem", fields: [parentId], references: [id], onDelete: Cascade)
  other_NavigationItem NavigationItem[] @relation("NavigationItemToNavigationItem")

  @@index([parentId])
}

model StockMovement {
  id              String            @id
  productId       String
  type            StockMovementType
  qty             Int
  reason          String?
  reference       String?
  performedBy     String
  notes           String?
  createdAt       DateTime          @default(now())
  HardwareProduct HardwareProduct   @relation(fields: [productId], references: [id])
}

model Supplier {
  id                 String              @id
  name               String
  slug               String              @unique
  type               SupplierType
  country            String?
  contactName        String?
  contactEmail       String?
  contactPhone       String?
  website            String?
  apiType            SupplierApiType?
  apiEndpoint        String?
  apiKeyEncrypted    String?
  apiNotes           String?
  importTemplate     Json?
  leadTimeDays       Int?
  paymentTerms       String?
  notes              String?
  isActive           Boolean             @default(true)
  isAuthorised       Boolean             @default(false)
  dealerAgreementUrl String?
  createdAt          DateTime            @default(now())
  updatedAt          DateTime
  HardwareProduct    HardwareProduct[]
  SupplierImportLog  SupplierImportLog[]
}

model SupplierImportLog {
  id              String            @id
  supplierId      String
  method          ImportMethod
  fileName        String?
  totalRows       Int               @default(0)
  imported        Int               @default(0)
  updated         Int               @default(0)
  skipped         Int               @default(0)
  errors          Json?
  columnMapping   Json?
  triggeredBy     String
  createdAt       DateTime          @default(now())
  HardwareProduct HardwareProduct[]
  Supplier        Supplier          @relation(fields: [supplierId], references: [id])
}

model WarrantyRecord {
  id              String          @id
  productId       String
  orderId         String?
  customerId      String
  serialNumber    String?
  purchaseDate    DateTime
  warrantyEndsAt  DateTime
  status          WarrantyStatus  @default(ACTIVE)
  claimHistory    Json?
  notes           String?
  createdAt       DateTime        @default(now())
  updatedAt       DateTime
  HardwareProduct HardwareProduct @relation(fields: [productId], references: [id])
}

model StockNotification {
  id         String    @id @default(cuid())
  email      String?
  phone      String?
  productId  String
  createdAt  DateTime  @default(now())
  notifiedAt DateTime?
  product    Product   @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId])
  @@index([email])
  @@index([phone])
}

model MarketingErrorLog {
  id        String   @id @default(cuid())
  channel   String
  error     String
  payload   Json?
  createdAt DateTime @default(now())

  @@index([channel])
  @@index([createdAt])
}

model ProductMockup {
  id         String    @id @default(cuid())
  productId  String
  platform   String
  imageUrl   String
  generator  String
  prompt     String
  isApproved Boolean   @default(false)
  isUsed     Boolean   @default(false)
  approvedAt DateTime?
  approvedBy String?
  createdAt  DateTime  @default(now())
  product    Product   @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId])
  @@index([isApproved])
  @@index([platform])
}

model ProductVideo {
  id           String    @id @default(cuid())
  productId    String
  platform     String
  videoUrl     String
  audioUrl     String?
  thumbnailUrl String?
  duration     Int?
  isApproved   Boolean   @default(false)
  isPosted     Boolean   @default(false)
  approvedAt   DateTime?
  createdAt    DateTime  @default(now())
  product      Product   @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId])
  @@index([platform])
  @@index([isApproved])
}

model ContentCalendar {
  id              String   @id @default(cuid())
  weekStarting    DateTime
  strategy        Json
  contentCalendar Json
  generatedBy     String   @default("ai")
  createdAt       DateTime @default(now())

  @@index([weekStarting])
}

model AiServiceLog {
  id           String   @id @default(cuid())
  service      String
  operation    String
  model        String?
  inputTokens  Int?     @default(0)
  outputTokens Int?     @default(0)
  imageCount   Int?     @default(0)
  audioChars   Int?     @default(0)
  durationSecs Int?     @default(0)
  costUsd      Float?   @default(0)
  success      Boolean  @default(true)
  error        String?
  entityId     String?
  entityType   String?
  createdAt    DateTime @default(now())

  @@index([service])
  @@index([createdAt])
  @@index([success])
  @@index([entityId])
}

