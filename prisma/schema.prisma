  faqs      Faq[]

  @@index([slug])
}

model Faq {
  id         String      @id @default(cuid())
  categoryId String
  question   String
  answer     String
  isPopular  Boolean     @default(false)
  sortOrder  Int         @default(0)
  isActive   Boolean     @default(true)
  updatedBy  String?
  category   FaqCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@index([categoryId])
}

model LegalPage {
  id          String             @id @default(cuid())
  slug        String             @unique
  title       String?
  content     String             @default("")
  version     Int                @default(1)
  lastUpdated DateTime?
  updatedBy   String?
  isPublished Boolean            @default(false)
  history     LegalPageHistory[]

  @@index([slug])
}

model LegalPageHistory {
  id          String    @id @default(cuid())
  legalPageId String
  content     String
  version     Int
  savedBy     String?
  changeNote  String?
  createdAt   DateTime  @default(now())
  legalPage   LegalPage @relation(fields: [legalPageId], references: [id], onDelete: Cascade)

  @@index([legalPageId])
}

model EmailTemplate {
  id          String   @id @default(cuid())
  slug        String   @unique
  name        String
  description String?
  subject     String   @default("")
  bodyHtml    String
  updatedAt   DateTime @updatedAt
  updatedBy   String?

  @@index([slug])
}

model DatabaseGuard {
  id        String   @id
  project   String
  updatedAt DateTime @updatedAt
}

model CatalogueCategory {
  id          String          @id @default(cuid())
  name        String
  slug        String          @unique
  icon        String?
  sortOrder   Int             @default(0)
  isActive    Boolean         @default(true)
  description String?
  imageUrl    String?
  items       CatalogueItem[]

  @@index([slug])
}

model CatalogueDesigner {
  id         String          @id @default(cuid())
  name       String
  slug       String?         @unique
  platform   String?
  profileUrl String?
  username   String?
  items      CatalogueItem[]
}

model CatalogueItem {
  id                 String                  @id @default(cuid())
  name               String
  slug               String                  @unique
  shortDescription   String?
  description        String?
  categoryId         String
  designerId         String?
  tags               String[]
  sourceUrl          String?
  licenseType        CatalogueLicense        @default(CC_BY)
  designerCredit     String?
  sourceType         CatalogueSourceType     @default(MANUAL)
  status             CatalogueStatus         @default(DRAFT)
  minQuantity        Int                     @default(1)
  maxQuantity        Int                     @default(50)
  isFeatured         Boolean                 @default(false)
  isNewArrival       Boolean                 @default(false)
  isStaffPick        Boolean                 @default(false)
  sortOrder          Int                     @default(0)
  createdAt          DateTime                @default(now())
  updatedAt          DateTime                @updatedAt
  basePriceKes       Float?
  isPopular          Boolean                 @default(false)
  metaDescription    String?
  metaTitle          String?
  priceOverrideKes   Float?
  printTimeHours     Float?
  weightGrams        Float?
  approvedBy         String?
  approvedAt         DateTime?
  rejectedBy         String?
  rejectionReason    String?
  category           CatalogueCategory       @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  designer           CatalogueDesigner?      @relation(fields: [designerId], references: [id])
  availableMaterials CatalogueItemMaterial[]
  photos             CatalogueItemPhoto[]

  @@index([categoryId])
  @@index([status])
  @@index([slug])
}

model CatalogueItemPhoto {
  id              String        @id @default(cuid())
  catalogueItemId String
  url             String
  isPrimary       Boolean       @default(false)
  sortOrder       Int           @default(0)
  storageKey      String?
  altText         String?
  sourceUrl       String?
  catalogueItem   CatalogueItem @relation(fields: [catalogueItemId], references: [id], onDelete: Cascade)

  @@index([catalogueItemId])
}

model CatalogueItemMaterial {
  id               String        @id @default(cuid())
  catalogueItemId  String
  materialCode     String
  materialName     String
  priceModifierKes Float?        @default(0)
  isDefault        Boolean       @default(false)
  isAvailable      Boolean       @default(true)
  availableColours Json?
  catalogueItem    CatalogueItem @relation(fields: [catalogueItemId], references: [id], onDelete: Cascade)

  @@index([catalogueItemId])
}

model CatalogueImportQueue {
  id            String       @id @default(cuid())
  status        ImportStatus @default(PENDING)
  sourceUrl     String?
  stlStorageKey String?
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  @@index([status])
}

model JobListing {
  id                  String           @id @default(cuid())
  title               String
  slug                String           @unique
  department          String
  type                JobType
  location            String           @default("Nairobi, Kenya")
  isRemote            Boolean          @default(false)
  description         String
  responsibilities    String
  requirements        String
  niceToHave          String?
  salaryMin           Int?
  salaryMax           Int?
  showSalary          Boolean          @default(false)
  applicationDeadline DateTime?
  status              JobStatus        @default(DRAFT)
  isFeatured          Boolean          @default(false)
  sortOrder           Int              @default(0)
  metaTitle           String?
  metaDescription     String?
  customQuestions     Json?
  createdAt           DateTime         @default(now())
  updatedAt           DateTime         @updatedAt
  publishedAt         DateTime?
  benefits            Json?
  createdBy           String?
  applications        JobApplication[]

  @@index([status])
  @@index([slug])
}

model JobApplication {
  id              String            @id @default(cuid())
  jobListingId    String
  firstName       String
  lastName        String
  email           String
  phone           String?
  location        String?
  coverLetter     String?
  linkedinUrl     String?
  portfolioUrl    String?
  cvFileUrl       String?
  cvFileName      String?
  answers         Json?
  source          String?
  referredBy      String?
  status          ApplicationStatus @default(NEW)
  internalNotes   String?
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  rejectionReason String?
  reviewedAt      DateTime?
  reviewedBy      String?
  jobListing      JobListing        @relation(fields: [jobListingId], references: [id], onDelete: Cascade)

  @@index([jobListingId])
  @@index([status])
  @@index([email])
}

model EmailAddress {
  id        String               @id @default(cuid())
  address   String               @unique
  label     String
  isActive  Boolean              @default(true)
  createdAt DateTime             @default(now())
  updatedAt DateTime             @updatedAt
  viewers   EmailMailboxViewer[]
  threads   EmailThread[]
}

model EmailThread {
  id            String       @id @default(cuid())
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
  createdById   String
  isActive      Boolean      @default(true)
  label         String
  subject       String
  customerName  String?
  customerEmail String
  mailboxId     String
  assignedToId  String?
  hasUnread     Boolean      @default(true)
  status        ThreadStatus @default(OPEN)
  emails        Email[]
  assignedTo    User?        @relation("AssignedThreads", fields: [assignedToId], references: [id])
  createdBy     User         @relation("EmailThreadCreatedBy", fields: [createdById], references: [id])
  mailbox       EmailAddress @relation(fields: [mailboxId], references: [id])

  @@index([mailboxId])
  @@index([customerEmail])
  @@index([status])
  @@index([assignedToId])
  @@index([updatedAt])
}

model Email {
  id              String         @id @default(cuid())
  sentAt          DateTime       @default(now())
  threadId        String
  isRead          Boolean        @default(false)
  direction       EmailDirection
  resendMessageId String?        @unique
  bodyText        String?
  bodyHtml        String
  subject         String
  cc              String?
  toAddress       String
  fromAddress     String
  attachments     Json           @default("[]")
  thread          EmailThread    @relation(fields: [threadId], references: [id], onDelete: Cascade)
}

model EmailMailboxViewer {
  id        String       @id @default(cuid())
  mailboxId String
  userId    String
  createdAt DateTime     @default(now())
  mailbox   EmailAddress @relation(fields: [mailboxId], references: [id], onDelete: Cascade)
  user      User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([mailboxId, userId])
  @@index([userId])
  @@index([mailboxId])
}

model PrinterMaterialType {
  id        String   @id
  name      String
  slug      String   @unique
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime
}

