// PrintHub — printhub.africa | An Ezana Group Company
// Prisma schema — PostgreSQL

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ============== USERS & AUTH ==============
enum UserRole {
  CUSTOMER
  STAFF
  ADMIN
  SUPER_ADMIN
}

model User {
  id                  String    @id @default(cuid())
  name                String?
  email               String    @unique
  phone               String? // Kenya +254 format
  passwordHash        String?
  role                UserRole  @default(CUSTOMER)
  emailVerified       DateTime?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt
  profileImage        String?
  loyaltyPoints       Int       @default(0)
  preferredLanguage   String?   @default("en")
  failedLoginAttempts Int       @default(0)
  lockedUntil         DateTime?
  // Staff invite
  inviteToken         String?
  inviteTokenExpiry   DateTime?
  status              String?   @default("ACTIVE") // ACTIVE | INVITE_PENDING | DEACTIVATED
  totpSecret          String?   // 2FA TOTP secret
  dateOfBirth         DateTime?
  isAnonymised        Boolean?  @default(false)
  anonymisedAt        DateTime?
  stripeCustomerId    String?   // Stripe Customer ID for saved cards
  acceptedTermsAt    DateTime?  // When user accepted Account Registration Terms at signup
  termsVersion       String?   // Version of terms accepted (e.g. "1.0")
  marketingConsent   Boolean   @default(false)
  marketingConsentAt DateTime?

  accounts         Account[]
  sessions         Session[]
  addresses        Address[]
  orders           Order[]
  productReviews   ProductReview[]
  uploadedFiles    UploadedFile[]
  printQuotes      PrintQuote[]
  quotes           Quote[]
  quotesCancelledByAdmin Quote[]        @relation("QuoteCancelledByAdmin")
  quoteCancellations    QuoteCancellation[]
  couponUsages     CouponUsage[]
  wishlists        Wishlist[]
  notifications    Notification[]
  primaryCorporateAccount  CorporateAccount?       @relation("CorporatePrimaryContact")
  corporateTeamMemberships CorporateTeamMember[]
  corporateApplications    CorporateApplication[]
  staff                    Staff?
  supportTickets   SupportTicket[]
  ticketMessages   TicketMessage[]
  auditLogs        AuditLog[]
  savedAddresses     SavedAddress[]
  savedMpesaNumbers  SavedMpesaNumber[]
  savedCards         SavedCard[]
  referralCodes      ReferralCode[]
  loyaltyAccount     LoyaltyAccount?
  userNotificationPrefs UserNotificationPrefs?
  userPermissions     UserPermission[]
  performedByMovements ThreeDConsumableMovement[]
}

model Address {
  id         String   @id @default(cuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  label      String // Home, Office
  street     String
  city       String
  county     String
  postalCode String?
  isDefault  Boolean  @default(false)
  lat        Float?
  lng        Float?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([userId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ============== PRODUCTS & CATALOG ==============
model Category {
  id              String     @id @default(cuid())
  name            String
  slug            String     @unique
  description     String?
  image           String?
  parentId        String?
  parent          Category?  @relation("CategoryTree", fields: [parentId], references: [id])
  children        Category[] @relation("CategoryTree")
  sortOrder       Int        @default(0)
  isActive        Boolean    @default(true)
  metaTitle       String?
  metaDescription String?
  products        Product[]

  @@index([parentId])
}

enum ProductType {
  READYMADE_3D
  LARGE_FORMAT
  CUSTOM
}

model Product {
  id               String      @id @default(cuid())
  name             String
  slug             String      @unique
  description      String?
  shortDescription String?
  categoryId       String
  category         Category    @relation(fields: [categoryId], references: [id])
  productType      ProductType
  images           String[] // URLs
  basePrice        Decimal     @db.Decimal(12, 2)
  comparePrice     Decimal?    @db.Decimal(12, 2)
  costPrice        Decimal?    @db.Decimal(12, 2) // shop COGS — used for margin, not print calculators
  sku                 String?     @unique
  stock                Int         @default(0)
  lowStockThreshold    Int         @default(0) // alert when below this (shop products)
  minOrderQty          Int         @default(1)
  maxOrderQty      Int?
  weight           Decimal?    @db.Decimal(10, 3)
  dimensions       Json? // { length, width, height } in cm
  materials        String[]
  colors           String[]
  finishes         String[]
  isActive         Boolean     @default(true)
  isFeatured       Boolean     @default(false)
  metaTitle        String?
  metaDescription  String?
  tags             String[]
  createdAt        DateTime    @default(now())
  updatedAt        DateTime    @updatedAt

  variants           ProductVariant[]
  productImages      ProductImage[]
  reviews            ProductReview[]
  orderItems         OrderItem[]
  wishlists          Wishlist[]
  inventory          Inventory[]
  shopStockMovements ShopInventoryMovement[]
  shopPOLines        ShopPurchaseOrderLine[]

  @@index([categoryId])
  @@index([slug])
  @@index([isFeatured, isActive])
  @@index([isActive])
  @@index([createdAt])
  @@index([basePrice])
}

model ProductVariant {
  id         String   @id @default(cuid())
  productId  String
  product    Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  name       String
  sku        String?  @unique
  price      Decimal  @db.Decimal(12, 2)
  stock      Int      @default(0)
  attributes Json // { color, size, material }
  image      String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  orderItems OrderItem[]
  inventory  Inventory[]

  @@index([productId])
}

model ProductImage {
  id         String  @id @default(cuid())
  productId  String
  product    Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  url        String
  storageKey String?
  uploadId   String?
  altText    String?
  sortOrder  Int     @default(0)
  isPrimary  Boolean @default(false)

  @@index([productId])
}

model ProductReview {
  id         String   @id @default(cuid())
  productId  String
  product    Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  rating     Int
  title      String?
  body       String?
  images     String[]
  isVerified Boolean  @default(false)
  isApproved Boolean  @default(false)
  createdAt  DateTime @default(now())

  @@index([productId])
  @@index([userId])
}

// ============== 3D PRINTING ==============
enum PrintMaterialType {
  PLA
  ABS
  PETG
  RESIN
  NYLON
  TPU
}

model PrintMaterial {
  id             String            @id @default(cuid())
  slug           String?           @unique // PLA_STD, PETG, RESIN_STD, etc.
  name           String
  description    String?
  type           PrintMaterialType
  colorOptions   String[]
  pricePerGram   Decimal           @db.Decimal(10, 4)
  density        Float?            // g/cm³ for weight estimate
  minChargeGrams Int?             // minimum billable grams
  leadTimeDays   Int               @default(3)
  image          String?
  properties     Json?
  sortOrder      Int               @default(0)
  isActive       Boolean           @default(true)
}

model PrintFinish {
  id            String  @id @default(cuid())
  name          String
  description   String?
  priceModifier Decimal @default(0) @db.Decimal(10, 2)
  isActive      Boolean @default(true)
}

// ============== LARGE FORMAT ==============
model PrintingMedium {
  id              String   @id @default(cuid())
  slug            String?  @unique // e.g. vinyl, canvas — used by instant quote calculator
  name            String // Vinyl Banner, Canvas, etc.
  pricePerSqMeter Decimal  @db.Decimal(12, 2)
  minWidth        Float? // cm
  maxWidth        Float?
  minHeight       Float?
  maxHeight       Float?
  description     String?
  sortOrder       Int      @default(0)
  isActive        Boolean  @default(true)
}

model LaminationType {
  id            String   @id @default(cuid())
  slug          String?  @unique // NONE, LAM_GLOSS, LAM_MATTE, LAM_ASCRATCH
  name          String
  pricePerSqm   Decimal  @default(0) @db.Decimal(10, 2) // KES per sqm
}

// Large format finishing add-ons (per unit)
model LargeFormatFinishing {
  id           String  @id @default(cuid())
  code         String  @unique // EYELET_STD, HEM_4, etc.
  name         String
  pricePerUnit Decimal @db.Decimal(10, 2)
  sortOrder    Int     @default(0)
  isActive     Boolean @default(true)
}

// Large format design / artwork setup (flat fee)
model DesignServiceOption {
  id       String  @id @default(cuid())
  code     String  @unique // NONE, DESIGN_MIN, DESIGN_STD, etc.
  name     String
  flatFee  Decimal @default(0) @db.Decimal(10, 2)
  sortOrder Int    @default(0)
  isActive Boolean @default(true)
}

// Rush / turnaround surcharge (% on print subtotal)
model TurnaroundOption {
  id               String   @id @default(cuid())
  code             String   @unique // STD, EXPRESS_1, EXPRESS_SD, etc.
  name             String
  surchargePercent Decimal  @default(0) @db.Decimal(5, 2)
  serviceType      String   // LARGE_FORMAT | THREE_D
  sortOrder        Int      @default(0)
  isActive         Boolean  @default(true)
}

// ============== LARGE FORMAT COST ENGINE ==============
// Printer machine settings — speed, depreciation, electricity, ink
model LFPrinterSettings {
  id                        String   @id @default(cuid())
  name                      String   // "Roland VG3-540"
  model                     String
  isActive                  Boolean  @default(true)
  isDefault                 Boolean  @default(false)
  maxPrintWidthM            Float    // 1.52
  printSpeedSqmPerHour      Float    // 15 (production)
  printSpeedHighQualSqmHr    Float?   // 8 (high quality)
  setupTimeHours            Float    @default(0.25)
  purchasePriceKes          Float
  lifespanHours             Float    @default(20000)
  annualMaintenanceKes      Float
  powerWatts                Float
  electricityRateKesKwh     Float    @default(24)
  inkChannelSettings        Json?    // { "C": { bottleMl, costKes, sqmPerBottle }, ... }
  updatedBy                 String?
  updatedAt                 DateTime @updatedAt
  createdAt                 DateTime @default(now())
}

// Business settings — labour, overhead, waste, profit, VAT
model LFBusinessSettings {
  id                        String   @id @default(cuid())
  labourRateKesPerHour      Float    @default(200)
  finishingTimeEyeletStd    Float    @default(0.1)
  finishingTimeEyeletHeavy  Float    @default(0.2)
  finishingTimeHemAll4      Float    @default(0.25)
  finishingTimeHemTop2      Float    @default(0.15)
  finishingTimePole         Float    @default(0.2)
  finishingTimeRope          Float    @default(0.1)
  monthlyRentKes            Float
  monthlyUtilitiesKes       Float
  monthlyInsuranceKes       Float
  monthlyOtherKes            Float
  workingDaysPerMonth       Int      @default(26)
  workingHoursPerDay       Int      @default(8)
  wastageBufferPercent      Float    @default(3)
  substrateWasteFactor      Float    @default(1.05)
  rigidSheetWasteFactor     Float    @default(1.1)
  defaultProfitMarginPct    Float    @default(40)
  vatRatePct                Float    @default(16)
  minOrderValueKes          Float    @default(500)
  updatedBy                 String?
  updatedAt                 DateTime @updatedAt
}

// Large format stock items — substrates, lamination, eyelets, tape, etc.
// Cost flows into calculator via averageCostKes (weighted average on receive)
model LFStockItem {
  id                      String   @id @default(cuid())
  code                    String   @unique // VINYL_OUTDOOR_152, LAM_GLOSS, EYELET_STD, HEM_TAPE
  name                    String
  category                String   // SUBSTRATE_ROLL | LAMINATION | FINISHING | INK
  unitType                String   // ROLL_LM | SHEET | UNIT | BOTTLE_ML
  rollWidthM              Float?   // for ROLL_LM — width in metres
  quantityOnHand          Float    @default(0)
  lowStockThreshold       Float    @default(0)
  costPerUnit             Float    @default(0)   // KES per unit (lm, sheet, etc.)
  lastPurchasePriceKes    Float?
  averageCostKes          Float    @default(0)   // weighted average
  totalUnitsEverPurchased Float    @default(0)
  totalCostEverPurchased  Float    @default(0)
  lastReceivedAt         DateTime?
  printerAssetId          String?  // optional: part/accessory linked to this printer
  replacementIntervalHours Float?  // wear part: replace every X machine hours
  lastReplacedAt          DateTime?
  nextReplacementDue      DateTime?
  createdAt               DateTime @default(now())
  updatedAt               DateTime @updatedAt

  maintenancePartUsages   MaintenancePartUsed[]
}

// 3D machine hourly rate
model MachineType {
  id          String   @id @default(cuid())
  code        String   @unique // FDM_STD, RESIN, etc.
  name        String
  ratePerHour Decimal  @db.Decimal(10, 2)
  sortOrder   Int      @default(0)
  isActive    Boolean  @default(true)
}

// 3D post-processing: support removal or finishing (per unit)
model ThreeDAddon {
  id           String  @id @default(cuid())
  code         String  @unique // SUP_RM_BASIC, SAND_LT, PAINT_1, etc.
  name         String
  pricePerUnit Decimal @db.Decimal(10, 2)
  category     String  // SUPPORT_REMOVAL | FINISHING
  sortOrder    Int     @default(0)
  isActive     Boolean @default(true)
}

// Global pricing config (VAT, minimums, etc.)
model PricingConfig {
  id        String @id @default(cuid())
  key       String @unique // vatRate, minOrderLargeFormat, minOrder3D, quantityDiscountTiers
  valueJson String // JSON value
}

// ============== ORDERS ==============
enum OrderStatus {
  PENDING
  CONFIRMED
  PROCESSING
  PRINTING
  QUALITY_CHECK
  READY_FOR_COLLECTION
  SHIPPED
  DELIVERED
  CANCELLED
  REFUNDED
}

enum OrderType {
  SHOP
  CUSTOM_PRINT  // legacy; prefer 3D_PRINT for new orders
  LARGE_FORMAT
  THREE_D_PRINT // 3D print jobs (custom FDM/resin)
  QUOTE
  POD           // Print on demand (catalogue)
}

model Order {
  id                String      @id @default(cuid())
  orderNumber       String      @unique // PHUB-XXXXXXX
  userId            String?
  user              User?       @relation(fields: [userId], references: [id])
  status            OrderStatus @default(PENDING)
  type              OrderType
  subtotal          Decimal     @db.Decimal(12, 2)
  tax               Decimal     @default(0) @db.Decimal(12, 2) // 16% VAT
  shippingCost      Decimal     @default(0) @db.Decimal(12, 2)
  discount          Decimal     @default(0) @db.Decimal(12, 2)
  total             Decimal     @db.Decimal(12, 2)
  currency          String      @default("KES")
  notes             String?
  estimatedDelivery DateTime?
  createdAt         DateTime    @default(now())
  updatedAt         DateTime    @updatedAt

  // Cancellation
  cancelledAt   DateTime?
  cancelReason  String?

  // Manual payment (admin-confirmed outside system)
  manualPaymentRef    String?
  manualPaymentNotes String?
  manualPaymentBy    String?

  // Payment link for recovery (valid 24h)
  paymentLinkToken    String?
  paymentLinkExpiresAt DateTime?

  // Last M-Pesa failure reason (from callback resultDesc)
  mpesaFailureReason String?

  // Fulfilment
  trackingNumber String?
  shippedAt      DateTime?
  deliveredAt    DateTime?
  paidAt         DateTime?

  // Payment method and status (shop orders)
  paymentMethod  String?   // MPESA_STK | MPESA_PAYBILL | MPESA_TILL | CARD_PESAPAL | CARD_FLUTTERWAVE | CASH_ON_PICKUP | BANK_TRANSFER
  paymentStatus  String?   // PENDING | PROCESSING | AWAITING_CONFIRMATION | CONFIRMED | FAILED | REFUNDED | CANCELLED
  pickupCode     String?   // 4-digit code for pay-on-pickup
  pickupLocationId String?
  pickupLocation   PickupLocation? @relation(fields: [pickupLocationId], references: [id])
  courierId        String?   // Customer's preferred courier location (from checkout) or assigned courier
  courier          Courier? @relation(fields: [courierId], references: [id])
  deliveryZoneId   String?   // Zone used for shipping fee (STANDARD/EXPRESS)
  deliveryZone     DeliveryZone? @relation(fields: [deliveryZoneId], references: [id])
  delivery         Delivery? // Full delivery record (status, dispatched, proof, etc.)

  corporateId         String?
  corporate           CorporateAccount? @relation(fields: [corporateId], references: [id])
  poReference         String?
  corporatePOId       String?
  corporatePO         CorporatePO?      @relation(fields: [corporatePOId], references: [id])
  corporateInvoiceId  String?
  corporateInvoice    CorporateInvoice? @relation(fields: [corporateInvoiceId], references: [id])
  placedBy            String?
  isNetTerms          Boolean           @default(false)

  items              OrderItem[]
  timeline           OrderTimeline[]
  trackingEvents     OrderTrackingEvent[]
  shippingAddress    ShippingAddress?
  payments           Payment[]
  refunds            Refund[]
  invoices           Invoice[]
  cancellation       Cancellation?

  @@index([status])
  @@index([createdAt])
  @@index([userId])
  @@index([orderNumber])
  @@index([paymentStatus])
}

model OrderItem {
  id             String   @id @default(cuid())
  orderId        String
  order          Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId      String?
  product        Product? @relation(fields: [productId], references: [id])
  variantId      String?
  quantity       Int
  unitPrice      Decimal  @db.Decimal(12, 2)
  customizations Json?
  uploadedFileId String?
  instructions   String?
  createdAt      DateTime @default(now())

  productionQueue  ProductionQueue[]
  productVariant   ProductVariant?   @relation(fields: [productVariantId], references: [id])
  productVariantId String?

  @@index([orderId])
}

model OrderTimeline {
  id        String   @id @default(cuid())
  orderId   String
  order     Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  status    String
  message   String?
  timestamp DateTime @default(now())
  updatedBy String?

  @@index([orderId])
}

model OrderTrackingEvent {
  id         String   @id @default(cuid())
  orderId    String
  order      Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  status     String
  title      String
  description String?
  isPublic   Boolean  @default(true)
  location   String?
  courierRef String?
  createdBy  String?
  createdAt  DateTime @default(now())

  @@index([orderId])
}

model ShippingAddress {
  id             String  @id @default(cuid())
  orderId        String  @unique
  order          Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  fullName       String
  email          String
  phone          String
  street         String
  city           String
  county         String
  postalCode     String?
  deliveryMethod String? // Standard, Express, Pickup
  lat            Float?
  lng            Float?
}

model Refund {
  id             String    @id @default(cuid())
  orderId        String
  order          Order     @relation(fields: [orderId], references: [id])
  refundNumber   String?   @unique // REF-00001
  amount         Decimal   @db.Decimal(12, 2)
  reason         String?
  status         String    // PENDING, APPROVED, REJECTED, COMPLETED, FAILED
  processedBy    String?
  processedAt    DateTime?
  reviewedBy     String?
  rejectionReason String?
  mpesaPhone           String?
  mpesaReceiptNo       String?
  mpesaConversationId  String?   // B2C callback matching
  createdAt            DateTime  @default(now())

  @@index([orderId])
  @@index([status])
}

model Cancellation {
  id           String   @id @default(cuid())
  orderId      String   @unique
  order        Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  reason       String
  cancelledBy  String?  // userId or "admin"
  createdAt    DateTime @default(now())

  @@index([orderId])
}

// Delivery & logistics — one per order when shipping (STANDARD/EXPRESS)
enum DeliveryStatus {
  PENDING
  DISPATCHED
  IN_TRANSIT
  DELIVERED
  FAILED
}

model Delivery {
  id                 String         @id @default(cuid())
  orderId            String         @unique
  order              Order          @relation(fields: [orderId], references: [id], onDelete: Cascade)
  deliveryZoneId     String?
  deliveryZone       DeliveryZone?  @relation(fields: [deliveryZoneId], references: [id])
  method             String         // STANDARD | EXPRESS
  status             DeliveryStatus @default(PENDING)
  estimatedDelivery  DateTime?
  dispatchedAt       DateTime?
  deliveredAt        DateTime?
  assignedCourierId  String?
  assignedCourier    Courier?       @relation(fields: [assignedCourierId], references: [id])
  trackingNumber     String?
  proofPhotoKey      String?
  failureReason      String?
  rescheduledTo      DateTime?
  createdAt          DateTime       @default(now())
  updatedAt          DateTime       @updatedAt

  @@index([status])
  @@index([deliveryZoneId])
}

// ============== PAYMENTS ==============
enum PaymentProvider {
  MPESA
  AIRTEL_MONEY
  PESAPAL
  FLUTTERWAVE
  STRIPE
  BANK_TRANSFER
  CASH_ON_PICKUP
}

enum PaymentStatus {
  PENDING
  PROCESSING
  AWAITING_CONFIRMATION
  COMPLETED
  FAILED
  REFUNDED
  CANCELLED
}

model Payment {
  id                    String          @id @default(cuid())
  orderId               String
  order                 Order           @relation(fields: [orderId], references: [id])
  provider              PaymentProvider
  amount                Decimal         @db.Decimal(12, 2)
  currency              String          @default("KES")
  status                PaymentStatus   @default(PENDING)
  reference             String?
  providerTransactionId String?
  providerResponse      Json?
  paidAt                DateTime?
  createdAt             DateTime        @default(now())
  updatedAt             DateTime        @updatedAt

  // M-Pesa STK
  mpesaCheckoutId       String?
  mpesaReceiptNo        String?
  mpesaPhone            String?

  // Manual Paybill/Till
  paybillNumber         String?
  tillNumber            String?
  manualReference       String?
  manualVerifiedBy      String?
  manualVerifiedAt      DateTime?
  proofFileId           String?

  // Card (Pesapal)
  pesapalRef            String?
  pesapalStatus         String?

  // Pay on Pickup
  pickupConfirmedBy     String?
  pickupConfirmedAt     DateTime?
  pickupNotes           String?

  failureReason         String?
  attempts              Int             @default(1)
  ipAddress             String?

  mpesaTransaction MpesaTransaction?
  invoices         Invoice[]

  @@index([orderId])
  @@index([status])
}

model SavedMpesaNumber {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  phone     String   // +254XXXXXXXXX
  label     String?
  isDefault Boolean  @default(false)
  createdAt DateTime @default(now())

  @@unique([userId, phone])
  @@index([userId])
}

model SavedCard {
  id            String   @id @default(cuid())
  userId        String
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  pesapalToken  String
  last4         String
  brand         String
  expiryMonth   Int
  expiryYear    Int
  holderName    String?
  isDefault     Boolean  @default(false)
  createdAt     DateTime @default(now())

  @@index([userId])
}

model MpesaTransaction {
  id                 String   @id @default(cuid())
  paymentId          String   @unique
  payment            Payment  @relation(fields: [paymentId], references: [id])
  phoneNumber        String
  merchantRequestId  String?
  checkoutRequestId  String?
  resultCode         String?
  resultDesc         String?
  mpesaReceiptNumber String?
  transactionDate    String?
  amount             Decimal? @db.Decimal(12, 2)
}

model Invoice {
  id            String    @id @default(cuid())
  orderId       String
  order         Order     @relation(fields: [orderId], references: [id])
  paymentId     String?
  payment       Payment?  @relation(fields: [paymentId], references: [id])
  invoiceNumber String    @unique
  issuedAt      DateTime  @default(now())
  dueAt         DateTime?
  pdfUrl        String?
  pdfKey        String?   // R2/storage key for generated PDF
  vatAmount     Decimal   @db.Decimal(12, 2)
  totalAmount   Decimal   @db.Decimal(12, 2)
  subtotal      Decimal?  @db.Decimal(12, 2)
  sentAt        DateTime?
  sentBy        String?

  @@index([orderId])
}

// Sequence counters for INV-00001, QUO-00001
model Counter {
  id    String @id // "invoice" | "quote_pdf"
  value Int    @default(0)
  updatedAt DateTime @updatedAt
}

// ============== CUSTOM FILE UPLOADS ==============
