model SupportTicket {
  id           String          @id @default(cuid())
  userId       String?
  orderId      String?
  subject      String
  status       String
  priority     String?
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt
  ticketNumber String          @unique(where: raw("(\"ticketNumber\" IS NOT NULL)"))
  guestEmail   String?
  guestName    String?
  guestPhone   String?
  assignedTo   String?
