  @@index([kraPin])
}

model CorporateTeamMember {
  id              String            @id @default(cuid())
  corporateId     String
  corporate       CorporateAccount  @relation(fields: [corporateId], references: [id], onDelete: Cascade)
  userId          String
  user            User              @relation(fields: [userId], references: [id])
  role            CorporateRole     @default(MEMBER)
  jobTitle        String?
  department      String?
  canPlaceOrders  Boolean           @default(true)
  canViewInvoices Boolean           @default(false)
  canManageTeam   Boolean           @default(false)
  spendingLimit   Int?
  isActive        Boolean           @default(true)
  invitedBy       String?
  invitedAt       DateTime          @default(now())
  acceptedAt      DateTime?

  @@unique([corporateId, userId])
  @@index([corporateId])
}

model CorporateBrandAsset {
  id              String            @id @default(cuid())
  corporateId     String
  corporate       CorporateAccount  @relation(fields: [corporateId], references: [id], onDelete: Cascade)
  uploadedBy      String
  name            String
  description     String?
  category        AssetCategory
  fileUrl         String
  fileKey         String
  fileName        String
  fileSize        Int
  mimeType        String
  thumbnailUrl    String?
  tags            String[]
  isActive        Boolean           @default(true)
  downloadCount   Int               @default(0)
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt

  @@index([corporateId])
}

model CorporatePO {
  id              String            @id @default(cuid())
  corporateId     String
  corporate       CorporateAccount  @relation(fields: [corporateId], references: [id])
  poNumber        String
  description     String?
  amount          Int
  orders          Order[]
  status          POStatus          @default(OPEN)
  expiresAt       DateTime?
  createdAt       DateTime          @default(now())

  @@unique([corporateId, poNumber])
  @@index([corporateId])
}

model CorporateInvoice {
  id              String                @id @default(cuid())
  invoiceNumber   String                @unique
  corporateId     String
  corporate       CorporateAccount      @relation(fields: [corporateId], references: [id])
  periodStart     DateTime
  periodEnd       DateTime
  orders          Order[]
  subtotal        Int
  vatAmount       Int
  discountAmount  Int                   @default(0)
  totalAmount     Int
  dueAt           DateTime
  status          CorporateInvoiceStatus @default(DRAFT)
  pdfUrl          String?
  pdfKey          String?
  sentAt          DateTime?
  paidAt          DateTime?
  paymentRef      String?
  notes           String?
  createdAt       DateTime              @default(now())
  updatedAt       DateTime              @updatedAt

  @@index([corporateId])
  @@index([status])
}

model CorporateApplication {
  id                      String                      @id @default(cuid())
  corporateId             String?
  corporate               CorporateAccount?           @relation(fields: [corporateId], references: [id])
  applicantUserId         String
  applicant               User                        @relation(fields: [applicantUserId], references: [id])

  companyName             String
  tradingName             String?
  kraPin                  String
  vatNumber               String?
  industry                CorporateIndustry
  companySize             CompanySize
  website                 String?
  contactPerson           String
  contactPhone            String
  contactEmail            String
  billingAddress          String
  billingCity             String
  billingCounty           String
  estimatedMonthlySpend   String
  creditRequested         Int?
  paymentTermsRequested   PaymentTerms?
  additionalNotes         String?

  status                     CorporateApplicationStatus  @default(PENDING)
  reviewedBy                 String?
  reviewedAt                 DateTime?
  rejectedReason             String?
  acceptedCorporateTermsAt   DateTime?
  corporateTermsVersion      String?

  createdAt                  DateTime                    @default(now())
  updatedAt                  DateTime                    @updatedAt

  @@index([applicantUserId])
  @@index([status])
}

model CorporateNote {
  id              String            @id @default(cuid())
  corporateId     String
  corporate       CorporateAccount  @relation(fields: [corporateId], references: [id], onDelete: Cascade)
  authorId        String
  body            String
  createdAt       DateTime          @default(now())

  @@index([corporateId])
}

model CorporateInvite {
  id          String          @id @default(cuid())
  corporateId String
  email       String
  role        CorporateRole
  jobTitle    String?
  invitedBy   String
  token       String          @unique @default(cuid())
  expiresAt   DateTime
  acceptedAt  DateTime?
  createdAt   DateTime        @default(now())

  @@index([corporateId])
  @@index([email])
}

model BulkQuote {
  id            String    @id @default(cuid())
  corporateId   String
  corporate     CorporateAccount @relation(fields: [corporateId], references: [id])
  items         Json
  totalEstimate Decimal?  @db.Decimal(12, 2)
  status        String
  expiresAt     DateTime?
  assignedTo    String?
}

// ============== INVENTORY & PRODUCTION ==============
model Inventory {
  id                String          @id @default(cuid())
  productId         String
  product           Product         @relation(fields: [productId], references: [id], onDelete: Cascade)
  variantId         String?
  quantity          Int             @default(0)
  lowStockThreshold Int             @default(5)
  location          String?
  unitCostKes       Float?          // cost per unit (KES) – for margin/profit checks
  productVariant    ProductVariant? @relation(fields: [productVariantId], references: [id])
  productVariantId  String?
}

// Shop (finished product) stock movements — separate from print materials
model ShopInventoryMovement {
  id          String   @id @default(cuid())
  productId   String
  product     Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  quantity    Int      // positive = received, negative = sold/adjusted
  reason      String   // RECEIVED | SOLD | ADJUSTMENT | STOCKTAKE | DAMAGE | RETURN
  reference   String?  // PO number, order number, etc.
  costPerUnit Decimal? @db.Decimal(12, 2)
  createdAt   DateTime @default(now())
  createdBy   String?

  @@index([productId])
  @@index([createdAt])
}

// Purchase orders for shop (finished products to resell) — separate from LFPurchaseOrder
model ShopPurchaseOrder {
  id             String   @id @default(cuid())
  orderNumber    String   @unique
  supplierId     String?
  status         String   @default("DRAFT") // DRAFT | SENT | PARTIAL | RECEIVED | CANCELLED
  totalKes       Decimal? @db.Decimal(12, 2)
  expectedDate   DateTime?
  receivedAt     DateTime?
  notes          String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  lines          ShopPurchaseOrderLine[]
}

model ShopPurchaseOrderLine {
  id                  String             @id @default(cuid())
  shopPurchaseOrderId String
  shopPurchaseOrder   ShopPurchaseOrder   @relation(fields: [shopPurchaseOrderId], references: [id], onDelete: Cascade)
  productId           String
  product             Product            @relation(fields: [productId], references: [id], onDelete: Cascade)
  quantity            Int
  unitCostKes         Decimal            @db.Decimal(12, 2)
  receivedQuantity    Int                @default(0)

  @@index([shopPurchaseOrderId])
  @@index([productId])
}

model ProductionQueue {
  id          String    @id @default(cuid())
  orderId     String
  orderItemId String
  assignedTo  String?
  status      String // Queued, In Progress, Printing, Quality Check, Done
  startedAt   DateTime?
  completedAt DateTime?
  machineId   String?
  notes       String?
  orderItem   OrderItem @relation(fields: [orderItemId], references: [id])
}

model Machine {
  id               String  @id @default(cuid())
  name             String
  type             String // LARGE_FORMAT_PRINTER, 3D_PRINTER_FDM, 3D_PRINTER_RESIN
  status           String  @default("IDLE") // IDLE, PRINTING, MAINTENANCE
  location         String?
  purchasePriceKes Float?  // purchase/asset value (KES) – for depreciation and valuation
}

// ============== PRINTER ASSETS (Phase 2 — full asset lifecycle) ==============
enum PrinterType {
  LARGE_FORMAT
  FDM
  RESIN
  HYBRID
}

enum AssetStatus {
  ACTIVE
  IDLE
  IN_MAINTENANCE
  AWAITING_PARTS
  RETIRED
}

enum MaintenanceType {
  SCHEDULED_SERVICE
  BREAKDOWN_REPAIR
  CLEANING
  CALIBRATION
  PART_REPLACEMENT
  FIRMWARE_UPDATE
  INSPECTION
  // Prompt / log modal types
  SCHEDULED
  PREVENTIVE
  CORRECTIVE
  EMERGENCY
  UPGRADE
}

model PrinterAsset {
  id                      String      @id @default(cuid())
  assetTag                String      @unique // ASSET-LF-001, ASSET-3D-001
  name                    String
  manufacturer            String?
  model                   String?
  serialNumber            String?
  printerType             PrinterType
  location                String?
  notes                   String?
  isActive                Boolean     @default(true)
  isDefault               Boolean     @default(false)
  createdAt               DateTime    @default(now())
  updatedAt               DateTime    @updatedAt

  // Specs (for calculator)
  maxPrintWidthM          Float?
  buildVolumeX            Float?
  buildVolumeY            Float?
  buildVolumeZ            Float?
  powerWatts              Float
  electricityRateKesKwh   Float       @default(24)
  productionSpeed         Float       // sqm/hr (LF) or cm3/hr (3D)
  highQualitySpeed        Float?
  setupTimeHours          Float       @default(0.25)
  postProcessingTimeHours Float?      // 3D: extra hours for post-processing
  compatibleMaterials     String[]    @default([]) // 3D: ["PLA", "PETG"]

  // Financial
  purchasePriceKes        Float
  purchaseDate            DateTime?
  supplierName            String?
  expectedLifespanHours   Float
  annualMaintenanceKes    Float       @default(0)
  warrantyExpiryDate      DateTime?
  insurancePolicyRef      String?

  // Usage (updated from production / maintenance)
  hoursUsedTotal          Float       @default(0)
  hoursUsedThisMonth      Float       @default(0)
  status                  AssetStatus @default(ACTIVE)
  nextScheduledMaintDate DateTime?
  maintenanceIntervalHours Float?

  // Computed (updated on save)
  remainingLifespanHours  Float?
  depreciationPerHourKes  Float?
  maintenancePerHourKes   Float?

  maintenanceLogs         MaintenanceLog[]
}

model MaintenanceLog {
  id                String          @id @default(cuid())
  printerAssetId    String
  printerAsset      PrinterAsset    @relation(fields: [printerAssetId], references: [id], onDelete: Cascade)
  type              MaintenanceType
  date              DateTime        @default(now())
  performedBy       String
  isExternal        Boolean         @default(false)
  technicianCompany String?
  description       String
  labourHours       Float           @default(0)
  labourCostKes     Float           @default(0)
  partsCostKes      Float           @default(0)
  totalCostKes      Float           @default(0)
  nextServiceDate   DateTime?
  nextServiceHours  Float?
  notes             String?
  hoursAtService    Float?          // machine hours counter at time of service
  createdBy         String?         // admin userId who logged it
  createdAt         DateTime        @default(now())

  partsUsed         MaintenancePartUsed[]

  @@index([printerAssetId])
}

model MaintenancePartUsed {
  id                String        @id @default(cuid())
  maintenanceLogId  String
  maintenanceLog    MaintenanceLog @relation(fields: [maintenanceLogId], references: [id], onDelete: Cascade)
  partName          String?       // free text when not linked to LFStockItem
  lfStockItemId     String?
  lfStockItem       LFStockItem?  @relation(fields: [lfStockItemId], references: [id])
  quantityUsed      Float
  unitCostKes       Float
  totalCostKes      Float

  @@index([maintenanceLogId])
}

// Inventory tabs: Hardware (printers etc.), Maintenance, Printer Accessories.
// When category = HARDWARE and hardwareType = LARGE_FORMAT_PRINTER or THREE_D_PRINTER,
// the calculator uses this item's cost fields for quote pricing; admin selects printer in Quote calculator.
// linkedPrinterId can reference either InventoryHardwareItem (id of a printer) or PrinterAsset.id
model InventoryHardwareItem {
  id          String   @id @default(cuid())
  name        String
  category    String   // HARDWARE | MAINTENANCE | PRINTER_ACCESSORIES
  priceKes    Float    @default(0) // purchase/selling price – required when adding item
  isActive    Boolean  @default(true)
  sortOrder   Int      @default(0)
  location    String?  // e.g. "Production floor A" – for hardware
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // For MAINTENANCE / PRINTER_ACCESSORIES: which printer this applies to (id of a HARDWARE printer)
  linkedPrinterId String?
  // For MAINTENANCE / PRINTER_ACCESSORIES: time impact in hours (included in cost calculations)
  timeHours       Float?

  // For category = HARDWARE only: type of hardware (printer specs used in calculators)
  hardwareType String? // LARGE_FORMAT_PRINTER | THREE_D_PRINTER | null for generic hardware
  printerSubType String? // 3D: FDM, RESIN, DLP, SLS, OTHER | LF: SOLVENT, ECO_SOLVENT, LATEX, UV, DYE_SUBLIMATION, OTHER

  // Large format printer fields (when hardwareType = LARGE_FORMAT_PRINTER)
  model                 String?
  maxPrintWidthM        Float?
  printSpeedSqmPerHour   Float?
  setupTimeHours        Float?
  lifespanHours         Float?
  annualMaintenanceKes  Float?
  powerWatts            Float?
  electricityRateKesKwh Float?

  // 3D printer fields (when hardwareType = THREE_D_PRINTER)
  maintenancePerYearKes   Float?
  postProcessingTimeHours Float?
}

// 3D consumables: filament, resin, nozzles, etc.
// costPerKgKes: FILAMENT – used by 3D calculator so quotes stay above cost
// unitCostKes: RESIN/OTHER – cost per unit (bottle, piece) for margin/profit checks
model ThreeDConsumable {
  id                String   @id @default(cuid())
  kind              String   // FILAMENT, RESIN, OTHER
  name              String   // e.g. "PLA", "Resin 1L", "Nozzle 0.4mm"
  specification     String?  // e.g. "Red 1kg", "Clear"
  brand             String?  // optional e.g. "eSUN"
  quantity          Int      @default(0)
  lowStockThreshold Int      @default(2)
  location          String?
  costPerKgKes      Float?   // cost per kg (KES) – FILAMENT; used by 3D calculator
  unitCostKes       Float?   // cost per unit (KES) – RESIN/OTHER; for margin/profit checks
  colourHex         String?  // e.g. #FF0000 for filament colour
  weightPerSpoolKg  Float?   // filament spool weight (kg)
  notes             String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  movements ThreeDConsumableMovement[]
}

// ============== STAFF & ADMIN ==============
model Department {
  id          String   @id @default(cuid())
  name        String   @unique
  description String?
  colour      String?
  isActive    Boolean  @default(true)
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  staff Staff[]
}

model Staff {
  id                String    @id @default(cuid())
  userId            String    @unique
  user              User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  department        String?   // denormalised name for display
  departmentId      String?
  departmentObj     Department? @relation(fields: [departmentId], references: [id], onDelete: SetNull)
  position          String?
  permissions       String[]  // granular permissions
  showOnAboutPage   Boolean   @default(false)
  aboutPageOrder    Int       @default(0)
  publicName        String?
  publicRole        String?
  publicBio         String?
  profilePhotoUrl   String?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  assignedQuotes    Quote[]

  @@index([departmentId])
  @@index([showOnAboutPage])
}

model AuditLog {
  id        String   @id @default(cuid())
  userId    String?
  user      User?    @relation(fields: [userId], references: [id])
  action    String
  entity    String
  entityId  String?
  before    Json?
  after     Json?
  ipAddress String?
  timestamp DateTime @default(now())

  @@index([userId])
  @@index([entity, entityId])
}

model SupportTicket {
  id           String    @id @default(cuid())
  ticketNumber String    @unique // e.g. TKT-00001
  userId       String?   // null for guest tickets
  user         User?     @relation(fields: [userId], references: [id], onDelete: SetNull)
  guestEmail   String?
  guestName    String?
  guestPhone   String?
  orderId      String?
  subject      String
  status       String    // OPEN, IN_PROGRESS, RESOLVED, CLOSED
  priority     String?   // LOW, MEDIUM, HIGH, URGENT
  assignedTo   String?
  resolvedAt   DateTime?
  closedAt     DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  messages TicketMessage[]
}

model TicketMessage {
  id          String        @id @default(cuid())
  ticketId    String
  ticket      SupportTicket @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  senderId    String?   // null for system or guest (use ticket guest fields)
  sender      User?     @relation(fields: [senderId], references: [id], onDelete: SetNull)
  senderType  String    // CUSTOMER, STAFF, SYSTEM
  message     String    @db.Text
  attachments String[]
  isInternal  Boolean   @default(false)
  createdAt   DateTime  @default(now())

  @@index([ticketId])
}

model SavedAddress {
  id            String   @id @default(cuid())
  userId        String
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  label         String   @default("Home")
  recipientName String?
  phone         String?
  line1         String
  line2         String?
  city          String
  county        String
  isDefault     Boolean  @default(false)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([userId])
}

model ReferralCode {
  id        String   @id @default(cuid())
  userId    String   @unique
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  code      String   @unique
  createdAt DateTime @default(now())

  @@index([userId])
}

model LoyaltyAccount {
  id           String    @id @default(cuid())
  userId       String    @unique
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  points       Int       @default(0)
  pointsEarned Int       @default(0) // lifetime earned (for tier)
  tier         String?
  updatedAt    DateTime  @updatedAt

  transactions LoyaltyTransaction[]
}

model LoyaltyTransaction {
  id          String         @id @default(cuid())
  accountId   String
  account     LoyaltyAccount @relation(fields: [accountId], references: [id], onDelete: Cascade)
  points      Int
  type        String         // EARN, REDEEM, ADJUST
  reference   String?        // orderId, etc.
  description String?
  createdAt   DateTime       @default(now())

  @@index([accountId])
}

model UserNotificationPrefs {
  id             String   @id @default(cuid())
  userId         String   @unique
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  emailOrders    Boolean? @default(true)
  emailMarketing Boolean? @default(false)
  smsOrders     Boolean? @default(false)
  updatedAt      DateTime @updatedAt
}

model UserPermission {
  id         String   @id @default(cuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  permission String
  createdAt  DateTime @default(now())

  @@unique([userId, permission])
  @@index([userId])
}

model Courier {
  id           String   @id @default(cuid())
  name         String
  sortOrder    Int      @default(0)
  trackingUrl  String?
  phone        String?
  logo         String?
  isActive     Boolean  @default(true)
  address      String?  // Street / branch address for "nearest location" selection
  city         String?
  county       String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  orders       Order[]
  deliveries   Delivery[]
}

model DeliveryZone {
  id          String   @id @default(cuid())
  name        String
  county      String?
  counties    String?  // comma-separated list
  postcodes   String?  // comma-separated or regex
  feeKes      Float?
  minOrderKes Float?
  minDays     Int?
  maxDays     Int?
  sortOrder   Int      @default(0)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  orders    Order[]
  deliveries Delivery[]
}

model PickupLocation {
  id          String   @id @default(cuid())
  name        String   // e.g. "Nairobi — Westlands"
  city        String
  county      String
  street      String   // full address line
  postalCode  String?
  instructions String? // e.g. "Gate B, call on arrival"
  isActive    Boolean  @default(true)
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  orders Order[]
}

model ThreeDConsumableMovement {
  id             String           @id @default(cuid())
  consumableId   String
  consumable     ThreeDConsumable @relation(fields: [consumableId], references: [id], onDelete: Cascade)
  type           String           // RECEIVED, CONSUMED, ADJUSTMENT, etc.
  quantity       Int              // delta: positive = in, negative = out
  costPerKgKes   Float?
  supplier       String?
  reference      String?
  performedById  String?
  performedBy    User?            @relation(fields: [performedById], references: [id])
  notes          String?
  createdAt      DateTime         @default(now())

  @@index([consumableId])
}

