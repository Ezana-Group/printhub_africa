model UploadedFile {
  id               String             @id @default(cuid())
  userId           String?
  user             User?              @relation(fields: [userId], references: [id], onDelete: SetNull)
  guestEmail       String?            // for guest uploads (e.g. quote without account)
  orderId          String?
  quoteId          String?
  quote            Quote?             @relation(fields: [quoteId], references: [id], onDelete: SetNull)
  uploadedByAdmin  Boolean            @default(false)
  filename         String
  originalName     String
  storageKey       String?            // R2 key
  bucket           String?            // "private" | "public"
  folder           String?
  mimeType         String
  size             Int
  url              String?            // public CDN URL when bucket=public
  ext              String?
  uploadContext    UploadContext?
  thumbnailUrl     String?
  fileType         UploadedFileType
  status           UploadedFileStatus @default(UPLOADED)
  virusScanStatus  String?            // "pending" | "clean" | "infected" | "error"
  virusScanAt      DateTime?
  reviewedBy       String?
  reviewedAt       DateTime?
  reviewNotes      String?
  rejectionReason  String?
  printVolume      Float?
  printWeight      Float?
  printTime        Float?
  dimensions       Json?
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt

  printQuotes PrintQuote[]
}

enum PrintQuoteStatus {
  DRAFT
  SENT
  ACCEPTED
  EXPIRED
  REJECTED
}

model PrintQuote {
  id             String           @id @default(cuid())
  uploadedFileId String?
  uploadedFile   UploadedFile?     @relation(fields: [uploadedFileId], references: [id])
  userId         String
  user           User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  material       String?
  quantity       Int              @default(1)
  dimensions     Json?
  area           Float? // sqm for large format
  estimatedCost  Decimal?          @db.Decimal(12, 2)
  validUntil     DateTime?
  status         PrintQuoteStatus  @default(DRAFT)
  staffNotes     String?
  createdAt      DateTime         @default(now())

  @@index([userId])
  @@index([status])
  @@index([createdAt])
}

// ============== UNIFIED QUOTES (Get a Quote / Design+Print) ==============
enum QuoteType {
  large_format
  three_d_print
  design_and_print
}

enum QuoteStatus {
  new
  reviewing
  quoted
  accepted
  rejected
  in_production
  completed
  cancelled
}

enum QuoteClosedBy {
  CUSTOMER  // customer withdrew or declined — admin cannot reopen
  STAFF     // staff cancelled — admin can reopen if needed
  SYSTEM    // auto-expired — admin can reopen if needed
}

enum PreferredContact {
  email
  whatsapp
  phone
}

model Quote {
  id                String           @id @default(cuid())
  quoteNumber       String           @unique // PHQ-00001
  type              QuoteType
  status            QuoteStatus      @default(new)
  customerId        String?
  customer          User?             @relation(fields: [customerId], references: [id])
  assignedStaffId   String?
  assignedStaff     Staff?            @relation(fields: [assignedStaffId], references: [id])
  customerName      String
  customerEmail     String
  customerPhone     String?
  preferredContact  PreferredContact  @default(email)
  projectName       String?
  description       String?           @db.Text
  referenceFiles    String[]         // URLs of uploaded reference/design files
  referenceFilesMeta Json?            // optional: [{ url, originalName, sizeBytes, uploadedAt }]
  specifications    Json?            // type-specific: dimensions, material, quantity, etc.
  budgetRange       String?           // for design_and_print
  deadline          DateTime?
  quotedAmount      Decimal?          @db.Decimal(12, 2)
  quotedAt          DateTime?
  quoteBreakdown    String?           @db.Text
  quoteValidityDays Int?
  quotePdfUrl       String?
  acceptedAt        DateTime?
  rejectedAt        DateTime?
  rejectionReason   String?           @db.Text
  notes             String?           @db.Text // internal staff notes
  adminNotes        String?           @db.Text
  referralSource    String?           // UTM / marketing
  cancelledAt       DateTime?
  cancelledBy       String?           // 'customer' or admin userId
  cancellationReason String?         // out_of_stock, technical_issue, customer_request, pricing_error, material_unavailable, other, customer_cancelled
  cancellationNotes String?          @db.Text
  cancelledByAdminId String?
  cancelledByAdmin  User?            @relation("QuoteCancelledByAdmin", fields: [cancelledByAdminId], references: [id])
  closedBy          QuoteClosedBy?   // who set final status — CUSTOMER = locked for admin
  closedAt          DateTime?
  closedReason      String?          @db.Text // e.g. "Withdrawn by customer", "Declined by customer"
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt

  uploadedFiles     UploadedFile[]
  quotePdfs         QuotePdf[]
  quoteCancellations QuoteCancellation[]

  @@index([customerId])
  @@index([assignedStaffId])
  @@index([status])
  @@index([type])
  @@index([createdAt])
}

model QuoteCancellation {
  id                  String   @id @default(cuid())
  quoteId             String
  quote               Quote    @relation(fields: [quoteId], references: [id], onDelete: Cascade)
  cancelledBy         String   // 'customer' | 'admin'
  cancelledByUserId   String?
  cancelledByUser     User?    @relation(fields: [cancelledByUserId], references: [id])
  reason              String
  notes               String?  @db.Text
  notificationSent    Boolean  @default(false)
  createdAt           DateTime @default(now())

  @@index([quoteId])
}

model QuotePdf {
  id          String   @id @default(cuid())
  quoteId     String
  quote       Quote    @relation(fields: [quoteId], references: [id], onDelete: Cascade)
  pdfKey      String   // R2/storage key
  pdfUrl      String?
  generatedAt DateTime @default(now())
  sentAt      DateTime?

  @@index([quoteId])
}

// ============== MARKETING & CRM ==============
enum CouponType {
  PERCENTAGE
  FIXED
  FREE_SHIPPING
}

model Coupon {
