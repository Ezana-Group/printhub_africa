  STL
  OBJ
  FBX
  THREE_MF
  STEP
  AI
  PDF
  PSD
  EPS
  SVG
  DXF
  DWG
  PNG
  JPEG
  WEBP
  TIFF
  DOCX
  XLSX
  OTHER
}

enum UploadedFileStatus {
  UPLOADING
  UPLOADED
  VIRUS_SCANNING
  CLEAN
  INFECTED
  REVIEWING
  APPROVED
  REJECTED
  PROCESSING
  EXPIRED
}

enum UploadContext {
  CUSTOMER_3D_PRINT
  CUSTOMER_LARGE_FORMAT
  CUSTOMER_QUOTE
  CUSTOMER_GENERAL
  CUSTOMER_PAYMENT_PROOF
  ADMIN_CATALOGUE_STL
  ADMIN_CATALOGUE_PHOTO
