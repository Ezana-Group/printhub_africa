generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["partialIndexes"]
}

datasource db {
  provider = "postgresql"
}

model User {
  id                       String                     @id @default(cuid())
  name                     String?
  email                    String                     @unique
  phone                    String?
  passwordHash             String?
  role                     UserRole                   @default(CUSTOMER)
  emailVerified            DateTime?
  createdAt                DateTime                   @default(now())
  updatedAt                DateTime                   @updatedAt
  profileImage             String?
  loyaltyPoints            Int                        @default(0)
  preferredLanguage        String?                    @default("en")
  failedLoginAttempts      Int                        @default(0)
  lockedUntil              DateTime?
  inviteToken              String?
  inviteTokenExpiry        DateTime?
  status                   String?                    @default("ACTIVE")
  anonymisedAt             DateTime?
  dateOfBirth              DateTime?
  isAnonymised             Boolean?                   @default(false)
  totpSecret               String?
  stripeCustomerId         String?
  acceptedTermsAt          DateTime?
  marketingConsent         Boolean                    @default(false)
  marketingConsentAt       DateTime?
  smsMarketingOptIn        Boolean                    @default(false)
  smsUnsubscribedAt        DateTime?
  termsVersion             String?
  productionPinHash        String?
  twoFaMethod              String?
  otpCodeHash              String?
  otpExpiresAt             DateTime?
  displayName              String?
  displayEmail             String?
  personalEmail            String?
  lastActiveAt             DateTime?                  @default(now())
  passwordChangedAt        DateTime?                  @default(now())
  passwordExpired          Boolean                    @default(false)
  passwordHistory          String[]                   @default([])
  lastLoginIp              String?
  accounts                 Account[]
  addresses                Address[]
  adminSessions            AdminSession[]
  auditLogs                AuditLog[]
  backupRecords            BackupRecord[]
  catalogueApproved        CatalogueItem[]            @relation("CatalogueApprovedBy")
  catalogueArchived        CatalogueItem[]            @relation("CatalogueArchivedBy")
  catalogueImported        CatalogueItem[]            @relation("CatalogueImportedBy")
  catalogueRejected        CatalogueItem[]            @relation("CatalogueRejectedBy")
  primaryCorporateAccount  CorporateAccount?          @relation("CorporatePrimaryContact")
  corporateApplications    CorporateApplication[]
  corporateTeamMemberships CorporateTeamMember[]
  couponUsages             CouponUsage[]
  emailMailboxViewers      EmailMailboxViewer[]
  assignedEmailThreads     EmailThread[]              @relation("AssignedThreads")
  emailThreadsCreated      EmailThread[]              @relation("EmailThreadCreatedBy")
  knownAdminDevices        KnownAdminDevice[]
  loyaltyAccount           LoyaltyAccount?
  notifications            Notification[]
  orders                   Order[]
  printQuotes              PrintQuote[]
  productReviews           ProductReview[]
  quotesCancelledByAdmin   Quote[]                    @relation("QuoteCancelledByAdmin")
  quotes                   Quote[]
  quoteCancellations       QuoteCancellation[]
  referralCodes            ReferralCode?
  savedAddresses           SavedAddress[]
  savedCards               SavedCard[]
  savedMpesaNumbers        SavedMpesaNumber[]
  sessions                 Session[]
  staff                    Staff?
  supportTickets           SupportTicket[]
  performedByMovements     ThreeDConsumableMovement[]
  ticketMessages           TicketMessage[]
  uploadedFiles            UploadedFile[]
  userNotificationPrefs    UserNotificationPrefs?
  userPermissions          UserPermission[]
  wishlists                Wishlist[]
}

model Address {
  id         String   @id @default(cuid())
  userId     String
  label      String
  street     String
  city       String
  county     String
  postalCode String?
  isDefault  Boolean  @default(false)
  lat        Float?
  lng        Float?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model AdminSession {
  id              String    @id @default(cuid())
  userId          String
  sessionToken    String    @unique
  ipAddress       String?
  userAgent       String?
  lastActiveAt    DateTime  @default(now())
  expiresAt       DateTime
  revokedAt       DateTime?
  createdAt       DateTime  @default(now())
  ipCity          String?
  ipCountry       String?
  suspiciousLogin Boolean   @default(false)
  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([sessionToken])
}

model KnownAdminDevice {
  id          String   @id @default(cuid())
  userId      String
  fingerprint String
  firstSeenAt DateTime @default(now())
  lastSeenAt  DateTime @default(now())
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Category {
  id              String          @id @default(cuid())
  name            String
  slug            String          @unique
  description     String?
  image           String?
  parentId        String?
  sortOrder       Int             @default(0)
  isActive        Boolean         @default(true)
  metaTitle       String?
  metaDescription String?
  showInNav       Boolean         @default(false)
  catalogueItems  CatalogueItem[]
  parent          Category?       @relation("CategoryTree", fields: [parentId], references: [id])
  children        Category[]      @relation("CategoryTree")
  externalModels  ExternalModel[]
  products        Product[]

  @@index([parentId])
}

model Product {
  id                       String                  @id @default(cuid())
  name                     String
  slug                     String                  @unique
  description              String?
  shortDescription         String?
  categoryId               String
  productType              ProductType
  images                   String[]
  basePrice                Decimal                 @db.Decimal(12, 2)
  comparePrice             Decimal?                @db.Decimal(12, 2)
  costPrice                Decimal?                @db.Decimal(12, 2)
  sku                      String?                 @unique
  stock                    Int?                    @default(0)
  lowStockThreshold        Int                     @default(0)
  minOrderQty              Int                     @default(1)
  maxOrderQty              Int?
  weight                   Decimal?                @db.Decimal(10, 3)
  dimensions               Json?
  materials                String[]
  colors                   String[]
  finishes                 String[]
  isActive                 Boolean                 @default(true)
  isFeatured               Boolean                 @default(false)
  metaTitle                String?
  metaDescription          String?
  tags                     String[]
  createdAt                DateTime                @default(now())
  updatedAt                DateTime                @updatedAt
  availability             ProductAvailability     @default(IN_STOCK)
  brand                    String?
  /// Links back to the CatalogueItem this POD product was created from
  catalogueItemId          String?                 @unique
  compatibility            String?
  /// URL to a dimension diagram image shown as a tab in the gallery
  dimensionDiagramUrl      String?
  /// Approximate filament weight in grams
  filamentWeightGrams      Float?
  /// True for Print-on-Demand products — no stock tracking
  isPOD                    Boolean                 @default(false)
  materialType             String?
  printTimeEstimate        String?
  /// Running count of units sold this calendar month (reset by monthly cron)
  soldThisMonth            Int                     @default(0)
  specifications           Json?
  exportNotes              String?
  /// Human-readable estimated print time, e.g. "4–6 hours"
  exportToGoogle            Boolean @default(true)
  exportToMeta              Boolean @default(true)
  exportToTiktok            Boolean @default(true)
  exportToLinkedIn          Boolean @default(false)
  exportToPinterest         Boolean @default(false)
  exportToX                 Boolean @default(false)
  exportToGoogleBiz         Boolean @default(true)
  exportToSnapchat          Boolean @default(false)
  exportToYoutube           Boolean @default(false)
  exportToInstagramStories  Boolean @default(false)
  exportToInstagramReels    Boolean @default(false)
  exportToYoutubeShorts     Boolean @default(false)
  exportToWhatsappStatus    Boolean @default(false)
  exportToWhatsappChannel   Boolean @default(false)
  exportToTelegram          Boolean @default(false)
  exportToGoogleDiscover    Boolean @default(false)
  exportToGoogleMapsPost    Boolean @default(true)
  exportToBingPlaces        Boolean @default(false)
  exportToAppleMaps         Boolean @default(false)
  exportToPigiaMe           Boolean @default(false)
  exportToOlxKenya          Boolean @default(false)
  exportToReddit            Boolean @default(false)
  exportToLinkedInNewsletter Boolean @default(false)
  exportToMedium            Boolean @default(false)
  exportToNextdoor          Boolean @default(false)
  exportToJiji              Boolean @default(false)
  featuredThisWeek          Boolean @default(false)
  weeklyViews               Int @default(0)
  totalViews                Int @default(0)
  lastExportedAt            DateTime?
  aiDescriptionGenerated  Boolean                 @default(false)
  aiGeneratedAt           DateTime?
  catalogueImportQueue    CatalogueImportQueue?
  keyFeatures             String[]                @default([])
  adCopyVariations        AdCopyVariation[]
  catalogueItem            CatalogueItem?          @relation("CatalogueProductLink")
  externalModel            ExternalModel?
  inventory                Inventory[]
  orderItems               OrderItem[]
  catalogueSourceItem      CatalogueItem?          @relation("CataloguePODSource", fields: [catalogueItemId], references: [id])
  category                 Category                @relation(fields: [categoryId], references: [id])
  filamentColors           ProductFilamentColor[]
  productImages            ProductImage[]
  mockups                  ProductMockup[]
  printMaterials           ProductPrintMaterial[]
  reviews                  ProductReview[]
  variants                 ProductVariant[]
  videos                   ProductVideo[]
  shopStockMovements       ShopInventoryMovement[]
  shopPOLines              ShopPurchaseOrderLine[]
  stockNotifications       StockNotification[]
  wishlists                Wishlist[]

  @@index([categoryId])
  @@index([slug])
  @@index([isFeatured, isActive])
  @@index([isActive])
  @@index([isPOD])
  @@index([createdAt])
  @@index([basePrice])
}

model ProductVariant {
  id         String      @id @default(cuid())
  productId  String
  name       String
  sku        String?     @unique
  price      Decimal     @db.Decimal(12, 2)
  stock      Int         @default(0)
  attributes Json
  image      String?
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt
  inventory  Inventory[]
  orderItems OrderItem[]
  product    Product     @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId])
}

model ProductImage {
  id         String  @id @default(cuid())
  productId  String
  url        String
  altText    String?
  sortOrder  Int     @default(0)
  isPrimary  Boolean @default(false)
  storageKey String?
  uploadId   String?
  product    Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId])
}

/// Join table linking shop products to printable 3D consumables (filament/resin)
model ProductPrintMaterial {
  productId    String
  consumableId String
  isDefault    Boolean          @default(false)
  consumable   ThreeDConsumable @relation(fields: [consumableId], references: [id])
  product      Product          @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@id([productId, consumableId])
  @@index([consumableId])
}

/// A named filament/resin colour option available for 3D products
model FilamentColor {
  id       String                 @id @default(cuid())
  name     String
  hexCode  String
  isActive Boolean                @default(true)
  products ProductFilamentColor[]
}

/// Join table linking products to available filament colour options
model ProductFilamentColor {
  productId       String
  filamentColorId String
  isAvailable     Boolean       @default(true)
  filamentColor   FilamentColor @relation(fields: [filamentColorId], references: [id])
  product         Product       @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@id([productId, filamentColorId])
  @@index([filamentColorId])
}

model ProductReview {
  id         String   @id @default(cuid())
  productId  String
  userId     String
  rating     Int
  title      String?
  body       String?
  images     String[]
  isVerified Boolean  @default(false)
  isApproved Boolean  @default(false)
  createdAt  DateTime @default(now())
  product    Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([productId])
  @@index([userId])
}

model PrintMaterial {
  id             String            @id @default(cuid())
  slug           String?           @unique
  name           String
  description    String?
  type           PrintMaterialType
  colorOptions   String[]
  pricePerGram   Decimal           @db.Decimal(10, 4)
  density        Float?
  minChargeGrams Int?
  leadTimeDays   Int               @default(3)
  image          String?
  properties     Json?
  sortOrder      Int               @default(0)
  isActive       Boolean           @default(true)
}

model PrintFinish {
  id            String  @id @default(cuid())
  name          String
  description   String?
  priceModifier Decimal @default(0) @db.Decimal(10, 2)
  isActive      Boolean @default(true)
}

model PrintingMedium {
  id              String  @id @default(cuid())
  slug            String? @unique
  name            String
  pricePerSqMeter Decimal @db.Decimal(12, 2)
  minWidth        Float?
  maxWidth        Float?
  minHeight       Float?
  maxHeight       Float?
  description     String?
  sortOrder       Int     @default(0)
  isActive        Boolean @default(true)
}

model LaminationType {
  id          String  @id @default(cuid())
  slug        String? @unique
  name        String
  pricePerSqm Decimal @default(0) @db.Decimal(10, 2)
}

model LargeFormatFinishing {
  id           String  @id @default(cuid())
  code         String  @unique
  name         String
  pricePerUnit Decimal @db.Decimal(10, 2)
  sortOrder    Int     @default(0)
  isActive     Boolean @default(true)
}

model DesignServiceOption {
  id        String  @id @default(cuid())
  code      String  @unique
  name      String
  flatFee   Decimal @default(0) @db.Decimal(10, 2)
  sortOrder Int     @default(0)
  isActive  Boolean @default(true)
}

model TurnaroundOption {
  id               String  @id @default(cuid())
  code             String  @unique
  name             String
  surchargePercent Decimal @default(0) @db.Decimal(5, 2)
  serviceType      String
  sortOrder        Int     @default(0)
  isActive         Boolean @default(true)
}

model LFPrinterSettings {
  id                      String   @id @default(cuid())
  name                    String
  model                   String
  isActive                Boolean  @default(true)
  isDefault               Boolean  @default(false)
  maxPrintWidthM          Float
  printSpeedSqmPerHour    Float
  printSpeedHighQualSqmHr Float?
  setupTimeHours          Float    @default(0.25)
  purchasePriceKes        Float
  lifespanHours           Float    @default(20000)
  annualMaintenanceKes    Float
  powerWatts              Float
  electricityRateKesKwh   Float    @default(24)
  inkChannelSettings      Json?
  updatedBy               String?
  updatedAt               DateTime @updatedAt
  createdAt               DateTime @default(now())
}

model LFBusinessSettings {
  id                       String   @id @default(cuid())
  labourRateKesPerHour     Float    @default(200)
  finishingTimeEyeletStd   Float    @default(0.1)
  finishingTimeEyeletHeavy Float    @default(0.2)
  finishingTimeHemAll4     Float    @default(0.25)
  finishingTimeHemTop2     Float    @default(0.15)
  finishingTimePole        Float    @default(0.2)
  finishingTimeRope        Float    @default(0.1)
  monthlyRentKes           Float
  monthlyUtilitiesKes      Float
  monthlyInsuranceKes      Float
  monthlyOtherKes          Float
  workingDaysPerMonth      Int      @default(26)
  workingHoursPerDay       Int      @default(8)
  wastageBufferPercent     Float    @default(3)
  substrateWasteFactor     Float    @default(1.05)
  rigidSheetWasteFactor    Float    @default(1.1)
  defaultProfitMarginPct   Float    @default(40)
  vatRatePct               Float    @default(16)
  minOrderValueKes         Float    @default(500)
  updatedBy                String?
  updatedAt                DateTime @updatedAt
}

model LFStockItem {
  id                       String                @id @default(cuid())
  code                     String                @unique
  name                     String
  category                 String
  unitType                 String
  rollWidthM               Float?
  quantityOnHand           Float                 @default(0)
  lowStockThreshold        Float                 @default(0)
  costPerUnit              Float                 @default(0)
  lastPurchasePriceKes     Float?
  averageCostKes           Float                 @default(0)
  totalUnitsEverPurchased  Float                 @default(0)
  totalCostEverPurchased   Float                 @default(0)
  lastReceivedAt           DateTime?
  printerAssetId           String?
  replacementIntervalHours Float?
  lastReplacedAt           DateTime?
  nextReplacementDue       DateTime?
  createdAt                DateTime              @default(now())
  updatedAt                DateTime              @updatedAt
  maintenancePartUsages    MaintenancePartUsed[]
}

model MachineType {
  id          String  @id @default(cuid())
  code        String  @unique
  name        String
  ratePerHour Decimal @db.Decimal(10, 2)
  sortOrder   Int     @default(0)
  isActive    Boolean @default(true)
}

model ThreeDAddon {
  id           String  @id @default(cuid())
  code         String  @unique
  name         String
  pricePerUnit Decimal @db.Decimal(10, 2)
  category     String
  sortOrder    Int     @default(0)
  isActive     Boolean @default(true)
}

model PricingConfig {
  id        String @id @default(cuid())
  key       String @unique
  valueJson String
}

model Order {
  id                   String               @id @default(cuid())
  orderNumber          String               @unique
  userId               String?
  status               OrderStatus          @default(PENDING)
  type                 OrderType
  subtotal             Decimal              @db.Decimal(12, 2)
  tax                  Decimal              @default(0) @db.Decimal(12, 2)
  shippingCost         Decimal              @default(0) @db.Decimal(12, 2)
  discount             Decimal              @default(0) @db.Decimal(12, 2)
  total                Decimal              @db.Decimal(12, 2)
  currency             String               @default("KES")
  notes                String?
  estimatedDelivery    DateTime?
  createdAt            DateTime             @default(now())
  updatedAt            DateTime             @updatedAt
  cancelReason         String?
  cancelledAt          DateTime?
  deliveredAt          DateTime?
  manualPaymentBy      String?
  manualPaymentNotes   String?
  manualPaymentRef     String?
  mpesaFailureReason   String?
  paidAt               DateTime?
  paymentLinkExpiresAt DateTime?
  paymentLinkToken     String?
  shippedAt            DateTime?
  trackingNumber       String?
  paymentMethod        String?
  paymentStatus        String?
  pickupCode           String?
  pickupLocationId     String?
  courierId            String?
  deliveryZoneId       String?
  corporateId          String?
  poReference          String?
  corporatePOId        String?
  corporateInvoiceId   String?
  placedBy             String?
  isNetTerms           Boolean              @default(false)
  isDepositPaid        Boolean              @default(false)
  outstandingBalance   Decimal?             @db.Decimal(12, 2)
  cancellation         Cancellation?
  delivery             Delivery?
  invoices             Invoice[]
  corporate            CorporateAccount?    @relation(fields: [corporateId], references: [id])
  corporateInvoice     CorporateInvoice?    @relation(fields: [corporateInvoiceId], references: [id])
  corporatePO          CorporatePO?         @relation(fields: [corporatePOId], references: [id])
  courier              Courier?             @relation(fields: [courierId], references: [id])
  deliveryZone         DeliveryZone?        @relation(fields: [deliveryZoneId], references: [id])
  pickupLocation       PickupLocation?      @relation(fields: [pickupLocationId], references: [id])
  user                 User?                @relation(fields: [userId], references: [id])
  items                OrderItem[]
  timeline             OrderTimeline[]
  trackingEvents       OrderTrackingEvent[]
  payments             Payment[]
  refunds              Refund[]
  shippingAddress      ShippingAddress?

  @@index([status])
  @@index([createdAt])
  @@index([userId])
  @@index([orderNumber])
  @@index([paymentStatus])
}

model OrderItem {
  id                String            @id @default(cuid())
  orderId           String
  productId         String?
  quantity          Int
  unitPrice         Decimal           @db.Decimal(12, 2)
  customizations    Json?
  uploadedFileId    String?
  instructions      String?
  createdAt         DateTime          @default(now())
  productVariantId  String?
  variantId         String?
  addInstallation   Boolean           @default(false)
  depositAmount     Decimal?          @db.Decimal(10, 2)
  hardwareProductId String?
  hardwareVariantId String?
  isDeposit         Boolean           @default(false)
  itemType          CartItemType      @default(PRINT_SERVICE)
  HardwareProduct   HardwareProduct?  @relation(fields: [hardwareProductId], references: [id])
  order             Order             @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product           Product?          @relation(fields: [productId], references: [id])
  productVariant    ProductVariant?   @relation(fields: [productVariantId], references: [id])
  productionQueue   ProductionQueue[]

  @@index([orderId])
}

model OrderTimeline {
  id        String   @id @default(cuid())
  orderId   String
  status    String
  message   String?
  timestamp DateTime @default(now())
  updatedBy String?
  order     Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId])
}

model OrderTrackingEvent {
  id          String   @id @default(cuid())
  orderId     String
  status      String
  title       String
  description String?
  isPublic    Boolean  @default(true)
  location    String?
  courierRef  String?
  createdBy   String?
  createdAt   DateTime @default(now())
  order       Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId])
}

model ShippingAddress {
  id             String  @id @default(cuid())
  orderId        String  @unique
  fullName       String
  email          String
  phone          String
  street         String
  city           String
  county         String
  postalCode     String?
  deliveryMethod String?
  lat            Float?
  lng            Float?
  order          Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
}

model Refund {
  id                   String    @id @default(cuid())
  orderId              String
  amount               Decimal   @db.Decimal(12, 2)
  reason               String?
  status               String
  processedBy          String?
  processedAt          DateTime?
  createdAt            DateTime  @default(now())
  refundNumber         String?   @unique(where: raw("(\"refundNumber\" IS NOT NULL)"))
  reviewedBy           String?
  rejectionReason      String?
  mpesaPhone           String?
  mpesaReceiptNo       String?
  mpesaConversationId  String?
  providerRefReference String?
  order                Order     @relation(fields: [orderId], references: [id])

  @@index([orderId])
  @@index([status])
}

model Cancellation {
  id          String   @id @default(cuid())
  orderId     String   @unique
  reason      String
  cancelledBy String?
  createdAt   DateTime @default(now())
  order       Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId])
}

model Delivery {
  id                String         @id @default(cuid())
  orderId           String         @unique
  deliveryZoneId    String?
  method            String
  status            DeliveryStatus @default(PENDING)
  estimatedDelivery DateTime?
  dispatchedAt      DateTime?
  deliveredAt       DateTime?
  assignedCourierId String?
  trackingNumber    String?
  proofPhotoKey     String?
  failureReason     String?
  rescheduledTo     DateTime?
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt
  assignedCourier   Courier?       @relation(fields: [assignedCourierId], references: [id])
  deliveryZone      DeliveryZone?  @relation(fields: [deliveryZoneId], references: [id])
  order             Order          @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([status])
  @@index([deliveryZoneId])
}

model Payment {
  id                    String            @id @default(cuid())
  orderId               String
  provider              PaymentProvider
  amount                Decimal           @db.Decimal(12, 2)
  currency              String            @default("KES")
  status                PaymentStatus     @default(PENDING)
  reference             String?
  providerTransactionId String?
  providerResponse      Json?
  paidAt                DateTime?
  createdAt             DateTime          @default(now())
  attempts              Int               @default(1)
  failureReason         String?
  ipAddress             String?
  manualReference       String?
  manualVerifiedAt      DateTime?
  manualVerifiedBy      String?
  mpesaCheckoutId       String?
  mpesaPhone            String?
  mpesaReceiptNo        String?
  paybillNumber         String?
  pesapalRef            String?
  pesapalStatus         String?
  pickupConfirmedAt     DateTime?
  pickupConfirmedBy     String?
  pickupNotes           String?
  proofFileId           String?
  tillNumber            String?
  updatedAt             DateTime          @updatedAt
  invoices              Invoice[]
  mpesaTransaction      MpesaTransaction?
  order                 Order             @relation(fields: [orderId], references: [id])

  @@index([orderId])
  @@index([status])
}

model SavedMpesaNumber {
  id        String   @id @default(cuid())
  userId    String
  phone     String
  label     String?
  isDefault Boolean  @default(false)
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, phone])
  @@index([userId])
}

model SavedCard {
  id           String   @id @default(cuid())
  userId       String
  pesapalToken String
  last4        String
  brand        String
  expiryMonth  Int
  expiryYear   Int
  holderName   String?
  isDefault    Boolean  @default(false)
  createdAt    DateTime @default(now())
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model MpesaTransaction {
  id                 String   @id @default(cuid())
  paymentId          String   @unique
  phoneNumber        String
  merchantRequestId  String?
  checkoutRequestId  String?
  resultCode         String?
  resultDesc         String?
  mpesaReceiptNumber String?
  transactionDate    String?
  amount             Decimal? @db.Decimal(12, 2)
  payment            Payment  @relation(fields: [paymentId], references: [id])
}

model Invoice {
  id            String    @id @default(cuid())
  orderId       String
  paymentId     String?
  invoiceNumber String    @unique
  issuedAt      DateTime  @default(now())
  dueAt         DateTime?
  pdfUrl        String?
  vatAmount     Decimal   @db.Decimal(12, 2)
  totalAmount   Decimal   @db.Decimal(12, 2)
  pdfKey        String?
  subtotal      Decimal?  @db.Decimal(12, 2)
  sentAt        DateTime?
  sentBy        String?
  order         Order     @relation(fields: [orderId], references: [id])
  payment       Payment?  @relation(fields: [paymentId], references: [id])

  @@index([orderId])
}

model Counter {
  id        String   @id
  value     Int      @default(0)
  updatedAt DateTime @updatedAt
}

model UploadedFile {
  id              String             @id @default(cuid())
  userId          String?
  orderId         String?
  filename        String
  originalName    String
  mimeType        String
  size            Int
  url             String?
  thumbnailUrl    String?
  fileType        UploadedFileType
  status          UploadedFileStatus @default(UPLOADED)
  reviewedBy      String?
  reviewNotes     String?
  printVolume     Float?
  printWeight     Float?
  printTime       Float?
  dimensions      Json?
  createdAt       DateTime           @default(now())
  guestEmail      String?
  reviewedAt      DateTime?
  bucket          String?
  ext             String?
  folder          String?
  quoteId         String?
  rejectionReason String?
  storageKey      String?
  updatedAt       DateTime           @updatedAt
  uploadContext   UploadContext?
  uploadedByAdmin Boolean            @default(false)
  virusScanAt     DateTime?
  virusScanStatus String?
  printQuotes     PrintQuote[]
  quote           Quote?             @relation(fields: [quoteId], references: [id])
  user            User?              @relation(fields: [userId], references: [id])
}

model PrintQuote {
  id             String           @id @default(cuid())
  uploadedFileId String?
  userId         String
  material       String?
  quantity       Int              @default(1)
  dimensions     Json?
  area           Float?
  estimatedCost  Decimal?         @db.Decimal(12, 2)
  validUntil     DateTime?
  status         PrintQuoteStatus @default(DRAFT)
  staffNotes     String?
  createdAt      DateTime         @default(now())
  uploadedFile   UploadedFile?    @relation(fields: [uploadedFileId], references: [id])
  user           User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([status])
  @@index([createdAt])
}

model Quote {
  id                 String              @id @default(cuid())
  quoteNumber        String              @unique
  type               QuoteType
  status             QuoteStatus         @default(new)
  customerId         String?
  assignedStaffId    String?
  customerName       String
  customerEmail      String
  customerPhone      String?
  preferredContact   PreferredContact    @default(email)
  projectName        String?
  description        String?
  referenceFiles     String[]
  referenceFilesMeta Json?
  specifications     Json?
  budgetRange        String?
  deadline           DateTime?
  quotedAmount       Decimal?            @db.Decimal(12, 2)
  quotedAt           DateTime?
  quoteBreakdown     String?
  quoteValidityDays  Int?
  quotePdfUrl        String?
  acceptedAt         DateTime?
  rejectedAt         DateTime?
  rejectionReason    String?
  notes              String?
  adminNotes         String?
  referralSource     String?
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  closedAt           DateTime?
  closedBy           QuoteClosedBy?
  closedReason       String?
  cancelledAt        DateTime?
  cancelledBy        String?
  cancellationReason String?
  cancellationNotes  String?
  cancelledByAdminId String?
  aiDraft              Json?
  aiDraftGeneratedAt   DateTime?
  assignedStaff      Staff?              @relation(fields: [assignedStaffId], references: [id])
  cancelledByAdmin   User?               @relation("QuoteCancelledByAdmin", fields: [cancelledByAdminId], references: [id])
  customer           User?               @relation(fields: [customerId], references: [id])
  quoteCancellations QuoteCancellation[]
  quotePdfs          QuotePdf[]
  uploadedFiles      UploadedFile[]

  @@index([customerId])
  @@index([assignedStaffId])
  @@index([status])
  @@index([type])
  @@index([createdAt])
}

model QuoteCancellation {
  id                String   @id @default(cuid())
  quoteId           String
  cancelledBy       String
  cancelledByUserId String?
  reason            String
  notes             String?
  notificationSent  Boolean  @default(false)
  createdAt         DateTime @default(now())
  cancelledByUser   User?    @relation(fields: [cancelledByUserId], references: [id])
  quote             Quote    @relation(fields: [quoteId], references: [id], onDelete: Cascade)

  @@index([quoteId])
}

model QuotePdf {
  id          String    @id @default(cuid())
  quoteId     String
  pdfKey      String
  pdfUrl      String?
  generatedAt DateTime  @default(now())
  sentAt      DateTime?
  quote       Quote     @relation(fields: [quoteId], references: [id], onDelete: Cascade)

  @@index([quoteId])
}

model Coupon {
  id             String        @id @default(cuid())
  code           String        @unique
  type           CouponType
  value          Decimal       @db.Decimal(10, 2)
  minOrderAmount Decimal?      @db.Decimal(12, 2)
  maxUses        Int?
  usedCount      Int           @default(0)
  startDate      DateTime
  expiryDate     DateTime
  isActive       Boolean       @default(true)
  applicableTo   String        @default("ALL")
  applicableIds  String[]
  usages         CouponUsage[]
}

model CouponUsage {
  id       String   @id @default(cuid())
  couponId String
  userId   String
  orderId  String
  usedAt   DateTime @default(now())
  coupon   Coupon   @relation(fields: [couponId], references: [id])
  user     User     @relation(fields: [userId], references: [id])

  @@index([couponId])
  @@index([userId])
}

model Newsletter {
  id           String   @id @default(cuid())
  email        String   @unique
  name         String?
  isSubscribed Boolean  @default(true)
  subscribedAt DateTime @default(now())
  source       String?
}

model Wishlist {
  id        String   @id @default(cuid())
  userId    String
  productId String
  addedAt   DateTime @default(now())
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, productId])
  @@index([userId])
}

model Cart {
  id                   String    @id @default(cuid())
  userId               String?
  sessionId            String?
  items                Json
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt
  email                String?
  phone                String?
  lastActivityAt       DateTime? @default(now())
  recoveryEmailSent1At DateTime?
  recoveryEmailSent2At DateTime?
  convertedAt          DateTime?
  recoveryOptOutAt     DateTime?

  @@index([userId])
  @@index([sessionId])
  @@index([convertedAt])
  @@index([lastActivityAt])
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  type      String
  title     String
  message   String
  isRead    Boolean  @default(false)
  link      String?
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model CorporateAccount {
  id                    String                 @id @default(cuid())
  accountNumber         String                 @unique
  companyName           String
  tradingName           String?
  kraPin                String                 @unique
  vatNumber             String?
  industry              CorporateIndustry
  companySize           CompanySize
  website               String?
  primaryUserId         String                 @unique
  billingAddress        String
  billingCity           String
  billingCounty         String
  billingPostalCode     String?
  physicalAddress       String?
  physicalCity          String?
  physicalCounty        String?
  paymentTerms          PaymentTerms           @default(PREPAID)
  creditLimit           Int                    @default(0)
  creditUsed            Int                    @default(0)
  discountPercent       Int                    @default(0)
  taxExempt             Boolean                @default(false)
  status                CorporateStatus        @default(PENDING)
  tier                  CorporateTier          @default(STANDARD)
  accountManagerId      String?
  approvedBy            String?
  approvedAt            DateTime?
  rejectedAt            DateTime?
  rejectedReason        String?
  suspendedAt           DateTime?
  suspendedReason       String?
  estimatedMonthlySpend String?
  createdAt             DateTime               @default(now())
  updatedAt             DateTime               @updatedAt
  bulkQuotes            BulkQuote[]
  primaryUser           User                   @relation("CorporatePrimaryContact", fields: [primaryUserId], references: [id])
  applications          CorporateApplication[]
  brandAssets           CorporateBrandAsset[]
  invoices              CorporateInvoice[]
  notes                 CorporateNote[]
  purchaseOrders        CorporatePO[]
  teamMembers           CorporateTeamMember[]
  orders                Order[]

  @@index([status])
  @@index([kraPin])
}

model CorporateTeamMember {
  id              String           @id @default(cuid())
  corporateId     String
  userId          String
  role            CorporateRole    @default(MEMBER)
  jobTitle        String?
  department      String?
  canPlaceOrders  Boolean          @default(true)
  canViewInvoices Boolean          @default(false)
  canManageTeam   Boolean          @default(false)
  spendingLimit   Int?
  isActive        Boolean          @default(true)
  invitedBy       String?
  invitedAt       DateTime         @default(now())
  acceptedAt      DateTime?
  corporate       CorporateAccount @relation(fields: [corporateId], references: [id], onDelete: Cascade)
  user            User             @relation(fields: [userId], references: [id])

  @@unique([corporateId, userId])
  @@index([corporateId])
}

model CorporateBrandAsset {
  id            String           @id @default(cuid())
  corporateId   String
  uploadedBy    String
  name          String
  description   String?
  category      AssetCategory
  fileUrl       String
  fileKey       String
  fileName      String
  fileSize      Int
  mimeType      String
  thumbnailUrl  String?
  tags          String[]
  isActive      Boolean          @default(true)
  downloadCount Int              @default(0)
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt
  corporate     CorporateAccount @relation(fields: [corporateId], references: [id], onDelete: Cascade)

  @@index([corporateId])
}

model CorporatePO {
  id          String           @id @default(cuid())
  corporateId String
  poNumber    String
  description String?
  amount      Int
  status      POStatus         @default(OPEN)
  expiresAt   DateTime?
  createdAt   DateTime         @default(now())
  corporate   CorporateAccount @relation(fields: [corporateId], references: [id])
  orders      Order[]

  @@unique([corporateId, poNumber])
  @@index([corporateId])
}

model CorporateInvoice {
  id             String                 @id @default(cuid())
  invoiceNumber  String                 @unique
  corporateId    String
  periodStart    DateTime
  periodEnd      DateTime
  subtotal       Int
  vatAmount      Int
  discountAmount Int                    @default(0)
  totalAmount    Int
  dueAt          DateTime
  status         CorporateInvoiceStatus @default(DRAFT)
  pdfUrl         String?
  pdfKey         String?
  sentAt         DateTime?
  paidAt         DateTime?
  paymentRef     String?
  notes          String?
  createdAt      DateTime               @default(now())
  updatedAt      DateTime               @updatedAt
  corporate      CorporateAccount       @relation(fields: [corporateId], references: [id])
  orders         Order[]

  @@index([corporateId])
  @@index([status])
}

model CorporateApplication {
  id                       String                     @id @default(cuid())
  corporateId              String?
  applicantUserId          String
  companyName              String
  tradingName              String?
  kraPin                   String
  vatNumber                String?
  industry                 CorporateIndustry
  companySize              CompanySize
  website                  String?
  contactPerson            String
  contactPhone             String
  contactEmail             String
  billingAddress           String
  billingCity              String
  billingCounty            String
  estimatedMonthlySpend    String
  creditRequested          Int?
  paymentTermsRequested    PaymentTerms?
  additionalNotes          String?
  status                   CorporateApplicationStatus @default(PENDING)
  reviewedBy               String?
  reviewedAt               DateTime?
  rejectedReason           String?
  createdAt                DateTime                   @default(now())
  updatedAt                DateTime                   @updatedAt
  acceptedCorporateTermsAt DateTime?
  corporateTermsVersion    String?
  applicant                User                       @relation(fields: [applicantUserId], references: [id])
  corporate                CorporateAccount?          @relation(fields: [corporateId], references: [id])

  @@index([applicantUserId])
  @@index([status])
}

model CorporateNote {
  id          String           @id @default(cuid())
  corporateId String
  authorId    String
  body        String
  createdAt   DateTime         @default(now())
  corporate   CorporateAccount @relation(fields: [corporateId], references: [id], onDelete: Cascade)

  @@index([corporateId])
}

model CorporateInvite {
  id          String        @id @default(cuid())
  corporateId String
  email       String
  role        CorporateRole
  jobTitle    String?
  invitedBy   String
  token       String        @unique @default(cuid())
  expiresAt   DateTime
  acceptedAt  DateTime?
  createdAt   DateTime      @default(now())

  @@index([corporateId])
  @@index([email])
}

model BulkQuote {
  id            String           @id @default(cuid())
  corporateId   String
  items         Json
  totalEstimate Decimal?         @db.Decimal(12, 2)
  status        String
  expiresAt     DateTime?
  assignedTo    String?
  corporate     CorporateAccount @relation(fields: [corporateId], references: [id])
}

model Inventory {
  id                String          @id @default(cuid())
  productId         String
  quantity          Int             @default(0)
  lowStockThreshold Int             @default(5)
  location          String?
  unitCostKes       Float?
  productVariantId  String?
  variantId         String?
  reservedQuantity  Int             @default(0)
  product           Product         @relation(fields: [productId], references: [id], onDelete: Cascade)
  productVariant    ProductVariant? @relation(fields: [productVariantId], references: [id])
}

model ShopInventoryMovement {
  id          String   @id @default(cuid())
  productId   String
  quantity    Int
  reason      String
  reference   String?
  costPerUnit Decimal? @db.Decimal(12, 2)
  createdAt   DateTime @default(now())
  createdBy   String?
  product     Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId])
  @@index([createdAt])
}

model ShopPurchaseOrder {
  id           String                  @id @default(cuid())
  orderNumber  String                  @unique
  supplierId   String?
  status       String                  @default("DRAFT")
  totalKes     Decimal?                @db.Decimal(12, 2)
  expectedDate DateTime?
  receivedAt   DateTime?
  notes        String?
  createdAt    DateTime                @default(now())
  updatedAt    DateTime                @updatedAt
  lines        ShopPurchaseOrderLine[]
}

model ShopPurchaseOrderLine {
  id                  String            @id @default(cuid())
  shopPurchaseOrderId String
  productId           String
  quantity            Int
  unitCostKes         Decimal           @db.Decimal(12, 2)
  receivedQuantity    Int               @default(0)
  product             Product           @relation(fields: [productId], references: [id], onDelete: Cascade)
  shopPurchaseOrder   ShopPurchaseOrder @relation(fields: [shopPurchaseOrderId], references: [id], onDelete: Cascade)

  @@index([shopPurchaseOrderId])
  @@index([productId])
}

model ProductionQueue {
  id          String    @id @default(cuid())
  orderId     String
  orderItemId String
  assignedTo  String?
  status      String
  startedAt   DateTime?
  completedAt DateTime?
  machineId   String?
  notes       String?
  orderItem   OrderItem @relation(fields: [orderItemId], references: [id])
}

model Machine {
  id               String  @id @default(cuid())
  name             String
  type             String
  status           String  @default("IDLE")
  location         String?
  purchasePriceKes Float?
}

model PrinterAsset {
  id                       String           @id @default(cuid())
  assetTag                 String           @unique
  name                     String
  manufacturer             String?
  model                    String?
  serialNumber             String?
  printerType              PrinterType
  location                 String?
  notes                    String?
  isActive                 Boolean          @default(true)
  isDefault                Boolean          @default(false)
  createdAt                DateTime         @default(now())
  updatedAt                DateTime         @updatedAt
  maxPrintWidthM           Float?
  buildVolumeX             Float?
  buildVolumeY             Float?
  buildVolumeZ             Float?
  powerWatts               Float
  electricityRateKesKwh    Float            @default(24)
  productionSpeed          Float
  highQualitySpeed         Float?
  setupTimeHours           Float            @default(0.25)
  postProcessingTimeHours  Float?
  compatibleMaterials      String[]         @default([])
  purchasePriceKes         Float
  purchaseDate             DateTime?
  supplierName             String?
  expectedLifespanHours    Float
  annualMaintenanceKes     Float            @default(0)
  warrantyExpiryDate       DateTime?
  insurancePolicyRef       String?
  hoursUsedTotal           Float            @default(0)
  hoursUsedThisMonth       Float            @default(0)
  status                   AssetStatus      @default(ACTIVE)
  nextScheduledMaintDate   DateTime?
  maintenanceIntervalHours Float?
  remainingLifespanHours   Float?
  depreciationPerHourKes   Float?
  maintenancePerHourKes    Float?
  maintenanceLogs          MaintenanceLog[]
}

model MaintenanceLog {
  id                String                @id @default(cuid())
  printerAssetId    String
  type              MaintenanceType
  date              DateTime              @default(now())
  performedBy       String
  isExternal        Boolean               @default(false)
  technicianCompany String?
  description       String
  labourHours       Float                 @default(0)
  labourCostKes     Float                 @default(0)
  totalCostKes      Float                 @default(0)
  nextServiceDate   DateTime?
  nextServiceHours  Float?
  notes             String?
  createdAt         DateTime              @default(now())
  createdBy         String?
  hoursAtService    Float?
  partsCostKes      Float                 @default(0)
  printerAsset      PrinterAsset          @relation(fields: [printerAssetId], references: [id], onDelete: Cascade)
  partsUsed         MaintenancePartUsed[]

  @@index([printerAssetId])
}

model MaintenancePartUsed {
  id               String         @id @default(cuid())
  maintenanceLogId String
  lfStockItemId    String?
  quantityUsed     Float
  unitCostKes      Float
  totalCostKes     Float
  partName         String?
  lfStockItem      LFStockItem?   @relation(fields: [lfStockItemId], references: [id])
  maintenanceLog   MaintenanceLog @relation(fields: [maintenanceLogId], references: [id], onDelete: Cascade)

  @@index([maintenanceLogId])
}

model InventoryHardwareItem {
  id                      String   @id @default(cuid())
  name                    String
  category                String
  priceKes                Float    @default(0)
  isActive                Boolean  @default(true)
  sortOrder               Int      @default(0)
  location                String?
  createdAt               DateTime @default(now())
  updatedAt               DateTime @updatedAt
  linkedPrinterId         String?
  timeHours               Float?
  hardwareType            String?
  printerSubType          String?
  model                   String?
  maxPrintWidthM          Float?
  printSpeedSqmPerHour    Float?
  setupTimeHours          Float?
  lifespanHours           Float?
  annualMaintenanceKes    Float?
  powerWatts              Float?
  electricityRateKesKwh   Float?
  maintenancePerYearKes   Float?
  postProcessingTimeHours Float?
}

model ThreeDConsumable {
