model CorporateAccount {
  id                  String              @id @default(cuid())
  accountNumber       String              @unique
  companyName         String
  tradingName         String?
  kraPin              String              @unique
  vatNumber           String?
  industry            CorporateIndustry
  companySize         CompanySize
  website             String?

  primaryUserId       String              @unique
  primaryUser         User                @relation("CorporatePrimaryContact", fields: [primaryUserId], references: [id])

  billingAddress      String
  billingCity         String
  billingCounty       String
  billingPostalCode   String?

  physicalAddress     String?
  physicalCity        String?
  physicalCounty      String?

  paymentTerms        PaymentTerms        @default(PREPAID)
  creditLimit         Int                 @default(0)
  creditUsed          Int                 @default(0)
  discountPercent     Int                 @default(0)
  taxExempt           Boolean             @default(false)

  status              CorporateStatus     @default(PENDING)
  tier                CorporateTier       @default(STANDARD)
  accountManagerId    String?
  approvedBy          String?
  approvedAt          DateTime?
  rejectedAt          DateTime?
  rejectedReason      String?
  suspendedAt         DateTime?
  suspendedReason     String?
  estimatedMonthlySpend String?

  teamMembers         CorporateTeamMember[]
  brandAssets         CorporateBrandAsset[]
