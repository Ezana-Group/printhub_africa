  @@index([userId])
}

model Newsletter {
  id           String   @id @default(cuid())
  email        String   @unique
  name         String?
  isSubscribed Boolean  @default(true)
  subscribedAt DateTime @default(now())
  source       String?
}

model Wishlist {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  productId String
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  addedAt   DateTime @default(now())

  @@unique([userId, productId])
  @@index([userId])
}

model Cart {
  id                    String    @id @default(cuid())
  userId                String?
  sessionId             String?   // for guests
  email                 String?
  phone                 String?
  items                 Json     // array of { productId, variantId, quantity, customizations }
  lastActivityAt        DateTime? @default(now())
  recoveryEmailSent1At  DateTime?
  recoveryEmailSent2At  DateTime?
  recoveryOptOutAt      DateTime? // user opted out of abandoned-cart emails
  convertedAt           DateTime? // set when order placed
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  @@index([userId])
  @@index([sessionId])
  @@index([convertedAt])
  @@index([lastActivityAt])
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      String
  title     String
  message   String
  isRead    Boolean  @default(false)
  link      String?
  createdAt DateTime @default(now())

  @@index([userId])
}

