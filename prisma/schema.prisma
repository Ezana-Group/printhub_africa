model CatalogueItem {
  id                 String                  @id @default(cuid())
  name               String
  slug               String                  @unique
  shortDescription   String?
  description        String?
  categoryId         String
  designerId         String?
  tags               String[]
  sourceUrl          String?
  licenseType        CatalogueLicense        @default(CC_BY)
  designerCredit     String?
  sourceType         CatalogueSourceType     @default(MANUAL)
  status             CatalogueStatus         @default(DRAFT)
  minQuantity        Int                     @default(1)
  maxQuantity        Int                     @default(50)
  isFeatured         Boolean                 @default(false)
  isNewArrival       Boolean                 @default(false)
  isStaffPick        Boolean                 @default(false)
  sortOrder          Int                     @default(0)
  createdAt          DateTime                @default(now())
  updatedAt          DateTime                @updatedAt
  basePriceKes       Float?
  isPopular          Boolean                 @default(false)
  metaDescription    String?
  metaTitle          String?
  priceOverrideKes   Float?
  printTimeHours     Float?
  weightGrams        Float?
  approvedAt         DateTime?
  rejectionReason    String?
  approvedById       String?
  archivedAt         DateTime?
  archivedById       String?
  importedById       String?
  modelStorageKey    String?
  modelUrl           String?
  productId          String?                 @unique
  rejectedById       String?
  approvedBy         User?                   @relation("CatalogueApprovedBy", fields: [approvedById], references: [id])
  archivedBy         User?                   @relation("CatalogueArchivedBy", fields: [archivedById], references: [id])
  category           Category                @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  designer           CatalogueDesigner?      @relation(fields: [designerId], references: [id])
  importedBy         User?                   @relation("CatalogueImportedBy", fields: [importedById], references: [id])
  product            Product?                @relation("CatalogueProductLink", fields: [productId], references: [id])
  rejectedBy         User?                   @relation("CatalogueRejectedBy", fields: [rejectedById], references: [id])
  availableMaterials CatalogueItemMaterial[]
  photos             CatalogueItemPhoto[]
  podProduct         Product?                @relation("CataloguePODSource")

  @@index([categoryId])
  @@index([status])
  @@index([slug])
}

