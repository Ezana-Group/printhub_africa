generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["partialIndexes"]
}

datasource db {
  provider = "postgresql"
}

model User {
  id                       String                     @id @default(cuid())
  name                     String?
  email                    String                     @unique
  phone                    String?
  passwordHash             String?
  role                     UserRole                   @default(CUSTOMER)
  emailVerified            DateTime?
  createdAt                DateTime                   @default(now())
  updatedAt                DateTime                   @updatedAt
  profileImage             String?
  loyaltyPoints            Int                        @default(0)
  preferredLanguage        String?                    @default("en")
  failedLoginAttempts      Int                        @default(0)
  lockedUntil              DateTime?
  inviteToken              String?
  inviteTokenExpiry        DateTime?
  status                   String?                    @default("ACTIVE")
  anonymisedAt             DateTime?
  dateOfBirth              DateTime?
  isAnonymised             Boolean?                   @default(false)
  totpSecret               String?
  stripeCustomerId         String?
  acceptedTermsAt          DateTime?
  marketingConsent         Boolean                    @default(false)
  marketingConsentAt       DateTime?
  termsVersion             String?
  productionPinHash        String?
  twoFaMethod              String?
  otpCodeHash              String?
  otpExpiresAt             DateTime?
  /// Where invite / password-setup emails are sent (optional). Login email remains `email`.
  personalEmail            String?
  accounts                 Account[]
  addresses                Address[]
  auditLogs                AuditLog[]
  primaryCorporateAccount  CorporateAccount?          @relation("CorporatePrimaryContact")
  corporateApplications    CorporateApplication[]
  corporateTeamMemberships CorporateTeamMember[]
  couponUsages             CouponUsage[]
  emailMailboxViewers      EmailMailboxViewer[]
  assignedEmailThreads     EmailThread[]              @relation("AssignedThreads")
  emailThreadsCreated      EmailThread[]              @relation("EmailThreadCreatedBy")
  loyaltyAccount           LoyaltyAccount?
  notifications            Notification[]
  orders                   Order[]
  printQuotes              PrintQuote[]
  productReviews           ProductReview[]
  quotesCancelledByAdmin   Quote[]                    @relation("QuoteCancelledByAdmin")
  quotes                   Quote[]
  quoteCancellations       QuoteCancellation[]
  referralCodes            ReferralCode?
  savedAddresses           SavedAddress[]
  savedCards               SavedCard[]
  savedMpesaNumbers        SavedMpesaNumber[]
  sessions                 Session[]
  staff                    Staff?
  supportTickets           SupportTicket[]
  performedByMovements     ThreeDConsumableMovement[]
  ticketMessages           TicketMessage[]
  uploadedFiles            UploadedFile[]
  userNotificationPrefs    UserNotificationPrefs?
  userPermissions          UserPermission[]
  wishlists                Wishlist[]
}

model Address {
  id         String   @id @default(cuid())
  userId     String
  label      String
  street     String
  city       String
  county     String
  postalCode String?
  isDefault  Boolean  @default(false)
  lat        Float?
  lng        Float?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Category {
  id              String     @id @default(cuid())
  name            String
  slug            String     @unique
  description     String?
  image           String?
  parentId        String?
  sortOrder       Int        @default(0)
  isActive        Boolean    @default(true)
  metaTitle       String?
  metaDescription String?
  parent          Category?  @relation("CategoryTree", fields: [parentId], references: [id])
  children        Category[] @relation("CategoryTree")
  products        Product[]

  @@index([parentId])
}

model Product {
  id                 String                  @id @default(cuid())
  name               String
  slug               String                  @unique
  description        String?
  shortDescription   String?
  categoryId         String
  productType        ProductType
  images             String[]
  basePrice          Decimal                 @db.Decimal(12, 2)
  comparePrice       Decimal?                @db.Decimal(12, 2)
  costPrice          Decimal?                @db.Decimal(12, 2)
  sku                String?                 @unique
  stock              Int                     @default(0)
  lowStockThreshold  Int                     @default(0)
  minOrderQty        Int                     @default(1)
  maxOrderQty        Int?
  weight             Decimal?                @db.Decimal(10, 3)
  dimensions         Json?
  materials          String[]
  colors             String[]
  finishes           String[]
  isActive           Boolean                 @default(true)
  isFeatured         Boolean                 @default(false)
  metaTitle          String?
  metaDescription    String?
  tags               String[]
  createdAt          DateTime                @default(now())
  updatedAt          DateTime                @updatedAt
  brand              String?
  specifications     Json?
  compatibility      String?
  materialType       String?
  availability       ProductAvailability     @default(IN_STOCK)
  inventory          Inventory[]
  orderItems         OrderItem[]
  category           Category                @relation(fields: [categoryId], references: [id])
  productImages      ProductImage[]
  reviews            ProductReview[]
  variants           ProductVariant[]
  shopStockMovements ShopInventoryMovement[]
  shopPOLines        ShopPurchaseOrderLine[]
  wishlists          Wishlist[]

  @@index([categoryId])
  @@index([slug])
  @@index([isFeatured, isActive])
  @@index([isActive])
  @@index([createdAt])
  @@index([basePrice])
}

model ProductVariant {
  id         String      @id @default(cuid())
  productId  String
  name       String
  sku        String?     @unique
  price      Decimal     @db.Decimal(12, 2)
  stock      Int         @default(0)
  attributes Json
  image      String?
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt
  inventory  Inventory[]
  orderItems OrderItem[]
  product    Product     @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId])
}

model ProductImage {
  id         String  @id @default(cuid())
  productId  String
  url        String
  altText    String?
  sortOrder  Int     @default(0)
  isPrimary  Boolean @default(false)
  storageKey String?
  uploadId   String?
  product    Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId])
}

model ProductReview {
  id         String   @id @default(cuid())
  productId  String
  userId     String
  rating     Int
  title      String?
  body       String?
  images     String[]
  isVerified Boolean  @default(false)
  isApproved Boolean  @default(false)
  createdAt  DateTime @default(now())
  product    Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([productId])
  @@index([userId])
}

model PrintMaterial {
  id             String            @id @default(cuid())
  slug           String?           @unique
  name           String
  description    String?
  type           PrintMaterialType
  colorOptions   String[]
  pricePerGram   Decimal           @db.Decimal(10, 4)
  density        Float?
  minChargeGrams Int?
  leadTimeDays   Int               @default(3)
  image          String?
  properties     Json?
  sortOrder      Int               @default(0)
  isActive       Boolean           @default(true)
}

model PrintFinish {
  id            String  @id @default(cuid())
  name          String
  description   String?
  priceModifier Decimal @default(0) @db.Decimal(10, 2)
  isActive      Boolean @default(true)
}

model PrintingMedium {
  id              String  @id @default(cuid())
  slug            String? @unique
  name            String
  pricePerSqMeter Decimal @db.Decimal(12, 2)
  minWidth        Float?
  maxWidth        Float?
  minHeight       Float?
  maxHeight       Float?
  description     String?
  sortOrder       Int     @default(0)
  isActive        Boolean @default(true)
}

model LaminationType {
  id          String  @id @default(cuid())
  slug        String? @unique
  name        String
  pricePerSqm Decimal @default(0) @db.Decimal(10, 2)
}

model LargeFormatFinishing {
  id           String  @id @default(cuid())
  code         String  @unique
  name         String
  pricePerUnit Decimal @db.Decimal(10, 2)
  sortOrder    Int     @default(0)
  isActive     Boolean @default(true)
}

model DesignServiceOption {
  id        String  @id @default(cuid())
  code      String  @unique
  name      String
  flatFee   Decimal @default(0) @db.Decimal(10, 2)
  sortOrder Int     @default(0)
  isActive  Boolean @default(true)
}

model TurnaroundOption {
  id               String  @id @default(cuid())
  code             String  @unique
  name             String
  surchargePercent Decimal @default(0) @db.Decimal(5, 2)
  serviceType      String
  sortOrder        Int     @default(0)
  isActive         Boolean @default(true)
}

model LFPrinterSettings {
  id                      String   @id @default(cuid())
  name                    String
  model                   String
  isActive                Boolean  @default(true)
  isDefault               Boolean  @default(false)
  maxPrintWidthM          Float
  printSpeedSqmPerHour    Float
  printSpeedHighQualSqmHr Float?
  setupTimeHours          Float    @default(0.25)
  purchasePriceKes        Float
  lifespanHours           Float    @default(20000)
  annualMaintenanceKes    Float
  powerWatts              Float
  electricityRateKesKwh   Float    @default(24)
  inkChannelSettings      Json?
  updatedBy               String?
  updatedAt               DateTime @updatedAt
  createdAt               DateTime @default(now())
}

model LFBusinessSettings {
  id                       String   @id @default(cuid())
  labourRateKesPerHour     Float    @default(200)
  finishingTimeEyeletStd   Float    @default(0.1)
  finishingTimeEyeletHeavy Float    @default(0.2)
  finishingTimeHemAll4     Float    @default(0.25)
  finishingTimeHemTop2     Float    @default(0.15)
  finishingTimePole        Float    @default(0.2)
  finishingTimeRope        Float    @default(0.1)
  monthlyRentKes           Float
  monthlyUtilitiesKes      Float
  monthlyInsuranceKes      Float
  monthlyOtherKes          Float
  workingDaysPerMonth      Int      @default(26)
  workingHoursPerDay       Int      @default(8)
  wastageBufferPercent     Float    @default(3)
  substrateWasteFactor     Float    @default(1.05)
  rigidSheetWasteFactor    Float    @default(1.1)
  defaultProfitMarginPct   Float    @default(40)
  vatRatePct               Float    @default(16)
  minOrderValueKes         Float    @default(500)
  updatedBy                String?
  updatedAt                DateTime @updatedAt
}

model LFStockItem {
  id                       String                @id @default(cuid())
  code                     String                @unique
  name                     String
  category                 String
  unitType                 String
  rollWidthM               Float?
  quantityOnHand           Float                 @default(0)
  lowStockThreshold        Float                 @default(0)
  costPerUnit              Float                 @default(0)
  lastPurchasePriceKes     Float?
  averageCostKes           Float                 @default(0)
  totalUnitsEverPurchased  Float                 @default(0)
  totalCostEverPurchased   Float                 @default(0)
  lastReceivedAt           DateTime?
  printerAssetId           String?
  replacementIntervalHours Float?
  lastReplacedAt           DateTime?
  nextReplacementDue       DateTime?
  createdAt                DateTime              @default(now())
  updatedAt                DateTime              @updatedAt
  maintenancePartUsages    MaintenancePartUsed[]
}

model MachineType {
  id          String  @id @default(cuid())
  code        String  @unique
  name        String
  ratePerHour Decimal @db.Decimal(10, 2)
  sortOrder   Int     @default(0)
  isActive    Boolean @default(true)
}

model ThreeDAddon {
  id           String  @id @default(cuid())
  code         String  @unique
  name         String
  pricePerUnit Decimal @db.Decimal(10, 2)
  category     String
  sortOrder    Int     @default(0)
  isActive     Boolean @default(true)
}

model PricingConfig {
  id        String @id @default(cuid())
  key       String @unique
  valueJson String
}

model Order {
  id                   String               @id @default(cuid())
  orderNumber          String               @unique
  userId               String?
  status               OrderStatus          @default(PENDING)
  type                 OrderType
  subtotal             Decimal              @db.Decimal(12, 2)
  tax                  Decimal              @default(0) @db.Decimal(12, 2)
  shippingCost         Decimal              @default(0) @db.Decimal(12, 2)
  discount             Decimal              @default(0) @db.Decimal(12, 2)
  total                Decimal              @db.Decimal(12, 2)
  currency             String               @default("KES")
  notes                String?
  estimatedDelivery    DateTime?
  createdAt            DateTime             @default(now())
  updatedAt            DateTime             @updatedAt
  cancelReason         String?
  cancelledAt          DateTime?
  deliveredAt          DateTime?
  manualPaymentBy      String?
  manualPaymentNotes   String?
  manualPaymentRef     String?
  mpesaFailureReason   String?
  paidAt               DateTime?
  paymentLinkExpiresAt DateTime?
  paymentLinkToken     String?
  shippedAt            DateTime?
  trackingNumber       String?
  paymentMethod        String?
  paymentStatus        String?
  pickupCode           String?
  pickupLocationId     String?
  courierId            String?
  deliveryZoneId       String?
  corporateId          String?
  poReference          String?
  corporatePOId        String?
  corporateInvoiceId   String?
  placedBy             String?
  isNetTerms           Boolean              @default(false)
  cancellation         Cancellation?
  delivery             Delivery?
  invoices             Invoice[]
  corporate            CorporateAccount?    @relation(fields: [corporateId], references: [id])
  corporateInvoice     CorporateInvoice?    @relation(fields: [corporateInvoiceId], references: [id])
  corporatePO          CorporatePO?         @relation(fields: [corporatePOId], references: [id])
  courier              Courier?             @relation(fields: [courierId], references: [id])
  deliveryZone         DeliveryZone?        @relation(fields: [deliveryZoneId], references: [id])
  pickupLocation       PickupLocation?      @relation(fields: [pickupLocationId], references: [id])
  user                 User?                @relation(fields: [userId], references: [id])
  items                OrderItem[]
  timeline             OrderTimeline[]
  trackingEvents       OrderTrackingEvent[]
  payments             Payment[]
  refunds              Refund[]
  shippingAddress      ShippingAddress?

  @@index([status])
  @@index([createdAt])
  @@index([userId])
  @@index([orderNumber])
  @@index([paymentStatus])
}

model OrderItem {
  id               String            @id @default(cuid())
  orderId          String
  productId        String?
  quantity         Int
  unitPrice        Decimal           @db.Decimal(12, 2)
  customizations   Json?
  uploadedFileId   String?
  instructions     String?
  createdAt        DateTime          @default(now())
  productVariantId String?
  variantId        String?
  order            Order             @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product          Product?          @relation(fields: [productId], references: [id])
  productVariant   ProductVariant?   @relation(fields: [productVariantId], references: [id])
  productionQueue  ProductionQueue[]

  @@index([orderId])
}

model OrderTimeline {
  id        String   @id @default(cuid())
  orderId   String
  status    String
  message   String?
  timestamp DateTime @default(now())
  updatedBy String?
  order     Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId])
}

model OrderTrackingEvent {
  id          String   @id @default(cuid())
  orderId     String
  status      String
  title       String
  description String?
  isPublic    Boolean  @default(true)
  location    String?
  courierRef  String?
  createdBy   String?
  createdAt   DateTime @default(now())
  order       Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId])
}

model ShippingAddress {
  id             String  @id @default(cuid())
  orderId        String  @unique
  fullName       String
  email          String
  phone          String
  street         String
  city           String
  county         String
  postalCode     String?
  deliveryMethod String?
  lat            Float?
  lng            Float?
  order          Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
}

model Refund {
  id                  String    @id @default(cuid())
  orderId             String
  amount              Decimal   @db.Decimal(12, 2)
  reason              String?
  status              String
  processedBy         String?
  processedAt         DateTime?
  createdAt           DateTime  @default(now())
  refundNumber        String?   @unique(where: raw("(\"refundNumber\" IS NOT NULL)"))
  reviewedBy          String?
  rejectionReason     String?
  mpesaPhone          String?
  mpesaReceiptNo      String?
  mpesaConversationId String?
  providerRefReference String?
  order               Order     @relation(fields: [orderId], references: [id])

  @@index([orderId])
  @@index([status])
}

model Cancellation {
  id          String   @id @default(cuid())
  orderId     String   @unique
  reason      String
  cancelledBy String?
  createdAt   DateTime @default(now())
  order       Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId])
}

model Delivery {
  id                String         @id @default(cuid())
  orderId           String         @unique
  deliveryZoneId    String?
  method            String
  status            DeliveryStatus @default(PENDING)
  estimatedDelivery DateTime?
  dispatchedAt      DateTime?
  deliveredAt       DateTime?
  assignedCourierId String?
  trackingNumber    String?
  proofPhotoKey     String?
  failureReason     String?
  rescheduledTo     DateTime?
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt
  assignedCourier   Courier?       @relation(fields: [assignedCourierId], references: [id])
  deliveryZone      DeliveryZone?  @relation(fields: [deliveryZoneId], references: [id])
  order             Order          @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([status])
  @@index([deliveryZoneId])
}

model Payment {
  id                    String            @id @default(cuid())
  orderId               String
  provider              PaymentProvider
  amount                Decimal           @db.Decimal(12, 2)
  currency              String            @default("KES")
  status                PaymentStatus     @default(PENDING)
  reference             String?
  providerTransactionId String?
  providerResponse      Json?
  paidAt                DateTime?
  createdAt             DateTime          @default(now())
  attempts              Int               @default(1)
  failureReason         String?
  ipAddress             String?
  manualReference       String?
  manualVerifiedAt      DateTime?
  manualVerifiedBy      String?
  mpesaCheckoutId       String?
  mpesaPhone            String?
  mpesaReceiptNo        String?
  paybillNumber         String?
  pesapalRef            String?
  pesapalStatus         String?
  pickupConfirmedAt     DateTime?
  pickupConfirmedBy     String?
  pickupNotes           String?
  proofFileId           String?
  tillNumber            String?
  updatedAt             DateTime          @updatedAt
  invoices              Invoice[]
  mpesaTransaction      MpesaTransaction?
  order                 Order             @relation(fields: [orderId], references: [id])

  @@index([orderId])
  @@index([status])
}

model SavedMpesaNumber {
  id        String   @id @default(cuid())
  userId    String
  phone     String
  label     String?
  isDefault Boolean  @default(false)
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, phone])
  @@index([userId])
}

model SavedCard {
  id           String   @id @default(cuid())
  userId       String
  pesapalToken String
  last4        String
  brand        String
  expiryMonth  Int
  expiryYear   Int
  holderName   String?
  isDefault    Boolean  @default(false)
  createdAt    DateTime @default(now())
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model MpesaTransaction {
  id                 String   @id @default(cuid())
  paymentId          String   @unique
  phoneNumber        String
  merchantRequestId  String?
  checkoutRequestId  String?
  resultCode         String?
  resultDesc         String?
  mpesaReceiptNumber String?
  transactionDate    String?
  amount             Decimal? @db.Decimal(12, 2)
  payment            Payment  @relation(fields: [paymentId], references: [id])
}

model Invoice {
  id            String    @id @default(cuid())
  orderId       String
  paymentId     String?
  invoiceNumber String    @unique
  issuedAt      DateTime  @default(now())
  dueAt         DateTime?
  pdfUrl        String?
  vatAmount     Decimal   @db.Decimal(12, 2)
  totalAmount   Decimal   @db.Decimal(12, 2)
  pdfKey        String?
  subtotal      Decimal?  @db.Decimal(12, 2)
  sentAt        DateTime?
  sentBy        String?
  order         Order     @relation(fields: [orderId], references: [id])
  payment       Payment?  @relation(fields: [paymentId], references: [id])

  @@index([orderId])
}

model Counter {
  id        String   @id
  value     Int      @default(0)
  updatedAt DateTime @updatedAt
}

model UploadedFile {
  id              String             @id @default(cuid())
  userId          String?
  orderId         String?
  filename        String
  originalName    String
  mimeType        String
  size            Int
  url             String?
  thumbnailUrl    String?
  fileType        UploadedFileType
  status          UploadedFileStatus @default(UPLOADED)
  reviewedBy      String?
  reviewNotes     String?
  printVolume     Float?
  printWeight     Float?
  printTime       Float?
  dimensions      Json?
  createdAt       DateTime           @default(now())
  guestEmail      String?
  reviewedAt      DateTime?
  bucket          String?
  ext             String?
  folder          String?
  quoteId         String?
  rejectionReason String?
  storageKey      String?
  updatedAt       DateTime           @updatedAt
  uploadContext   UploadContext?
  uploadedByAdmin Boolean            @default(false)
  virusScanAt     DateTime?
  virusScanStatus String?
  printQuotes     PrintQuote[]
  quote           Quote?             @relation(fields: [quoteId], references: [id])
  user            User?              @relation(fields: [userId], references: [id])
}

model PrintQuote {
  id             String           @id @default(cuid())
  uploadedFileId String?
  userId         String
  material       String?
  quantity       Int              @default(1)
  dimensions     Json?
  area           Float?
  estimatedCost  Decimal?         @db.Decimal(12, 2)
  validUntil     DateTime?
  status         PrintQuoteStatus @default(DRAFT)
  staffNotes     String?
  createdAt      DateTime         @default(now())
  uploadedFile   UploadedFile?    @relation(fields: [uploadedFileId], references: [id])
  user           User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([status])
  @@index([createdAt])
}

model Quote {
  id                 String              @id @default(cuid())
  quoteNumber        String              @unique
  type               QuoteType
  status             QuoteStatus         @default(new)
  customerId         String?
  assignedStaffId    String?
  customerName       String
  customerEmail      String
  customerPhone      String?
  preferredContact   PreferredContact    @default(email)
  projectName        String?
  description        String?
  referenceFiles     String[]
  referenceFilesMeta Json?
  specifications     Json?
  budgetRange        String?
  deadline           DateTime?
  quotedAmount       Decimal?            @db.Decimal(12, 2)
  quotedAt           DateTime?
  quoteBreakdown     String?
  quoteValidityDays  Int?
  quotePdfUrl        String?
  acceptedAt         DateTime?
  rejectedAt         DateTime?
  rejectionReason    String?
  notes              String?
  adminNotes         String?
  referralSource     String?
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  closedAt           DateTime?
  closedBy           QuoteClosedBy?
  closedReason       String?
  cancelledAt        DateTime?
  cancelledBy        String?
  cancellationReason String?
  cancellationNotes  String?
  cancelledByAdminId String?
  assignedStaff      Staff?              @relation(fields: [assignedStaffId], references: [id])
  cancelledByAdmin   User?               @relation("QuoteCancelledByAdmin", fields: [cancelledByAdminId], references: [id])
  customer           User?               @relation(fields: [customerId], references: [id])
  quoteCancellations QuoteCancellation[]
  quotePdfs          QuotePdf[]
  uploadedFiles      UploadedFile[]

  @@index([customerId])
  @@index([assignedStaffId])
  @@index([status])
  @@index([type])
  @@index([createdAt])
}

model QuoteCancellation {
  id                String   @id @default(cuid())
  quoteId           String
  cancelledBy       String
  cancelledByUserId String?
  reason            String
  notes             String?
  notificationSent  Boolean  @default(false)
  createdAt         DateTime @default(now())
