model AuditLog {
  id         String   @id @default(cuid())
  userId     String?
  action     String
  entity     String
  entityId   String?
  before     Json?
  after      Json?
  ipAddress  String?
  timestamp  DateTime @default(now())
  category   String?
  targetId   String?
