.env
.env.local
.env.development.local
.env.test.local
.env.production.local
.env.test

# dependencies
/node_modules
/.pnp
.pnp.js
.yarn/install-state.gz

# testing
/coverage
/test-results
/playwright-report

# next.js
/.next/
/out/
/build

# Prisma
prisma/dev.db
prisma/dev.db-journal

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# misc
.DS_Store
Thumbs.db
*.pem

# Editor
.vscode/
.idea/
*.swp
*.swo

# Uploads (never commit user files)
public/uploads/

# ERPNext Docker volumes (local only)
erpnext-data/

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

/lib/generated/prisma

