# ============================================================
# PrintHub — Environment variables template
# ============================================================
# Copy to .env.local and fill in values. Never commit .env.local.
# For testing stack: Neon, R2, Resend, Africa's Talking, M-Pesa Daraja.
# ============================================================

# ── APP ─────────────────────────────────────────────────────
# This is the root URL used for emails and Absolute links.
# Local: http://localhost:3000  |  Prod: https://printhub.africa
NEXT_PUBLIC_APP_URL=https://printhub.africa

# Domains for Cookie Scoping and Subdomain Routing (Production)
# Root domain should include a leading dot for subdomains (e.g. .printhub.africa)
NEXT_PUBLIC_ROOT_DOMAIN=.printhub.africa
# Admin subdomain (e.g. admin.printhub.africa)
NEXT_PUBLIC_ADMIN_DOMAIN=admin.printhub.africa

NEXT_PUBLIC_APP_NAME=PrintHub

# ── NEXTAUTH ─────────────────────────────────────────────────
# Set to the same origin as NEXT_PUBLIC_APP_URL.
# In a subdomain architecture, NextAuth should typically use the root domain.
NEXTAUTH_URL=
NEXTAUTH_SECRET=

# ── DATABASE (Neon: pooled + direct for migrations) ──────────
# For best TTFB on Vercel: use Neon's connection pooler for DATABASE_URL to avoid cold-start DB connections.
# Neon dashboard: use the "pooled" connection string (e.g. ep-xxx-pooler.neon.tech?pgbouncer=true).
# Local Postgres: use your normal connection string. DIRECT_URL is for Prisma migrations (non-pooled); same as DATABASE_URL if not using a pooler.
DATABASE_URL=
DIRECT_URL=

# Required for seed/clean scripts only. Set to 1 in .env.local for this project so dummy data from
# other similar projects is never seeded here. Seed and clean will refuse to run unless this is set
# and the connected DB is the PrintHub DB (DatabaseGuard table).
PRINTHUB_SEED_ALLOW=1 

# ── FILE STORAGE (Cloudflare R2) ──────────────────────────────
R2_ENDPOINT=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_UPLOADS_BUCKET=printhub-uploads
R2_PUBLIC_BUCKET=printhub-public
# Base URL for public file links (server). Required for upload confirm to return image URLs.
# Set NEXT_PUBLIC_R2_PUBLIC_URL to the same value so client-built URLs match; if unset, the server-provided URL from confirm is used.
R2_PUBLIC_URL=https://printhub-uploads.r2.dev
NEXT_PUBLIC_R2_PUBLIC_URL=

# ── EMAIL (Resend) ───────────────────────────────────────────
# Used for: verification, password reset, order/quote/ticket/refund/cancel emails, abandoned cart, and "Email invoice to customer" (Finance → Invoices).
RESEND_API_KEY=
FROM_EMAIL=hello@printhub.africa
FROM_NAME=PrintHub
# Optional: where to send contact form copies (defaults to primary business email)
# CONTACT_EMAIL=

# ── SMS (Africa's Talking — Sandbox) ─────────────────────────
# Used for: test SMS (admin), 2FA login codes when user chooses "SMS code" in My Account.
AT_API_KEY=
AT_USERNAME=sandbox
AT_SENDER_ID=PrintHub
AT_ENV=sandbox

# ── PAYMENTS: M-Pesa (Daraja Sandbox) ───────────────────────
MPESA_CONSUMER_KEY=
MPESA_CONSUMER_SECRET=
MPESA_SHORTCODE=174379
MPESA_PASSKEY=
MPESA_CALLBACK_URL=
MPESA_ENV=sandbox
# Production: comma-separated Safaricom callback IPs (from go-live docs). Leave empty in sandbox.
MPESA_CALLBACK_IP_WHITELIST=
# Optional: Paybill number shown when STK fails (customer pays via Lipa na M-Pesa → Pay Bill). Default 522522.
# NEXT_PUBLIC_MPESA_PAYBILL=522522

# ── M-Pesa B2C (Refunds) ─────────────────────────────────────
# Required for Admin → Refunds → "Send via M-Pesa". Daraja B2C API credentials and callback URLs.
# MPESA_B2C_INITIATOR_NAME=
# MPESA_B2C_SECURITY_CREDENTIAL=
# MPESA_B2C_RESULT_URL=
# MPESA_B2C_QUEUE_TIMEOUT_URL=

# ── PAYMENTS: Other Kenya mobile money (optional) ───────────
# Airtel Money and TKash (Telkom) are shown at checkout. To enable STK/push, add API credentials when available.
# AIRTEL_MONEY_* and TKASH_* can be added here when integrating Airtel/Telkom payment APIs.

# ── PAYMENTS: PESAPAL — primary card and mobile money provider ───────
# Cards, Airtel Money, Equitel, etc. Card payments at checkout redirect to PesaPal. Register your IPN URL in PesaPal dashboard first, then paste the returned notification ID here.
PESAPAL_CONSUMER_KEY=
PESAPAL_CONSUMER_SECRET=
PESAPAL_IPN_URL=
PESAPAL_NOTIFICATION_ID=
PESAPAL_ENV=sandbox

# ── OAUTH (optional; set NEXT_PUBLIC_* to show buttons on login/register) ─
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
NEXT_PUBLIC_GOOGLE_CLIENT_ID=

FACEBOOK_CLIENT_ID=
FACEBOOK_CLIENT_SECRET=
NEXT_PUBLIC_FACEBOOK_APP_ID=

# Apple: clientSecret is a JWT (generate via Apple Developer); expires ~6 months
APPLE_CLIENT_ID=
APPLE_CLIENT_SECRET=
NEXT_PUBLIC_APPLE_CLIENT_ID=

# Magic link (email sign-in) uses Resend; FROM_EMAIL above is the sender
# No extra env needed — Email provider always available if Resend is configured

# ── LIVE CHAT (Chatwoot, optional) ────────────────────────────
# Replaced Tawk.to with Chatwoot
# NEXT_PUBLIC_TAWK_PROPERTY_ID=
# NEXT_PUBLIC_TAWK_WIDGET_ID=
NEXT_PUBLIC_CHATWOOT_TOKEN=
NEXT_PUBLIC_CHATWOOT_BASE_URL=https://chat.printhub.africa

# ── ANALYTICS (optional) ─────────────────────────────────────
NEXT_PUBLIC_GA_MEASUREMENT_ID=G-JSKJSRWRG1
NEXT_PUBLIC_PLAUSIBLE_DOMAIN=printhub.africa
NEXT_PUBLIC_PLAUSIBLE_URL=https://analytics.printhub.africa
# Hotjar, ContentSquare, or any script URL. Loaded only after user accepts analytics cookies.
# Example: https://t.contentsquare.net/uxa/b8f571ccfd395.js
NEXT_PUBLIC_ANALYTICS_SCRIPT_URL=

# ── ERROR TRACKING (GlitchTip, Sentry compatible) ───────────────────────
# SENTRY_ORG= (deprecated for glitchtip)
# SENTRY_PROJECT= (deprecated for glitchtip)
# SENTRY_AUTH_TOKEN= (deprecated for glitchtip)
NEXT_PUBLIC_SENTRY_DSN=https://<your_sentry_key>@errors.printhub.africa/1

# ── SEARCH (Meilisearch) ───────────────────────────────────────
# Replaced Algolia with Meilisearch
# NEXT_PUBLIC_ALGOLIA_APP_ID=
# NEXT_PUBLIC_ALGOLIA_SEARCH_KEY=
# ALGOLIA_ADMIN_KEY=
ALGOLIA_INDEX_NAME=products
MEILISEARCH_URL=https://meilisearch.railway.internal
MEILISEARCH_KEY=your_meilisearch_master_key
MEILI_MASTER_KEY=your_meilisearch_master_key

# ── INVOICES & TAX ──────────────────────────────────────────
# Optional: KRA PIN shown on tax invoices (Kenya). Leave empty to hide.
# KRA_PIN=

# ── UPLOAD SECURITY (optional) ───────────────────────────────
# VirusTotal API key for scanning private uploads after confirm. Max 32MB; leave empty to skip scan.
# VIRUSTOTAL_API_KEY=

# ── NOTIFICATIONS (optional overrides) ────────────────────────
# Contact form copies: CONTACT_EMAIL (see Email section). Careers: where to email new application notifications.
# CAREERS_NOTIFICATION_EMAIL=

# ── INTERNAL ─────────────────────────────────────────────────
ADMIN_EMAIL=admin@printhub.africa
CRON_SECRET=
# Set to true to enable unpaid order auto-cancel cron (GET /api/cron/cancel-unpaid-orders). Schedule every 15 min.
# CRON_CANCEL_UNPAID_ORDERS_ENABLED=true

# ============================================================
# PRODUCTION (printhub.africa) — override these when going live
# ============================================================
# NEXT_PUBLIC_APP_URL=https://printhub.africa
# NEXTAUTH_URL=https://printhub.africa
# FROM_EMAIL=hello@printhub.africa
# MPESA_CALLBACK_URL=https://printhub.africa/api/payments/mpesa/callback
# MPESA_ENV=production
# PESAPAL_IPN_URL=https://printhub.africa/api/payments/pesapal/ipn
# PESAPAL_ENV=live
# AT_USERNAME=<your AT username — NOT "sandbox">
# AT_ENV=live
# ── 3D MODEL IMPORT ──────────────────────────────────────────
# Thingiverse: Create an app at https://www.thingiverse.com/apps/create
THINGIVERSE_ACCESS_TOKEN=
# MyMiniFactory: Create an app at https://www.myminifactory.com/api/v2/apps
MMF_CLIENT_ID=
MYMINIFACTORY_API_KEY=

# ── MARKETING & ADVERTISING ──────────────────────────────────
# META (Facebook/Instagram)
NEXT_PUBLIC_META_PIXEL_ENABLED=false
NEXT_PUBLIC_META_PIXEL_ID=
META_CONVERSIONS_API_ENABLED=false
META_ACCESS_TOKEN=

# GOOGLE (ADS/GA4/GTM)
NEXT_PUBLIC_GTM_ENABLED=false
NEXT_PUBLIC_GTM_ID=
NEXT_PUBLIC_GA4_ID=G-JSKJSRWRG1
NEXT_PUBLIC_GOOGLE_ADS_ID=
NEXT_PUBLIC_GOOGLE_MERCHANT_ID=

# TIKTOK
NEXT_PUBLIC_TIKTOK_PIXEL_ENABLED=false
NEXT_PUBLIC_TIKTOK_PIXEL_ID=
TIKTOK_EVENTS_API_TOKEN=

# X (TWITTER)
NEXT_PUBLIC_X_PIXEL_ENABLED=false
NEXT_PUBLIC_X_PIXEL_ID=

# SNAPCHAT
NEXT_PUBLIC_SNAP_PIXEL_ENABLED=false
NEXT_PUBLIC_SNAP_PIXEL_ID=

# KLAVIYO (Behavioural)
KLAVIYO_ENABLED=false
KLAVIYO_API_KEY=
NEXT_PUBLIC_KLAVIYO_PUBLIC_KEY=

# LISTMONK (Campaigns/Newsletters)
LISTMONK_URL=https://listmonk.railway.internal
LISTMONK_ADMIN_USER=admin
LISTMONK_ADMIN_PASSWORD=
LISTMONK_DEFAULT_LIST_ID=1

# WHATSAPP BUSINESS Cloud API
WHATSAPP_ENABLED=false
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_ACCESS_TOKEN=

# TWILIO (Optional SMS/WhatsApp fallback)
TWILIO_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# ─── AI SERVICES ─────────────────────────────────────────────────────────────
# All keys are server-side only — never expose to browser (no NEXT_PUBLIC_ prefix)

# Anthropic (Claude Opus 4.6)
# ANTHROPIC_API_KEY=

# OpenAI (GPT-4o, GPT-4o Mini, Whisper, DALL-E 3)
# OPENAI_API_KEY=

# Stability AI (image variations + background removal)
# STABILITY_API_KEY=

# ElevenLabs (voiceover generation)
# ELEVENLABS_API_KEY=
# ELEVENLABS_VOICE_ID=

# Runway ML (image-to-video)
# RUNWAY_API_KEY=

# Google Gemini 1.5 Pro (large context analysis)
# GEMINI_API_KEY=

# Perplexity (real-time trend research)
# PERPLEXITY_API_KEY=

# Google Indexing API (Google Discover pings)
# GOOGLE_INDEXING_KEY=

# ─── NEW PLATFORM CREDENTIALS ────────────────────────────────────────────────

# Telegram (AI-10 bot + channel product posts)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHANNEL_ID=

# WhatsApp Channel (product post broadcasts)
WHATSAPP_CHANNEL_ID=

# Instagram (Stories + Reels via Facebook Graph API v19.0)
INSTAGRAM_USER_ID=
META_ACCESS_TOKEN=

# YouTube Shorts (YouTube Data API v3)
YOUTUBE_CHANNEL_ID=
YOUTUBE_CLIENT_ID=
YOUTUBE_CLIENT_SECRET=
YOUTUBE_REFRESH_TOKEN=

# Jiji.co.ke (unofficial — may break; controlled via AI Control Centre)
JIJI_EMAIL=
JIJI_PASSWORD=

# ─── FFMPEG SERVICE (separate Railway deployment) ─────────────────────────────
FFMPEG_SERVICE_URL=
COMBINE_SECRET=

# ─── AI ADMIN ALERTS ─────────────────────────────────────────────────────────
ADMIN_EMAIL=
SUPER_ADMIN_EMAIL=admin@printhub.africa
SUPER_ADMIN_PASSWORD=
