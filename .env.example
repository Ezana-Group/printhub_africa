# ============================================================
# PrintHub — Environment variables template
# ============================================================
# Copy to .env.local and fill in values. Never commit .env.local.
# For testing stack: Neon, R2, Resend, Africa's Talking, M-Pesa Daraja.
# ============================================================

# ── APP ─────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=
NEXT_PUBLIC_APP_NAME=PrintHub

# ── NEXTAUTH ─────────────────────────────────────────────────
NEXTAUTH_URL=
NEXTAUTH_SECRET=

# ── DATABASE (Neon: pooled + direct for migrations) ──────────
# Neon: use pooled URL for DATABASE_URL, direct URL for DIRECT_URL.
# Local Postgres: set both to the same connection string.
DATABASE_URL=
DIRECT_URL= 

# ── FILE STORAGE (Cloudflare R2) ──────────────────────────────
R2_ENDPOINT=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_UPLOADS_BUCKET=printhub-uploads
R2_PUBLIC_BUCKET=printhub-public
R2_PUBLIC_URL=https://printhub-uploads.r2.dev

# ── EMAIL (Resend) ───────────────────────────────────────────
RESEND_API_KEY=
FROM_EMAIL=hello@printhub.africa
FROM_NAME=PrintHub

# ── SMS (Africa's Talking — Sandbox) ─────────────────────────
AT_API_KEY=
AT_USERNAME=sandbox
AT_SENDER_ID=PrintHub
AT_ENV=sandbox

# ── PAYMENTS: M-Pesa (Daraja Sandbox) ───────────────────────
MPESA_CONSUMER_KEY=
MPESA_CONSUMER_SECRET=
MPESA_SHORTCODE=174379
MPESA_PASSKEY=
MPESA_CALLBACK_URL=
MPESA_ENV=sandbox

# ── PAYMENTS: PESAPAL (Sandbox) ─────────────────────────────
PESAPAL_CONSUMER_KEY=
PESAPAL_CONSUMER_SECRET=
PESAPAL_IPN_URL=
PESAPAL_ENV=sandbox

# ── PAYMENTS: FLUTTERWAVE (Test) ─────────────────────────────
FLUTTERWAVE_PUBLIC_KEY=
FLUTTERWAVE_SECRET_KEY=
FLUTTERWAVE_WEBHOOK_SECRET=
FLUTTERWAVE_ENV=test

# ── PAYMENTS: STRIPE (Test) ──────────────────────────────────
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# ── GOOGLE OAUTH ─────────────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ── ANALYTICS (optional) ─────────────────────────────────────
NEXT_PUBLIC_GA_MEASUREMENT_ID=

# ── ERROR TRACKING (optional) ───────────────────────────────
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=

# ── SEARCH (optional) ───────────────────────────────────────
NEXT_PUBLIC_ALGOLIA_APP_ID=
NEXT_PUBLIC_ALGOLIA_SEARCH_KEY=
ALGOLIA_ADMIN_KEY=

# ── INTERNAL ─────────────────────────────────────────────────
ADMIN_EMAIL=admin@printhub.africa
CRON_SECRET=
