# ============================================================
# PrintHub — Environment variables
# ============================================================
# For local development: copy this file to .env.local and fill in values.
#   cp .env.local.example .env.local
#
# For Railway production: set all these in the Railway service
#   Variables tab — NOT in a committed file.
#
# For Railway staging: create a "staging" Railway environment
#   and set staging values there (separate DB, different URLs).
#
# NEVER commit .env.local or any file containing real secrets.
# ============================================================

# ── APP ─────────────────────────────────────────────────────
# Local: http://localhost:3000 | Production: https://printhub.africa
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=PrintHub

# ── NEXTAUTH ─────────────────────────────────────────────────
# Must match NEXT_PUBLIC_APP_URL exactly for NextAuth cookie domain to work.
NEXTAUTH_URL=http://localhost:3000
# Generate: openssl rand -base64 32
NEXTAUTH_SECRET=

# ── DATABASE (Neon) ─────────────────────────────────────────
# Railway Postgres: use the Railway "Private" connection URL for DATABASE_URL
# (faster internal networking). Use the public URL only if Railway Postgres is external.
# For Neon: Dashboard → Connection string → Pooled (DATABASE_URL), Direct (DATABASE_URL_UNPOOLED).
DATABASE_URL=
DATABASE_URL_UNPOOLED=

# ── FILE STORAGE (Cloudflare R2) ───────────────────────────
# R2: Cloudflare Dashboard → R2 → Manage R2 API Tokens.
# Create token with Object Read & Write; note Access Key ID + Secret.
# Endpoint: https://<ACCOUNT_ID>.r2.cloudflarestorage.com
R2_ENDPOINT=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_UPLOADS_BUCKET=printhub-uploads
R2_PUBLIC_BUCKET=printhub-public
# Public bucket custom domain or R2 dev subdomain, e.g. https://pub-xxx.r2.dev
R2_PUBLIC_URL=

# Optional: VirusTotal for scanning uploads (set key to enable)
VIRUSTOTAL_API_KEY=

# Optional: AWS S3 fallback (lib/s3.ts uses R2_* first, then AWS_*)
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_REGION=us-east-1
# AWS_S3_BUCKET_NAME=
# NEXT_PUBLIC_S3_URL=

# ── EMAIL (Resend) ──────────────────────────────────────────
RESEND_API_KEY=
FROM_EMAIL=hello@printhub.africa
FROM_NAME=PrintHub

# ── INTERNAL EMAIL SYSTEM (Cloudflare → Resend Inbound) ─────
# Cloudflare Email Routing token: must allow "Email Routing Rules: Edit".
CLOUDFLARE_API_TOKEN=
# Cloudflare zone id (from Cloudflare dashboard).
CLOUDFLARE_ZONE_ID=
# Resend webhook signing secret (from the webhook details page).
RESEND_WEBHOOK_SECRET=
# Resend-provided inbound address that Cloudflare forwards mail to.
# (Provided by Resend when you configure inbound email + webhooks.)
RESEND_INBOUND_ADDRESS=

# ── SMS (Africa's Talking) ──────────────────────────────────
AT_API_KEY=
AT_USERNAME=sandbox
AT_SENDER_ID=PrintHub
AT_ENV=sandbox

# ── PAYMENTS: M-Pesa (Safaricom Daraja) ──────────────────────
# Sandbox: https://developer.safaricom.co.ke — create app, get keys.
# Production: go-live process; set MPESA_CALLBACK_IP_WHITELIST.
MPESA_CONSUMER_KEY=
MPESA_CONSUMER_SECRET=
MPESA_SHORTCODE=
MPESA_PASSKEY=
# Full URL to your callback, e.g. https://printhub.africa/api/payments/mpesa/callback
MPESA_CALLBACK_URL=
MPESA_ENV=sandbox
# Production: comma-separated Safaricom IPs (from go-live docs)
MPESA_CALLBACK_IP_WHITELIST=

# ── PAYMENTS: Pesapal ───────────────────────────────────────
PESAPAL_CONSUMER_KEY=
PESAPAL_CONSUMER_SECRET=
PESAPAL_IPN_URL=
PESAPAL_ENV=sandbox

# ── PAYMENTS: Flutterwave ────────────────────────────────────
FLUTTERWAVE_PUBLIC_KEY=
FLUTTERWAVE_SECRET_KEY=
FLUTTERWAVE_WEBHOOK_SECRET=
FLUTTERWAVE_ENV=test

# ── PAYMENTS: Stripe ────────────────────────────────────────
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# ── OAUTH: Google ────────────────────────────────────────────
# Google Cloud Console → APIs & Services → Credentials → OAuth 2.0.
# Authorized redirect URI: {NEXTAUTH_URL}/api/auth/callback/google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
NEXT_PUBLIC_GOOGLE_CLIENT_ID=

# ── OAUTH: Facebook ──────────────────────────────────────────
# Meta for Developers → App → Facebook Login → Settings.
# Valid OAuth Redirect URI: {NEXTAUTH_URL}/api/auth/callback/facebook
FACEBOOK_CLIENT_ID=
FACEBOOK_CLIENT_SECRET=
NEXT_PUBLIC_FACEBOOK_APP_ID=

# ── OAUTH: Apple (optional) ──────────────────────────────────
# Apple Developer → Sign in with Apple → generate client secret (JWT, ~6 months).
APPLE_CLIENT_ID=
APPLE_CLIENT_SECRET=
NEXT_PUBLIC_APPLE_CLIENT_ID=

# ── ANALYTICS & MONITORING ───────────────────────────────────
NEXT_PUBLIC_GA_MEASUREMENT_ID=
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=
NEXT_PUBLIC_HOTJAR_ID=
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_ORG=
SENTRY_PROJECT=

# ── SEARCH (Algolia, optional) ───────────────────────────────
NEXT_PUBLIC_ALGOLIA_APP_ID=
NEXT_PUBLIC_ALGOLIA_SEARCH_KEY=
ALGOLIA_ADMIN_KEY=

# ── CONTENT (Sanity, optional) ──────────────────────────────
NEXT_PUBLIC_SANITY_PROJECT_ID=
NEXT_PUBLIC_SANITY_DATASET=production
SANITY_API_TOKEN=

# ── ERPNext (optional; npm run erpnext:setup) ─────────────────
ERPNEXT_URL=
ERPNEXT_API_KEY=
ERPNEXT_API_SECRET=

# ── INTERNAL ─────────────────────────────────────────────────
CONTACT_EMAIL=
ADMIN_EMAIL=admin@printhub.africa
# ── MARKETING & TRACKING ─────────────────────────────────────
# META (Facebook/Instagram)
NEXT_PUBLIC_META_PIXEL_ID=
META_ACCESS_TOKEN=
META_CONVERSIONS_API_ENABLED=false

# GOOGLE (Ads, GTM, Merchant)
NEXT_PUBLIC_GTM_ID=
NEXT_PUBLIC_GA4_ID=
NEXT_PUBLIC_GOOGLE_ADS_ID=
NEXT_PUBLIC_GOOGLE_MERCHANT_ID=

# TIKTOK
NEXT_PUBLIC_TIKTOK_PIXEL_ID=
TIKTOK_EVENTS_API_TOKEN=

# PINTEREST
NEXT_PUBLIC_PINTEREST_TAG_ID=
NEXT_PUBLIC_PINTEREST_TAG_ENABLED=false

# SNAPCHAT
NEXT_PUBLIC_SNAP_PIXEL_ID=
SNAP_CONVERSIONS_API_TOKEN=

# KLAVIYO (Email/SMS)
KLAVIYO_API_KEY=
NEXT_PUBLIC_KLAVIYO_PUBLIC_KEY=
KLAVIYO_ENABLED=false

# WHATSAPP BUSINESS
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_ENABLED=false

# ─────────────────────────────────────────────────────────────
# Railway auto-provides these — DO NOT set them manually:
#   RAILWAY_PUBLIC_DOMAIN   — the *.up.railway.app domain of this service
#   RAILWAY_ENVIRONMENT     — "production" or "staging"
#   RAILWAY_SERVICE_NAME    — service name from railway.toml
#   PORT                    — set to 3000 by the Dockerfile
# ─────────────────────────────────────────────────────────────

# ── CRON SECURITY ────────────────────────────────────────────
# Shared secret used by n8n to call /api/cron/* endpoints.
# n8n sends this as: Authorization: Bearer <CRON_SECRET>
# Generate: openssl rand -hex 32
CRON_SECRET=

# --- ADMIN SEPARATION ---
# Local: http://admin.localhost:3000 | Prod: https://admin.printhub.africa
NEXT_PUBLIC_ADMIN_URL=http://admin.localhost:3000
# Local: http://localhost:3000 | Prod: https://printhub.africa
NEXT_PUBLIC_APP_URL=http://localhost:3000
# Used for internal service-to-service validation
INTERNAL_SERVICE_SECRET=generate-a-64-char-random-string-here

# ── RATE LIMITING ──────────────────────────────────────────
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# n8n Automation Engine
# ------------------------------------------------------------
# Base URL of your self-hosted n8n instance (e.g., https://n8n.printhub.africa)
NEXT_PUBLIC_N8N_URL=https://n8n.printhub.africa
N8N_HOST=n8n.printhub.africa
N8N_PORT=5678
N8N_PROTOCOL=https

# Internal webhook path for triggers (without /webhook prefix if calling n8n directly)
# Next.js calls n8n at: {N8N_WEBHOOK_BASE_URL}/{path}
N8N_WEBHOOK_BASE_URL=https://n8n.printhub.africa/webhook

# Shared secret for HMAC-SHA256 signature verification (MUST match in Railway/n8n)
# Used for: Next.js -> n8n (X-Printhub-Signature)
# Also used for: n8n -> Next.js (callback verification)
N8N_WEBHOOK_SECRET=    # openssl rand -hex 32

# Encryption key for n8n credentials storage (NEVER change after deployment)
N8N_ENCRYPTION_KEY=    # openssl rand -hex 32

# Admin n8n Credentials (for n8n internal auth)
N8N_BASIC_AUTH_ACTIVE=true
N8N_BASIC_AUTH_USER=admin
N8N_BASIC_AUTH_PASSWORD=

# Database for n8n (Separate from PrintHub DB)
N8N_DB_TYPE=postgresdb
N8N_DB_POSTGRESDB_HOST=
N8N_DB_POSTGRESDB_PORT=5432
N8N_DB_POSTGRESDB_DATABASE=n8n
N8N_DB_POSTGRESDB_USER=
N8N_DB_POSTGRESDB_PASSWORD=

# External Services (shared with n8n via Railway panel)
# ------------------------------------------------------------
PRINTHUB_INTERNAL_SECRET=    # same as INTERNAL_SERVICE_SECRET
PRINTHUB_API_URL=https://printhub.africa

# WhatsApp Business API
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_TEMPLATE_NAMESPACE=

# Resend API Key
RESEND_API_KEY=
FROM_EMAIL=
FROM_NAME=PrintHub Africa

# SMS (Africa's Talking)
AT_API_KEY=
AT_USERNAME=
AT_SENDER_ID=

# Meta/Facebook
META_ACCESS_TOKEN=
META_PIXEL_ID=
META_AD_ACCOUNT_ID=
META_CATALOG_ID=

# TikTok
TIKTOK_EVENTS_API_TOKEN=
TIKTOK_AD_ACCOUNT_ID=
TIKTOK_CATALOG_ID=

# Google
GOOGLE_ADS_DEVELOPER_TOKEN=
GOOGLE_ADS_CUSTOMER_ID=
GOOGLE_ADS_CLIENT_ID=
GOOGLE_ADS_CLIENT_SECRET=
GOOGLE_ADS_REFRESH_TOKEN=
GOOGLE_MERCHANT_ID=

# LinkedIn
LINKEDIN_ACCESS_TOKEN=
LINKEDIN_ORGANIZATION_ID=

# Slack
SLACK_WEBHOOK_URL=

# Social Media Export Flags (Control which feeds are active)
# ------------------------------------------------------------
EXPORT_GOOGLE_MERCHANT=true
EXPORT_META_CATALOG=true
EXPORT_TIKTOK_SHOP=true
EXPORT_LINKEDIN_ADS=true
EXPORT_PINTEREST_SHOP=true
EXPORT_X_ADS=true
EXPORT_GOOGLE_BUSINESS=true
EXPORT_SNAPCHAT_ADS=true
EXPORT_YOUTUBE_SHOP=true

# --- Kenya Classifieds & AI Platform Posting ---
PIGIAME_EMAIL=
PIGIAME_PASSWORD=
OLX_EMAIL=
OLX_PASSWORD=

# Google Additional
GOOGLE_MAPS_PLACE_ID=
BING_MAPS_KEY=
APPLE_MAPS_ACCESS_TOKEN=

# Social Medium/Reddit/LinkedIn
MEDIUM_INTEGRATION_TOKEN=
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USERNAME=
REDDIT_PASSWORD=
LINKEDIN_ORGANIZATION_ID=
LINKEDIN_NEWSLETTER_ID=
NEXTDOOR_API_KEY=

# ── AI MODELS (For n8n enhancement flows) ────────────────────
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
