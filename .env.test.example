# ===========================================
# PrintHub TEST Environment
# Copy to .env.test and use ONLY for tests.
# NEVER run tests against production database.
# ===========================================
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=test-secret-change-in-ci

# Test database (separate from dev/prod)
DATABASE_URL="postgresql://user:password@localhost:5432/printhub_test?schema=public"
