            "index": 0
          }
        ]
      ]
    },
    "Perplexity: SEO Research": {
      "main": [
        [
          {
            "node": "Claude: Write Article",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "Claude: Write Article": {
      "main": [
        [
          {
            "node": "Save Blog Draft",
            "type": "main",
            "index": 0
          }
        ]
      ]
    }
