{
  "name": "AI-1 — Auto-Generate Social Media Posts (GPT-4o)",
  "nodes": [
    {
      "parameters": {
        "httpMethod": "POST",
        "path": "generate-social-posts",
        "options": {
          "rawBody": true
        }
      },
      "name": "Webhook: Product Published",
      "type": "n8n-nodes-base.webhook",
      "typeVersion": 1,
      "position": [
        200,
        300
      ],
      "webhookId": "generate-social-posts"
    },
    {
      "parameters": {
        "jsCode": "const crypto = require('crypto');\nconst sig = $node['Webhook: Product Published'].json.headers['x-printhub-signature'];\nconst hmac = crypto.createHmac('sha256', process.env.N8N_WEBHOOK_SECRET).update(JSON.stringify($node['Webhook: Product Published'].json.body)).digest('hex');\nif (sig !== hmac) throw new Error('Invalid signature');\nreturn $node['Webhook: Product Published'].json.body;"
      },
      "name": "Verify Signature",
      "type": "n8n-nodes-base.code",
      "typeVersion": 1,
      "position": [
        420,
        300
      ]
    },
    {
      "parameters": {
        "url": "https://admin.printhub.africa/api/n8n/get-product-context",
        "method": "GET",
        "authentication": "none",
        "headerParameters": {
          "parameters": [
            {
              "name": "x-printhub-signature",
              "value": "={{ $env.N8N_WEBHOOK_SECRET }}"
            }
          ]
        },
        "qs": [
          {
            "name": "productId",
            "value": "={{ $json.productId }}"
          }
        ]
      },
      "name": "Get Product Context",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.1,
      "position": [
        640,
        300
      ]
    },
    {
      "parameters": {
        "url": "https://api.openai.com/v1/chat/completions",
        "method": "POST",
        "authentication": "none",
        "headerParameters": {
          "parameters": [
            {
              "name": "Authorization",
              "value": "=Bearer {{$env.OPENAI_API_KEY}}"
            }
          ]
        },
        "bodyParametersJson": "={ \"model\": \"claude-opus-4-6\", \"messages\": [{ \"role\": \"system\", \"content\": \"You are a professional social media strategist for PrintHub Africa, Nairobi. Tone: punchy, high-energy. British English. \\n\\nPLATFORM ROUTING (via exportFlags):\\n- exportMeta -> FB + IG\\n- exportTiktok -> TikTok\\n- exportLinkedin -> LinkedIn\\n- exportX -> Twitter\\n- exportTelegram -> Telegram\\n- exportYoutube (if video_url present) -> YT Community\\n\\nIMAGE FORMAT: {{$env.R2_PUBLIC_URL}}/products/images/{image_key}. \\n\\nOUTPUT: JSON with fields (instagram, facebook, tiktok, linkedin, twitter, telegram, youtube, video). Default to IG/FB/Twitter if flags null.\" }, { \"role\": \"user\", \"content\": \"Generate posts for product: {{ $json.name }}. Description: {{ $json.description }}. exportFlags: {{ JSON.stringify($json.exportFlags) }}. primary_image_key: {{ $json.image_key }}. video_url: {{ $json.video_url || 'null' }}.\" }] }"
      },
      "name": "Claude: Generate Social Posts",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.1,
      "position": [
        860,
        300
      ]
    },
    {
      "parameters": {
        "url": "https://admin.printhub.africa/api/n8n/save-ai-content",
        "method": "POST",
        "authentication": "none",
        "headerParameters": {
          "parameters": [
            {
              "name": "x-printhub-signature",
              "value": "={{ $env.N8N_WEBHOOK_SECRET }}"
            }
          ]
        },
        "bodyParametersJson": "={ \"productId\": \"{{ $node['Get Product Context'].json.id }}\", \"socialPosts\": {{ $json.choices[0].message.content }} }"
      },
      "name": "Save Social Posts",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.1,
      "position": [
        1080,
        300
      ]
    }
  ],
  "connections": {
    "Webhook: Product Published": {
