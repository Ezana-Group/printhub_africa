{
  "name": "3. Cron - Daily Social Feed Sync (6:00 AM EAT)",
  "nodes": [
    {
      "parameters": {
        "rule": {
          "interval": [
            {
              "field": "cronExpression",
              "expression": "0 3 * * *"
            }
          ]
        }
      },
      "id": "schedule-trigger-6am",
      "name": "Schedule: 6AM",
      "type": "n8n-nodes-base.scheduleTrigger",
      "typeVersion": 1,
      "position": [
        100,
        300
      ]
    },
    {
      "parameters": {
        "method": "GET",
        "url": "={{$vars.ADMIN_URL}}/api/n8n/sync-catalog",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "x-printhub-signature",
              "value": "={{$vars.N8N_WEBHOOK_SECRET}}"
            }
          ]
        },
        "options": {}
      },
      "id": "http-trigger-sync",
      "name": "HTTP: Trigger Sync",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.1,
      "position": [
        320,
        300
      ]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "={{$vars.ADMIN_URL}}/api/n8n/log",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "x-printhub-signature",
              "value": "={{$vars.N8N_WEBHOOK_SECRET}}"
            }
          ]
        },
        "sendBody": true,
        "bodyParameters": {
          "parameters": [
            {
              "name": "action",
              "value": "CATALOG_SYNC_CRON"
            },
            {
              "name": "details",
              "value": "Daily automated sync performed"
            }
          ]
        },
        "options": {}
      },
      "id": "audit-log-catalog-sync",
      "name": "AuditLog: Catalog Sync",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.1,
      "position": [
        540,
        300
      ]
    }
  ],
  "connections": {
    "Schedule: 6AM": {
      "main": [
        [
          {
            "node": "HTTP: Trigger Sync",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "HTTP: Trigger Sync": {
      "main": [
        [
          {
            "node": "AuditLog: Catalog Sync",
            "type": "main",
            "index": 0
          }
        ]
      ]
    }
  },
  "meta": {
    "instanceId": "printhub-n8n-production"
  },
  "settings": {
    "errorWorkflow": "{{GLOBAL_ERROR_HANDLER_ID}}"
  }
}