          "sendBody": true,
          "bodyParameters": {
            "parameters": [
              { "name": "action", "value": "WEEKLY_SMS_BROADCAST" },
              { "name": "details", "value": "Broadcast sent to marketing list" }
            ]
          }
        }
      }
