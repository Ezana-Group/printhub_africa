{
  "name": "2. Cron - Daily Low Stock Check (8:00 AM EAT)",
  "nodes": [
    {
      "parameters": {
        "rule": {
          "interval": [
            {
              "field": "days"
            }
          ],
          "time": "08:00"
        }
      },
      "name": "Schedule: 8AM",
      "type": "n8n-nodes-base.scheduleTrigger",
      "typeVersion": 1,
      "position": [
        100,
        300
      ]
    },
    {
      "parameters": {
        "url": "https://admin.printhub.africa/api/n8n/stock-levels",
        "method": "GET",
        "authentication": "headerAuth",
        "headerParameters": {
          "parameters": [
            {
              "name": "x-n8n-secret",
              "value": "={{$env.N8N_WEBHOOK_SECRET}}"
            }
          ]
        }
      },
      "name": "Pull Inventory Audit",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.1,
      "position": [
        320,
        300
      ]
    }
  ],
  "connections": {
    "Schedule: 8AM": {
      "main": [
        [
          {
            "node": "Pull Inventory Audit",
            "type": "main",
            "index": 0
          }
        ]
      ]
    }
  }
}