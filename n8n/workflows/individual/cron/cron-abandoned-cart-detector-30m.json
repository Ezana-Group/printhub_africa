{
  "name": "1. Cron - Abandoned Cart Detector (30m)",
  "nodes": [
    {
      "parameters": {
        "rule": {
          "interval": [
            {
              "field": "minutes",
              "value": 30
            }
          ]
        }
      },
      "name": "Schedule: 30m",
      "type": "n8n-nodes-base.scheduleTrigger",
      "typeVersion": 1,
      "position": [
        100,
        300
      ]
    },
    {
      "parameters": {
        "url": "https://admin.printhub.africa/api/n8n/get-abandoned-carts",
        "method": "GET",
        "authentication": "headerAuth",
        "headerParameters": {
          "parameters": [
            {
              "name": "x-n8n-secret",
              "value": "={{$env.N8N_WEBHOOK_SECRET}}"
            }
          ]
        }
      },
      "name": "Fetch High Intent Carts",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.1,
      "position": [
        320,
        300
      ]
    },
    {
      "parameters": {
        "fieldToSplit": "carts",
        "options": {}
      },
      "name": "Split Batches",
      "type": "n8n-nodes-base.splitInBatches",
      "typeVersion": 1,
      "position": [
        540,
        300
      ]
    }
  ],
  "connections": {
    "Schedule: 30m": {
      "main": [
        [
          {
            "node": "Fetch High Intent Carts",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "Fetch High Intent Carts": {
      "main": [
        [
          {
            "node": "Split Batches",
            "type": "main",
            "index": 0
          }
        ]
      ]
    }
  }
}