[
  {
    "name": "Cron - Abandoned Cart Detector (Hourly)",
    "nodes": [
      {
        "parameters": { "rule": { "interval": [{ "field": "hours" }] } },
        "name": "Schedule",
        "type": "n8n-nodes-base.scheduleTrigger",
        "typeVersion": 1,
        "position": [400, 300]
      },
      {
        "parameters": { "url": "https://admin.printhub.africa/api/n8n/get-abandoned-carts", "method": "GET", "authentication": "headerAuth", "headerParameters": { "parameters": [{ "name": "x-n8n-secret", "value": "={{$env.N8N_WEBHOOK_SECRET}}" }] } },
        "name": "Fetch High Intent Carts",
        "type": "n8n-nodes-base.httpRequest",
        "typeVersion": 4.1,
        "position": [620, 300]
      },
      {
        "parameters": { "fieldToSplit": "carts", "options": {} },
        "name": "Split into Batches",
        "type": "n8n-nodes-base.splitInBatches",
        "typeVersion": 1,
        "position": [840, 300]
      }
    ],
    "connections": { "Schedule": { "main": [[{ "node": "Fetch High Intent Carts", "type": "main", "index": 0 }]] }, "Fetch High Intent Carts": { "main": [[{ "node": "Split into Batches", "type": "main", "index": 0 }]] } }
  },
