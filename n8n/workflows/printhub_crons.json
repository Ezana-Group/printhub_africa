[
  {
    "name": "1. Cron - Abandoned Cart Detector (30m)",
    "nodes": [
      {
        "parameters": { "rule": { "interval": [{ "field": "minutes", "value": 30 }] } },
        "name": "Schedule: 30m",
        "type": "n8n-nodes-base.scheduleTrigger",
        "typeVersion": 1,
        "position": [100, 300]
      },
      {
        "parameters": { "url": "https://admin.printhub.africa/api/n8n/get-abandoned-carts", "method": "GET", "authentication": "headerAuth", "headerParameters": { "parameters": [{ "name": "x-n8n-secret", "value": "={{$env.N8N_WEBHOOK_SECRET}}" }] } },
        "name": "Fetch High Intent Carts",
        "type": "n8n-nodes-base.httpRequest",
        "typeVersion": 4.1,
        "position": [320, 300]
      },
      {
        "parameters": { "fieldToSplit": "carts", "options": {} },
        "name": "Split Batches",
        "type": "n8n-nodes-base.splitInBatches",
        "typeVersion": 1,
        "position": [540, 300]
      }
    ],
    "connections": { "Schedule: 30m": { "main": [[{ "node": "Fetch High Intent Carts", "type": "main", "index": 0 }]] }, "Fetch High Intent Carts": { "main": [[{ "node": "Split Batches", "type": "main", "index": 0 }]] } }
  },
  {
    "name": "2. Cron - Daily Low Stock Check (8:00 AM EAT)",
    "nodes": [
      {
        "parameters": { "rule": { "interval": [{ "field": "days" }], "time": "08:00" } },
        "name": "Schedule: 8AM",
        "type": "n8n-nodes-base.scheduleTrigger",
        "typeVersion": 1,
        "position": [100, 300]
      },
      {
        "parameters": { "url": "https://admin.printhub.africa/api/n8n/stock-levels", "method": "GET", "authentication": "headerAuth", "headerParameters": { "parameters": [{ "name": "x-n8n-secret", "value": "={{$env.N8N_WEBHOOK_SECRET}}" }] } },
        "name": "Pull Inventory Audit",
        "type": "n8n-nodes-base.httpRequest",
        "typeVersion": 4.1,
        "position": [320, 300]
      }
    ],
    "connections": { "Schedule: 8AM": { "main": [[{ "node": "Pull Inventory Audit", "type": "main", "index": 0 }]] } }
  },
  {
    "name": "3. Cron - Daily Social Feed Sync (6:00 AM EAT)",
    "nodes": [
      {
        "parameters": { "rule": { "interval": [{ "field": "days" }], "time": "06:00" } },
        "name": "Schedule: 6AM",
        "type": "n8n-nodes-base.scheduleTrigger",
        "typeVersion": 1,
        "position": [100, 300]
      }
    ],
    "connections": {}
  },
  {
    "name": "4. Cron - Admin Session Cleanup (Hourly)",
    "nodes": [
      {
        "parameters": { "rule": { "interval": [{ "field": "hours" }] } },
        "name": "Schedule: Hourly",
        "type": "n8n-nodes-base.scheduleTrigger",
        "typeVersion": 1,
        "position": [100, 300]
      },
      {
        "parameters": { "url": "https://admin.printhub.africa/api/n8n/cleanup-sessions", "method": "POST", "authentication": "headerAuth", "headerParameters": { "parameters": [{ "name": "x-n8n-secret", "value": "={{$env.N8N_WEBHOOK_SECRET}}" }] } },
        "name": "Purge Expired Sessions",
        "type": "n8n-nodes-base.httpRequest",
        "typeVersion": 4.1,
        "position": [320, 300]
      }
    ],
    "connections": { "Schedule: Hourly": { "main": [[{ "node": "Purge Expired Sessions", "type": "main", "index": 0 }]] } }
  }
]
