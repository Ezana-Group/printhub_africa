{
  "name": "5. PrintHub - Security Alert (Impossible Travel + Auth)",
  "nodes": [
    {
      "parameters": {
        "httpMethod": "POST",
        "path": "security-alert-auth-only",
        "options": {
          "rawBody": true
        }
      },
      "name": "Webhook: Security",
      "type": "n8n-nodes-base.webhook",
      "typeVersion": 1,
      "position": [
        0,
        300
      ],
      "webhookId": "security-alert-auth-only"
    },
    {
      "parameters": {
        "url": "https://api.resend.com/emails",
        "method": "POST",
        "authentication": "none",
        "headerParameters": {
          "parameters": [
            {
              "name": "Authorization",
              "value": "=Bearer {{$env.RESEND_API_KEY}}"
            }
          ]
        },
        "bodyParametersJson": "={ \"from\": \"Security <security@printhub.africa>\", \"to\": \"{{ $env.ADMIN_EMAIL }}\", \"subject\": \"🔐 Security Alert: {{ $json.type }}\", \"html\": \"<p>A security event was detected: <strong>{{ $json.message }}</strong></p>\" }"
      },
      "name": "Email: Admin Alert",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.1,
      "position": [
        200,
        300
      ]
    }
  ],
  "connections": {
    "Webhook: Security": {
      "main": [
        [
          {
            "node": "Email: Admin Alert",
            "type": "main",
            "index": 0
          }
        ]
      ]
    }
  }
}