{
  "name": "Cron - Admin Session Cleanup (Hourly)",
  "nodes": [
    {
      "parameters": {
        "rule": {
          "interval": [
            {
              "field": "hours"
            }
          ]
        }
      },
      "id": "schedule-trigger-hourly",
      "name": "Schedule: Hourly",
      "type": "n8n-nodes-base.scheduleTrigger",
      "typeVersion": 1,
      "position": [
        100,
        300
      ]
    },
    {
      "parameters": {
        "method": "DELETE",
        "url": "={{$env[\"ADMIN_URL\"]}}/api/n8n/cleanup-sessions",
        "headerParameters": {
          "parameters": [
            {
              "name": "x-printhub-signature",
              "value": "={{$env[\"N8N_WEBHOOK_SECRET\"]}}"
            }
          ]
        },
        "options": {}
      },
      "id": "http-cleanup-sessions",
      "name": "HTTP: Cleanup Sessions",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.1,
      "position": [
        320,
        300
      ]
    }
  ],
  "connections": {
    "Schedule: Hourly": {
      "main": [
        [
          {
            "node": "HTTP: Cleanup Sessions",
            "type": "main",
            "index": 0
          }
        ]
      ]
    }
  },
  "meta": {
    "instanceId": "printhub-n8n-production"
  },
  "settings": {
    "errorWorkflow": "{{GLOBAL_ERROR_HANDLER_ID}}"
  }
}