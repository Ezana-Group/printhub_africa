{
  "name": "2. Cron - Daily Low Stock Check (8:00 AM EAT)",
  "nodes": [
    {
      "parameters": {
        "rule": {
          "interval": [
            {
              "field": "days"
            }
          ],
          "time": "08:00"
        }
      },
      "name": "Schedule Trigger",
      "type": "n8n-nodes-base.scheduleTrigger",
      "typeVersion": 1,
      "position": [
        100,
        300
      ]
    },
    {
      "parameters": {
        "method": "GET",
        "url": "https://admin.printhub.africa/api/n8n/stock-levels",
        "authentication": "none",
        "headerParametersUi": [
          {
            "name": "x-printhub-signature",
            "value": "={{$env.N8N_WEBHOOK_SECRET}}"
          }
        ]
      },
      "name": "Pull Inventory Audit",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 1,
      "position": [
        320,
        300
      ]
    },
    {
      "parameters": {
        "conditions": {
          "number": [
            {
              "value1": "={{$json.stock}}",
              "operation": "smaller",
              "value2": 5
            }
          ]
        }
      },
      "name": "Filter: Stock < 5",
      "type": "n8n-nodes-base.if",
      "typeVersion": 1,
      "position": [
        540,
        300
      ]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "=https://graph.facebook.com/v19.0/{{$env.WHATSAPP_PHONE_NUMBER_ID}}/messages",
        "authentication": "none",
        "headerParametersUi": [
          {
            "name": "Authorization",
            "value": "=Bearer {{$env.WHATSAPP_ACCESS_TOKEN}}"
          }
        ],
        "jsonParameters": true,
        "bodyParametersJson": "={ \"messaging_product\": \"whatsapp\", \"to\": \"{{$env.STAFF_WHATSAPP_NUMBER}}\", \"type\": \"text\", \"text\": { \"body\": \"⚠️ LOW STOCK ALERT: \" + $json.name + \" (SKU: \" + $json.sku + \") has only \" + $json.stock + \" units left. Reorder soon!\" } }"
      },
      "name": "WhatsApp: Notify Staff",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 1,
      "position": [
        760,
        200
      ]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "https://printhub.africa/api/n8n/log",
        "authentication": "none",
        "headerParametersUi": [
          {
            "name": "x-printhub-signature",
            "value": "={{$env.N8N_WEBHOOK_SECRET}}"
          }
        ],
        "jsonParameters": true,
        "bodyParametersJson": "={ \"action\": \"LOW_STOCK_ALERT\", \"details\": {{JSON.stringify($json)}} }"
      },
      "name": "AuditLog: Low Stock Flagged",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 1,
      "position": [
        760,
        400
      ]
    }
  ],
  "connections": {
    "Schedule Trigger": {
      "main": [
        [
          {
            "node": "Pull Inventory Audit",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "Pull Inventory Audit": {
      "main": [
        [
          {
            "node": "Filter: Stock < 5",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "Filter: Stock < 5": {
      "main": [
        [
          {
            "node": "WhatsApp: Notify Staff",
            "type": "main",
            "index": 0
          },
          {
            "node": "AuditLog: Low Stock Flagged",
            "type": "main",
            "index": 0
          }
        ],
        []
      ]
    }
  }
}