        "name": "WhatsApp: Staff Alert",
        "type": "n8n-nodes-base.httpRequest",
        "typeVersion": 4.1,
        "position": [540, 400]
      }
    ],
    "connections": { "Webhook: Staff Alert": { "main": [[{ "node": "Verify Internal Staff Sig", "type": "main", "index": 0 }]] }, "Verify Internal Staff Sig": { "main": [[{ "node": "Telegram: Staff Group", "type": "main", "index": 0 }, { "node": "WhatsApp: Staff Alert", "type": "main", "index": 0 }]] } }
