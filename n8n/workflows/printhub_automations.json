        "typeVersion": 1,
        "position": [540, 300]
      },
      {
        "parameters": { "url": "https://api.resend.com/emails", "method": "POST", "authentication": "headerAuth", "headerParameters": { "parameters": [{ "name": "Authorization", "value": "=Bearer {{$env.RESEND_API_KEY}}" }] }, "bodyParameters": { "parameters": [{ "name": "from", "value": "PrintHub Africa <shipping@printhub.africa>" }, { "name": "to", "value": "={{$json.customerEmail}}" }, { "name": "subject", "value": "=Your order {{$json.orderNumber}} is on its way!" }, { "name": "html", "value": "=<p>Exciting news {{$json.customerName}}! Your order is dispatched. Tracking: {{$json.trackingNumber}}</p>" }] } },
        "name": "Email: Dispatched",
        "type": "n8n-nodes-base.httpRequest",
        "typeVersion": 4.1,
        "position": [760, 200]
      }
    ],
    "connections": { "Webhook: Status Changed": { "main": [[{ "node": "Verify Internal Auth", "type": "main", "index": 0 }]] }, "Verify Internal Auth": { "main": [[{ "node": "If Dispatched", "type": "main", "index": 0 }]] }, "If Dispatched": { "main": [[{ "node": "Email: Dispatched", "type": "main", "index": 0 }]] } }
