        "parameters": { "jsCode": "const { exportFlags, mockups, videos, captions, name, slug, price, description } = $json;\nreturn [{\n  productId: $json.id,\n  productName: name,\n  productSlug: slug,\n  price,\n  description,\n  exportFlags,\n  mockups: mockups || [],\n  videos: videos || [],\n  captions: captions || { instagram: '', linkedin: '', tiktok: '', youtube_community: '' }\n}];" },
