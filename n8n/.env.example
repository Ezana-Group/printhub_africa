# ==============================================================================
# n8n PrintHub Africa — FRESH INSTALL MINIMAL CONFIG (v5.0)
# ==============================================================================

# --- n8n CORE CONFIGURATION ---
N8N_HOST="n8n.example.com"
N8N_PORT="5678"
N8N_PROTOCOL="http"
WEBHOOK_URL="https://n8n.example.com"
N8N_EDITOR_BASE_URL="https://n8n.example.com"
N8N_URL="https://n8n.example.com"

# --- DATABASE CONFIGURATION (POSTGRES) ---
DB_TYPE="postgresdb"
DB_POSTGRESDB_HOST="your-db-host"
DB_POSTGRESDB_PORT="5432"
DB_POSTGRESDB_DATABASE="n8n"
DB_POSTGRESDB_USER="your-db-user"
DB_POSTGRESDB_PASSWORD="your-db-password"
DB_POSTGRESDB_SCHEMA="n8n_fresh_v5"
DB_POSTGRESDB_SSL_REJECT_UNAUTHORIZED="false"
DB_POSTGRESDB_SSL_MODE="require"

# --- SYSTEM SETTINGS ---
NODE_ENV="production"
N8N_LOG_LEVEL="info"
N8N_METRICS="true"
N8N_SKIP_DATABASE_INIT="false"
N8N_HEALTHCHECK_ACTIVE="true"
