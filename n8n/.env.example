# ==============================================================================
# n8n PrintHub Africa — Environment Variables Template (v3.1)
# Copy this file to .env and fill in all blank values.
# ==============================================================================

# --- n8n CORE CONFIGURATION ---
N8N_HOST="n8n.printhub.africa"
N8N_PORT="5678"
N8N_PROTOCOL="http"
WEBHOOK_URL="https://n8n.printhub.africa"
N8N_EDITOR_BASE_URL="https://n8n.printhub.africa"
N8N_ENCRYPTION_KEY=""
N8N_WEBHOOK_SECRET=""
# Used by Workflow 7 self-trigger node as $env.N8N_URL
N8N_URL="n8n.printhub.africa"

# --- AUTHENTICATION ---
N8N_BASIC_AUTH_ACTIVE="true"
N8N_BASIC_AUTH_USER="admin"
N8N_BASIC_AUTH_PASSWORD=""

# --- DATABASE CONFIGURATION (NEON POSTGRES) ---
DB_TYPE="postgresdb"
DB_POSTGRESDB_HOST=""
DB_POSTGRESDB_PORT="5432"
DB_POSTGRESDB_DATABASE="n8n_printhubdb"
DB_POSTGRESDB_USER=""
DB_POSTGRESDB_PASSWORD=""
DB_POSTGRESDB_SCHEMA="public"
DB_POSTGRESDB_SSL_REJECT_UNAUTHORIZED="false"
DB_POSTGRESDB_SSL_MODE="require"

# --- n8n SYSTEM OVERRIDES ---
N8N_SKIP_DATABASE_INIT="false"
N8N_VERSION_NOTIFICATIONS_ENABLED="false"

# --- SYSTEM & LOGGING ---
NODE_ENV="production"
N8N_LOG_LEVEL="info"
N8N_METRICS="true"
N8N_ENFORCE_SETTINGS_FILE_PERMISSIONS="false"

# --- PRINTHUB INTEGRATION ---
PRINTHUB_API_URL="https://printhub.africa"
RESEND_API_KEY=""
FROM_EMAIL="hello@printhub.africa"
FROM_NAME="PrintHub Africa"
# Notification recipients — used by AI-8, AI-9, AI-10, AI-12, Cron AI-1, Cron AI-3
ADMIN_EMAIL="admin@printhub.africa"
# Used by Cron AI-3 monthly BI report
SUPER_ADMIN_EMAIL="admin@printhub.africa"

# --- BRAND VOICE & AI APPROVALS ---
AI_APPROVAL_EMAIL="marketing@printhub.africa"
AI_REQUIRE_APPROVAL="true"
PRINTHUB_BRAND_VOICE="Professional, Nairobi-based, British English, Expert tone. Prices in KES."

# --- CLOUDFLARE R2 STORAGE ---
R2_ENDPOINT=""
R2_ACCESS_KEY_ID=""
R2_SECRET_ACCESS_KEY=""
R2_PUBLIC_BUCKET="printhub-public"
R2_PUBLIC_URL=""

# --- AFRICA'S TALKING ---
# ⚠️  Set AT_USERNAME to your production Africa's Talking username (not "sandbox") before go-live
AT_API_KEY=""
AT_USERNAME=""
AT_SENDER_ID="PrintHub"

# --- WHATSAPP BUSINESS ---
WHATSAPP_PHONE_NUMBER_ID=""
WHATSAPP_ACCESS_TOKEN=""
WHATSAPP_CHANNEL_ID=""

# --- META / FACEBOOK ---
META_ACCESS_TOKEN=""
META_PIXEL_ID=""
META_AD_ACCOUNT_ID=""
META_CATALOG_ID=""

# --- TIKTOK ---
TIKTOK_EVENTS_API_TOKEN=""
TIKTOK_AD_ACCOUNT_ID=""
TIKTOK_CATALOG_ID=""

# --- GOOGLE ADS & MERCHANT ---
GOOGLE_ADS_DEVELOPER_TOKEN=""
GOOGLE_ADS_CUSTOMER_ID=""
GOOGLE_ADS_REFRESH_TOKEN=""
GOOGLE_ADS_CLIENT_ID=""
GOOGLE_ADS_CLIENT_SECRET=""
GOOGLE_MERCHANT_ID=""
GOOGLE_INDEXING_KEY=""

# --- GOOGLE BUSINESS PROFILE (AI-11 — Google Maps posting) ---
GOOGLE_ACCOUNT_ID=""
GOOGLE_LOCATION_ID=""
GOOGLE_MAPS_PLACE_ID=""

# --- BING PLACES (AI-11) ---
BING_MAPS_KEY=""
BING_BUSINESS_ID=""

# --- APPLE MAPS (AI-11) ---
APPLE_MAPS_ACCESS_TOKEN=""
APPLE_KEY_ID=""
APPLE_TEAM_ID=""
APPLE_PRIVATE_KEY=""
APPLE_PLACE_ID=""

# --- INSTAGRAM (Workflow 7 — Graph API publishing) ---
INSTAGRAM_USER_ID=""

# --- SOCIAL CHANNELS ---
TELEGRAM_BOT_TOKEN=""
TELEGRAM_CHANNEL_ID=""
JIJI_EMAIL=""
JIJI_PASSWORD=""

# --- KENYA CLASSIFIEDS ---
PIGIAME_EMAIL=""
PIGIAME_PASSWORD=""
OLX_EMAIL=""
OLX_PASSWORD=""

# --- SOCIAL — Medium / Reddit / LinkedIn ---
MEDIUM_INTEGRATION_TOKEN=""
# MEDIUM_TOKEN must match MEDIUM_INTEGRATION_TOKEN — used inside workflow JSON
MEDIUM_TOKEN=""
MEDIUM_USER_ID=""
REDDIT_CLIENT_ID=""
REDDIT_CLIENT_SECRET=""
REDDIT_USERNAME=""
REDDIT_PASSWORD=""
LINKEDIN_ORGANIZATION_ID=""
LINKEDIN_NEWSLETTER_ID=""
NEXTDOOR_API_KEY=""

# --- BUSINESS CONTACT (used in PigiaMe/OLX listing posts) ---
BUSINESS_PHONE=""

# --- AI & AUTOMATION ---
ANTHROPIC_API_KEY=""
OPENAI_API_KEY=""
STABILITY_API_KEY=""
ELEVENLABS_API_KEY=""
ELEVENLABS_VOICE_ID=""
RUNWAY_API_KEY=""
GEMINI_API_KEY=""
PERPLEXITY_API_KEY=""

# --- MEDIA & OTHERS ---
FFMPEG_SERVICE_URL=""
COMBINE_SECRET=""
