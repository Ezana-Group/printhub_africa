# ==============================================================================
# n8n PrintHub Africa — FRESH INSTALL MINIMAL CONFIG (v5.0)
# ==============================================================================

# --- n8n CORE CONFIGURATION ---
N8N_HOST="n8n.example.com"
N8N_PORT="5678"
N8N_PROTOCOL="http"
WEBHOOK_URL="https://n8n.example.com"
N8N_EDITOR_BASE_URL="https://n8n.example.com"
N8N_URL="https://n8n.example.com"

# IMPORTANT: Keep encryption keys consistent for credential extraction later if needed
N8N_ENCRYPTION_KEY="replace-with-64-char-hex"
N8N_WEBHOOK_SECRET="replace-with-64-char-hex"

# --- DATABASE CONFIGURATION (POSTGRES) ---
DB_TYPE="postgresdb"
DB_POSTGRESDB_HOST="your-db-host"
DB_POSTGRESDB_PORT="5432"
DB_POSTGRESDB_DATABASE="n8n"
DB_POSTGRESDB_USER="your-db-user"
DB_POSTGRESDB_PASSWORD="your-db-password"
DB_POSTGRESDB_SCHEMA="n8n_fresh_v5"
DB_POSTGRESDB_SSL_REJECT_UNAUTHORIZED="false"
DB_POSTGRESDB_SSL_MODE="require"

# --- WHATSAPP CLOUD API (Meta) ---
WHATSAPP_PHONE_NUMBER_ID=""
WHATSAPP_WABA_ID=""
WHATSAPP_ACCESS_TOKEN=""

# --- TELEGRAM BOT API ---
TELEGRAM_BOT_TOKEN=""
TELEGRAM_STAFF_GROUP_ID=""
TELEGRAM_CHANNEL_ID=""

# --- STAFF NOTIFICATIONS ---
STAFF_WHATSAPP_NUMBER="" # Format: 254XXXXXXXXX

# --- EMAIL (Resend) ---
RESEND_API_KEY=""

# --- SMS (Africa's Talking) ---
AT_USERNAME=""
AT_API_KEY=""

# --- AI ENGINES (Catalogue & Content) ---
OPENAI_API_KEY=""
ANTHROPIC_API_KEY=""
PERPLEXITY_API_KEY=""

# --- ANALYTICS (Meta CAPI) ---
META_PIXEL_ID=""
META_ACCESS_TOKEN=""

# --- PLATFORM SYNC CREDENTIALS ---
JIJI_EMAIL=""
JIJI_PASSWORD=""
PIGIAME_EMAIL=""
PIGIAME_PASSWORD=""
OLX_EMAIL=""
OLX_PASSWORD=""

# --- SYSTEM SETTINGS ---
NODE_ENV="production"
N8N_LOG_LEVEL="info"
N8N_METRICS="true"
N8N_SKIP_DATABASE_INIT="false"
N8N_HEALTHCHECK_ACTIVE="true"